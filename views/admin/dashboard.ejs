<div class="grid grid-cols-12 gap-8">
    <section class="col-span-12 xl:col-span-9 space-y-8">
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
            <div class="rounded-xl bg-surface-container p-5 hover:bg-surface-container-high transition-all duration-150">
                <div class="flex items-start justify-between mb-5">
                    <span class="material-symbols-outlined text-primary">stadium</span>
                    <span class="px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-[0.14em] bg-primary/10 text-primary">
                        Đang hoạt động <%= stats.activeFields %>
                    </span>
                </div>
                <p class="text-[11px] font-bold uppercase tracking-[0.14em] text-on-surface-variant mb-2">Tổng số sân</p>
                <p class="text-3xl font-bold headline-tight text-white"><%= stats.totalFields %></p>
            </div>

            <div class="rounded-xl bg-surface-container p-5 hover:bg-surface-container-high transition-all duration-150">
                <div class="flex items-start justify-between mb-5">
                    <span class="material-symbols-outlined text-primary">event_available</span>
                    <span class="px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-[0.14em] bg-primary/10 text-primary">
                        <%= stats.confirmedToday %> đã duyệt
                    </span>
                </div>
                <p class="text-[11px] font-bold uppercase tracking-[0.14em] text-on-surface-variant mb-2">Đơn đặt hôm nay</p>
                <p class="text-3xl font-bold headline-tight text-white"><%= stats.todayBookings %></p>
            </div>

            <div class="rounded-xl bg-surface-container p-5 hover:bg-surface-container-high transition-all duration-150">
                <div class="flex items-start justify-between mb-5">
                    <span class="material-symbols-outlined text-secondary">payments</span>
                    <span class="px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-[0.14em] <%= trends.revenueChange >= 0 ? 'bg-primary/10 text-primary' : 'bg-error/10 text-error' %>">
                        <%= trends.revenueChange >= 0 ? '+' : '' %><%= trends.revenueChange %>%
                    </span>
                </div>
                <p class="text-[11px] font-bold uppercase tracking-[0.14em] text-on-surface-variant mb-2">Doanh thu trong ngày</p>
                <p class="text-3xl font-bold headline-tight text-white"><%= stats.dailyRevenue.toLocaleString('vi-VN') %>đ</p>
            </div>

            <div class="rounded-xl bg-surface-container p-5 hover:bg-surface-container-high transition-all duration-150">
                <div class="flex items-start justify-between mb-5">
                    <span class="material-symbols-outlined text-secondary">monitoring</span>
                    <span class="px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-[0.14em] <%= trends.volumeChange >= 0 ? 'bg-primary/10 text-primary' : 'bg-error/10 text-error' %>">
                        <%= trends.volumeChange >= 0 ? '+' : '' %><%= trends.volumeChange %>%
                    </span>
                </div>
                <p class="text-[11px] font-bold uppercase tracking-[0.14em] text-on-surface-variant mb-2">Tỷ lệ lấp đầy</p>
                <p class="text-3xl font-bold headline-tight text-white"><%= stats.occupancyRate %>%</p>
            </div>
        </div>

        <div class="rounded-xl bg-surface-container p-6 overflow-hidden">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8">
                <div>
                    <h2 class="text-xl font-bold tracking-tight text-white">Xu hướng đặt sân</h2>
                    <p class="text-sm text-on-surface-variant mt-1">Biến động lượng đặt sân trong <%= currentRange %> ngày gần nhất.</p>
                </div>
                <div class="flex items-center gap-2 bg-surface-container-high rounded-lg p-1">
                    <a href="?range=7" class="px-4 py-2 rounded-md text-xs font-bold uppercase tracking-[0.14em] transition-all <%= currentRange === 7 ? 'bg-surface-lowest text-primary' : 'text-on-surface-variant hover:text-white' %>">
                        7 ngày
                    </a>
                    <a href="?range=30" class="px-4 py-2 rounded-md text-xs font-bold uppercase tracking-[0.14em] transition-all <%= currentRange === 30 ? 'bg-surface-lowest text-primary' : 'text-on-surface-variant hover:text-white' %>">
                        30 ngày
                    </a>
                </div>
            </div>

            <div class="h-64 flex items-end justify-between gap-2">
                <% chartData.forEach((item) => { %>
                    <% const height = Math.max((item.count / maxBookings) * 100, item.count > 0 ? 10 : 4); %>
                    <div class="flex-1 flex flex-col items-center gap-3 group">
                        <div class="w-full h-52 flex items-end">
                            <div class="w-full rounded-t-lg bg-surface-container-low relative transition-all duration-150 group-hover:bg-surface-container-high" style="height: <%= height %>%;">
                                <div class="absolute inset-0 rounded-t-lg <%= item.count === peakDay.count && item.date === peakDay.date ? 'bg-primary shadow-[0_-6px_18px_rgba(78,222,99,0.28)]' : 'bg-primary/25' %>"></div>
                                <div class="absolute -top-7 left-1/2 -translate-x-1/2 text-[10px] font-bold text-white opacity-0 group-hover:opacity-100 transition-opacity">
                                    <%= item.count %>
                                </div>
                            </div>
                        </div>
                        <div class="text-center">
                            <p class="text-[10px] font-bold uppercase tracking-[0.14em] <%= item.date === peakDay.date ? 'text-primary' : 'text-on-surface-variant' %>"><%= item.shortLabel %></p>
                            <p class="text-[10px] text-on-surface-variant/70 mt-1"><%= item.fullLabel %></p>
                        </div>
                    </div>
                <% }) %>
            </div>

            <div class="mt-6 rounded-lg bg-surface-container-high/60 p-4 flex flex-col md:flex-row md:items-center md:justify-between gap-3">
                <div>
                    <p class="text-[11px] font-bold uppercase tracking-[0.14em] text-on-surface-variant mb-1">Ngày cao điểm</p>
                    <p class="text-sm text-white"><%= peakDay.shortLabel %> ghi nhận <span class="text-primary font-semibold"><%= peakDay.count %></span> lượt đặt.</p>
                </div>
                <a href="/admin/bookings" class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:text-white transition-colors">
                    Xem sổ đơn
                    <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                </a>
            </div>
        </div>

        <div class="rounded-xl bg-surface-container overflow-hidden">
            <div class="px-6 py-5 flex items-center justify-between bg-surface-container-high/40">
                <div>
                    <h2 class="text-xl font-bold tracking-tight text-white">Đơn đặt gần đây</h2>
                    <p class="text-sm text-on-surface-variant mt-1">Các đơn mới nhất vừa đi vào quy trình duyệt.</p>
                </div>
                <a href="/admin/bookings" class="text-sm font-semibold text-primary hover:text-white transition-colors">Xem tất cả</a>
            </div>

            <% if (recentBookings && recentBookings.length > 0) { %>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="bg-surface-lowest text-[10px] uppercase tracking-[0.14em] text-on-surface-variant">
                                <th class="px-6 py-4 font-bold">ID</th>
                                <th class="px-6 py-4 font-bold">Khách hàng</th>
                                <th class="px-6 py-4 font-bold">Sân</th>
                                <th class="px-6 py-4 font-bold">Thời gian</th>
                                <th class="px-6 py-4 font-bold">Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% recentBookings.forEach((booking) => { %>
                                <tr class="cursor-pointer hover:bg-surface-container-high transition-colors" onclick="window.location='/admin/bookings/<%= booking._id %>'">
                                    <td class="px-6 py-4 text-xs font-mono text-on-surface-variant">#<%= booking._id.toString().slice(-6).toUpperCase() %></td>
                                    <td class="px-6 py-4 text-sm font-medium text-white"><%= booking.user ? booking.user.name : 'Khách không xác định' %></td>
                                    <td class="px-6 py-4 text-sm text-white"><%= booking.field ? booking.field.name : 'Sân không xác định' %></td>
                                    <td class="px-6 py-4 text-sm text-on-surface-variant">
                                        <%= booking.date ? new Date(booking.date).toLocaleDateString('vi-VN') : '--' %> · <%= booking.startTime %> - <%= booking.endTime %>
                                    </td>
                                    <td class="px-6 py-4">
                                        <% if (booking.status === 'confirmed') { %>
                                            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-[0.14em] bg-primary/10 text-primary">Đã duyệt</span>
                                        <% } else if (booking.status === 'pending') { %>
                                            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-[0.14em] bg-secondary/10 text-secondary">Chờ duyệt</span>
                                        <% } else { %>
                                            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-[0.14em] bg-error/10 text-error">Đã đóng</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="px-6 py-16 text-center">
                    <div class="w-16 h-16 rounded-full bg-surface-container-high flex items-center justify-center mx-auto mb-4">
                        <span class="material-symbols-outlined text-on-surface-variant">inbox</span>
                    </div>
                    <p class="text-lg font-semibold text-white mb-1">Chưa có tín hiệu đặt sân</p>
                    <p class="text-sm text-on-surface-variant">Các đơn mới sẽ xuất hiện tại đây khi người dùng hoàn tất thanh toán.</p>
                </div>
            <% } %>
        </div>
    </section>

    <aside class="col-span-12 xl:col-span-3 space-y-8">
        <div class="rounded-xl bg-surface-container p-6">
            <h2 class="text-[11px] font-bold uppercase tracking-[0.16em] text-on-surface-variant mb-5">Thao tác nhanh</h2>
            <div class="space-y-3">
                <a href="/admin/fields/create" class="flex items-center gap-3 p-3 rounded-lg bg-surface-container-high hover:bg-surface-variant transition-colors">
                    <span class="material-symbols-outlined text-primary">add_box</span>
                    <span class="text-sm font-medium text-white">Thêm sân mới</span>
                </a>
                <a href="/admin/bookings?status=pending" class="flex items-center gap-3 p-3 rounded-lg bg-surface-container-high hover:bg-surface-variant transition-colors">
                    <span class="material-symbols-outlined text-secondary">approval</span>
                    <span class="text-sm font-medium text-white">Xem đơn chờ duyệt</span>
                </a>
                <a href="/admin/schedule" class="flex items-center gap-3 p-3 rounded-lg bg-surface-container-high hover:bg-surface-variant transition-colors">
                    <span class="material-symbols-outlined text-primary">calendar_month</span>
                    <span class="text-sm font-medium text-white">Mở lịch tuần</span>
                </a>
            </div>
        </div>

        <div class="rounded-xl bg-surface-container p-6">
            <h2 class="text-[11px] font-bold uppercase tracking-[0.16em] text-on-surface-variant mb-5">Tóm tắt vận hành</h2>
            <div class="space-y-4">
                <div class="rounded-lg bg-surface-container-high p-4">
                    <p class="text-[10px] font-bold uppercase tracking-[0.14em] text-on-surface-variant mb-2">Chờ xử lý</p>
                    <p class="text-2xl font-bold headline-tight text-white"><%= stats.pendingBookings %></p>
                </div>
                <div class="rounded-lg bg-surface-container-high p-4">
                    <p class="text-[10px] font-bold uppercase tracking-[0.14em] text-on-surface-variant mb-2">Tài khoản người dùng</p>
                    <p class="text-2xl font-bold headline-tight text-white"><%= stats.totalUsers %></p>
                </div>
            </div>
        </div>

        <div class="rounded-xl border border-primary/20 bg-gradient-to-br from-primary-container/10 to-surface-lowest p-5">
            <div class="flex items-center gap-2 text-primary mb-3">
                <span class="material-symbols-outlined text-[18px]">tips_and_updates</span>
                <span class="text-[10px] font-bold uppercase tracking-[0.16em]">Gợi ý vận hành</span>
            </div>
            <p class="text-sm leading-6 text-on-surface">
                Nhu cầu đạt đỉnh vào <span class="font-semibold text-primary"><%= peakDay.shortLabel %></span>. Hãy rà soát giá sân và phân bổ nhân sự quanh khung này để giữ tốc độ duyệt đơn và hiệu suất lấp đầy.
            </p>
        </div>
    </aside>
</div>
