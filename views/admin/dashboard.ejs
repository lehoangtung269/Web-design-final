<div class="grid grid-cols-12 gap-8">
    <!-- Left Column (75%) -->
    <div class="col-span-12 lg:col-span-9 space-y-12">
        
        <!-- KPI Bento Grid -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
            <div class="bg-surface p-6 relative group overflow-hidden">
                <div class="absolute inset-0 bg-surface-container transition-transform duration-300 transform scale-y-0 origin-bottom group-hover:scale-y-100 z-0"></div>
                <div class="relative z-10">
                    <div class="flex justify-between items-start mb-6">
                        <span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">stadium</span>
                    </div>
                    <p class="label-sm text-on-surface-variant mb-2">TOTAL FIELDS</p>
                    <h3 class="headline-lg text-on-surface"><%= stats.totalFields %></h3>
                </div>
            </div>
            
            <div class="bg-surface-container p-6 relative group overflow-hidden">
                <div class="absolute inset-0 bg-surface-container-high transition-transform duration-300 transform scale-y-0 origin-bottom group-hover:scale-y-100 z-0"></div>
                <div class="relative z-10">
                    <div class="flex justify-between items-start mb-6">
                        <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">event_available</span>
                        <% if (stats.pendingBookings > 0) { %>
                            <span class="label-sm text-background bg-primary px-3 py-1 ghost-border"><%= stats.pendingBookings %> PENDING</span>
                        <% } %>
                    </div>
                    <p class="label-sm text-on-surface-variant mb-2">TOTAL BOOKINGS</p>
                    <h3 class="headline-lg text-on-surface"><%= stats.totalBookings %></h3>
                </div>
            </div>
            
            <div class="bg-surface p-6 relative group overflow-hidden">
                <div class="absolute inset-0 bg-surface-container transition-transform duration-300 transform scale-y-0 origin-bottom group-hover:scale-y-100 z-0"></div>
                <div class="relative z-10">
                    <div class="flex justify-between items-start mb-6">
                        <span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">group</span>
                    </div>
                    <p class="label-sm text-on-surface-variant mb-2">TOTAL USERS</p>
                    <h3 class="headline-lg text-on-surface"><%= stats.totalUsers %></h3>
                </div>
            </div>
            
            <div class="bg-surface-container p-6 relative group overflow-hidden">
                <div class="absolute inset-0 bg-surface-container-high transition-transform duration-300 transform scale-y-0 origin-bottom group-hover:scale-y-100 z-0"></div>
                <div class="relative z-10">
                    <div class="flex justify-between items-start mb-6">
                        <span class="material-symbols-outlined text-error" style="font-variation-settings: 'FILL' 1;">pending_actions</span>
                    </div>
                    <p class="label-sm text-on-surface-variant mb-2">CRITICAL ACTIONS</p>
                    <h3 class="headline-lg text-error"><%= stats.pendingBookings %></h3>
                </div>
            </div>
        </div>

        <!-- Booking Trends Chart (Visual Mock) -->
        <div class="bg-surface-container p-8 relative">
            <div class="flex justify-between items-center mb-10">
                <div>
                    <h2 class="headline-sm text-on-surface mb-1">Utilization Matrix</h2>
                    <p class="label-md text-on-surface-variant">REAL-TIME PITCH ANALYTICS</p>
                </div>
                <div class="flex gap-4">
                    <a href="/admin/dashboard?range=7" class="label-sm px-4 py-2 <%= currentRange === 7 ? 'bg-surface-container-highest text-primary ghost-border' : 'bg-surface-container-low text-on-surface-variant hover:text-white' %> transition-colors">7 DAYS</a>
                    <a href="/admin/dashboard?range=30" class="label-sm px-4 py-2 <%= currentRange === 30 ? 'bg-surface-container-highest text-primary ghost-border' : 'bg-surface-container-low text-on-surface-variant hover:text-white' %> transition-colors">30 DAYS</a>
                </div>
            </div>
            
            <div class="h-48 flex items-end justify-between gap-[2px] px-2 border-b border-surface-container-highest pb-2">
                <% if (typeof chartData !== 'undefined' && chartData.length > 0) { 
                    chartData.forEach((point, i) => { 
                        const heightPercent = point.count > 0 ? (point.count / maxBookings) * 100 : 2;
                        const isToday = i === chartData.length - 1;
                %>
                    <div class="flex-1 bg-surface-container-highest relative group/bar transition-all hover:bg-outline-variant" style="height: <%= heightPercent %>%;">
                        <div class="absolute inset-0 <%= isToday && point.count > 0 ? 'bg-primary' : point.count === 0 ? 'bg-surface-container-lowest' : 'bg-secondary/40 group-hover/bar:bg-secondary' %> transition-all"></div>
                        <!-- Tooltip -->
                        <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-3 opacity-0 group-hover/bar:opacity-100 transition-opacity pointer-events-none z-10 w-max bg-surface-container-highest text-primary label-sm px-3 py-2 ambient-shadow">
                            <%= point.count %> OPS<br><span class="text-on-surface-variant"><%= point.date %></span>
                        </div>
                    </div>
                <% 
                    });
                } else { 
                %>
                    <div class="w-full flex items-center justify-center h-full text-on-surface-variant label-md">NO DATA IN REGION</div>
                <% } %>
            </div>
            <div class="flex justify-between mt-3 px-2 label-sm text-outline-variant">
                <% if (typeof chartData !== 'undefined' && chartData.length > 0) { 
                    const step = chartData.length > 15 ? Math.ceil(chartData.length / 5) : 1;
                    chartData.forEach((point, i) => {
                        if (i % step === 0 || i === chartData.length - 1) {
                %>
                    <span><%= point.label %></span>
                <%      } else if (chartData.length <= 15) { %>
                    <span class="opacity-0 sm:opacity-100"><%= point.label %></span>
                <%      }
                    });
                } %>
            </div>
        </div>

        <!-- Booking List Module (No-Line Implementation) -->
        <div class="bg-surface">
            <div class="flex justify-between items-center mb-6">
                <h2 class="headline-sm text-on-surface">Recent Logistics</h2>
                <a href="/admin/bookings" class="label-sm text-primary hover:text-white transition-colors">VIEW ALL OPS</a>
            </div>
            
            <% if (typeof recentBookings !== 'undefined' && recentBookings.length > 0) { %>
                <div class="flex flex-col gap-3">
                    <!-- Invisible Header explicitly for alignment in Tactical Mode -->
                    <div class="hidden md:flex px-6 py-2 label-sm text-on-surface-variant">
                        <div class="w-24">OP ID</div>
                        <div class="flex-1">CUSTOMER</div>
                        <div class="flex-1">PITCH</div>
                        <div class="flex-1">TIME WINDOW</div>
                        <div class="w-28 text-right">STATUS</div>
                    </div>
                    
                    <% recentBookings.forEach(booking => { %>
                    <div class="bg-surface-container hover:bg-surface-container-high transition-colors p-4 md:px-6 md:py-4 flex flex-col md:flex-row items-start md:items-center ghost-border cursor-pointer" onclick="window.location='/admin/bookings/<%= booking._id %>';">
                        <div class="w-24 label-sm text-on-surface-variant mb-2 md:mb-0">
                            #<%= booking._id.toString().substring(booking._id.toString().length - 6).toUpperCase() %>
                        </div>
                        <div class="flex-1 mb-2 md:mb-0 text-on-surface font-medium">
                            <%= booking.user ? booking.user.name : 'Unknown Operator' %>
                        </div>
                        <div class="flex-1 mb-2 md:mb-0 text-secondary label-md">
                            <%= booking.field ? booking.field.name : 'Unknown Sector' %>
                        </div>
                        <div class="flex-1 mb-3 md:mb-0 label-sm text-on-surface-variant">
                            <%= booking.startTime %> — <%= booking.endTime %>
                        </div>
                        <div class="w-28 flex justify-start md:justify-end">
                            <% if (booking.status === 'confirmed') { %>
                                <span class="label-sm bg-primary/20 text-primary px-3 py-1">CLEARED</span>
                            <% } else if (booking.status === 'pending') { %>
                                <span class="label-sm bg-secondary/20 text-secondary px-3 py-1">PENDING</span>
                            <% } else { %>
                                <span class="label-sm bg-error/20 text-error px-3 py-1">REJECTED</span>
                            <% } %>
                        </div>
                    </div>
                    <% }) %>
                </div>
            <% } else { %>
            <div class="p-8 text-center text-on-surface-variant label-md bg-surface-container">
                NO ACTIVE OPERATIONS FOUND.
            </div>
            <% } %>
        </div>
    </div>

    <!-- Right Column (25%) -->
    <aside class="col-span-12 lg:col-span-3 space-y-6">
        
        <!-- System Tip / Context Card -->
        <div class="bg-surface-container-lowest ghost-border p-6 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-16 h-16 bg-primary opacity-20 blur-[30px]"></div>
            <div class="flex items-center gap-3 text-primary mb-4 relative z-10">
                <span class="material-symbols-outlined text-lg">radar</span>
                <span class="label-sm">TACTICAL HUD</span>
            </div>
            <p class="text-on-surface-variant text-sm leading-relaxed relative z-10">
                You have <strong class="text-error"><%= stats.pendingBookings %> pending</strong> operations. Maintain response latency under 15 minutes to guarantee peak retention velocity.
            </p>
        </div>
        
        <!-- Quick Actions -->
        <div class="bg-surface p-6 ghost-border">
            <h2 class="label-sm text-on-surface-variant mb-6">OPERATIONAL DIRECTIVES</h2>
            
            <div class="flex flex-col gap-3">
                <a href="/admin/fields/create" class="flex items-center gap-4 bg-surface-container p-4 hover:bg-surface-container-high transition-colors text-on-surface label-md group">
                    <span class="material-symbols-outlined text-primary group-hover:scale-110 transition-transform">add_box</span>
                    NEW SECTOR
                </a>
                
                <a href="/admin/bookings?status=pending" class="flex items-center gap-4 bg-surface-container p-4 hover:bg-surface-container-high transition-colors text-on-surface label-md group">
                    <span class="material-symbols-outlined text-secondary group-hover:scale-110 transition-transform">fact_check</span>
                    REVIEW QUEUE
                </a>
                
                <a href="/admin/users" class="flex items-center gap-4 bg-surface-container p-4 hover:bg-surface-container-high transition-colors text-on-surface label-md group">
                    <span class="material-symbols-outlined text-outline-variant group-hover:scale-110 transition-transform">manage_accounts</span>
                    OPERATOR COMM
                </a>
            </div>
        </div>

        <!-- Live Feed -->
        <div class="bg-surface p-6 ghost-border">
            <h2 class="label-sm text-on-surface-variant mb-6">LIVE TELEMETRY</h2>
            <div class="space-y-6 relative before:absolute before:left-[11px] before:top-2 before:bottom-2 before:w-[2px] before:bg-surface-container-high">
                
                <div class="relative pl-8">
                    <div class="absolute left-2 top-1.5 w-2 h-2 rounded-full bg-primary ring-4 ring-surface"></div>
                    <p class="label-sm text-primary mb-1">T-00:00:01</p>
                    <p class="text-sm font-medium text-on-surface-variant">Kinetic HUD <span class="text-on-surface">ONLINE</span></p>
                </div>
                
                <div class="relative pl-8">
                    <div class="absolute left-2 top-1.5 w-2 h-2 rounded-full bg-secondary ring-4 ring-surface"></div>
                    <p class="label-sm text-on-surface-variant mb-1">T-00:15:00</p>
                    <p class="text-sm font-medium text-on-surface-variant">Data sync <span class="text-on-surface">success</span></p>
                </div>
                
            </div>
        </div>
        
    </aside>
</div>