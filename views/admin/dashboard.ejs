<!-- Telemetry Modules (Stat Cards) -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    <div class="bg-surface rounded-3xl p-6 ghost-border relative overflow-hidden group hover:-translate-y-1 hover:bg-surface-high transition-all duration-500 shadow-ambient hover:shadow-glow">
        <div class="absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-full blur-2xl group-hover:bg-primary/10 transition-colors"></div>
        <div class="label-sm text-on-surface-variant mb-2">Total Entities</div>
        <div class="headline-lg text-4xl text-white"><%= stats.totalUsers %></div>
        <div class="mt-4 flex items-center gap-2 text-xs text-primary bg-primary/10 w-fit px-2 py-1 rounded-md">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
            Live tracking active
        </div>
    </div>

    <div class="bg-surface rounded-3xl p-6 ghost-border relative overflow-hidden group hover:-translate-y-1 hover:bg-surface-high transition-all duration-500 shadow-ambient hover:shadow-glow">
        <div class="absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-full blur-2xl group-hover:bg-primary/10 transition-colors"></div>
        <div class="label-sm text-on-surface-variant mb-2">Volume Processed</div>
        <div class="headline-lg text-4xl text-white"><%= stats.totalBookings %></div>
    </div>

    <div class="bg-surface rounded-3xl p-6 ghost-border relative overflow-hidden group hover:-translate-y-1 hover:bg-surface-high transition-all duration-500 shadow-ambient hover:shadow-glow">
        <div class="absolute top-0 right-0 w-32 h-32 bg-warning/5 rounded-full blur-2xl group-hover:bg-warning/10 transition-colors"></div>
        <div class="label-sm text-on-surface-variant mb-2 text-warning">Pending Signals</div>
        <div class="headline-lg text-4xl text-warning"><%= stats.pendingBookings %></div>
        <a href="/admin/bookings?status=pending" class="absolute bottom-6 right-6 text-warning opacity-0 group-hover:opacity-100 transition-opacity">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </a>
    </div>

    <div class="bg-surface rounded-3xl p-6 ghost-border relative overflow-hidden group hover:-translate-y-1 hover:bg-surface-high transition-all duration-500 shadow-ambient hover:shadow-glow">
        <div class="absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-full blur-2xl group-hover:bg-primary/10 transition-colors"></div>
        <div class="label-sm text-on-surface-variant mb-2">Active Arenas</div>
        <div class="headline-lg text-4xl text-white"><%= stats.totalFields %></div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mt-8">
    <!-- Signal Activity Chart (No-Line CSS Graph) -->
    <div class="lg:col-span-2 bg-surface rounded-3xl p-8 ghost-border shadow-ambient flex flex-col">
        <div class="flex justify-between items-center mb-8">
            <h2 class="headline-md text-xl">Signal Activity (<%= currentRange %> Days)</h2>
            <div class="flex gap-2 bg-surface-low p-1 rounded-xl ghost-border">
                <a href="?range=7" class="px-4 py-1.5 rounded-lg text-sm font-medium transition-colors <%= currentRange === 7 ? 'bg-primary/20 text-primary' : 'text-on-surface-variant hover:text-white' %>">7D</a>
                <a href="?range=30" class="px-4 py-1.5 rounded-lg text-sm font-medium transition-colors <%= currentRange === 30 ? 'bg-primary/20 text-primary' : 'text-on-surface-variant hover:text-white' %>">30D</a>
            </div>
        </div>
        
        <div class="flex-1 flex items-end justify-between gap-2 h-48 relative pt-4">
            <!-- Ghost grid lines -->
            <div class="absolute inset-0 flex flex-col justify-between pointer-events-none opacity-10">
                <div class="h-px w-full bg-white"></div>
                <div class="h-px w-full bg-white"></div>
                <div class="h-px w-full bg-white"></div>
            </div>
            
            <% chartData.forEach(data => { 
                const heightPercent = (data.count / maxBookings) * 100;
            %>
                <div class="flex flex-col items-center flex-1 group z-10">
                    <div class="w-full relative flex justify-center h-full items-end">
                        <div class="w-full max-w-[24px] bg-surface-high rounded-t-sm transition-all duration-500 group-hover:bg-primary relative" style="height: <%= heightPercent === 0 ? 2 : heightPercent %>%">
                            <% if(data.count > 0) { %>
                                <div class="absolute -top-8 left-1/2 -translate-x-1/2 bg-surface-lowest text-xs py-1 px-2 rounded opacity-0 group-hover:opacity-100 transition-opacity ghost-border whitespace-nowrap z-20">
                                    <%= data.count %> units
                                </div>
                            <% } %>
                        </div>
                    </div>
                    <% if (currentRange <= 14) { %>
                        <span class="text-[10px] text-on-surface-variant mt-3 whitespace-nowrap -rotate-45 block origin-top-left"><%= data.label %></span>
                    <% } %>
                </div>
            <% }) %>
        </div>
    </div>

    <!-- Recent Transmissions List (No-Line implementation) -->
    <div class="bg-surface rounded-3xl p-8 ghost-border shadow-ambient flex flex-col">
        <div class="flex justify-between items-center mb-6">
            <h2 class="headline-md text-xl">Recent Transmissions</h2>
            <a href="/admin/bookings" class="label-sm text-primary hover:text-white transition-colors">View All</a>
        </div>
        
        <div class="flex flex-col gap-3 flex-1">
            <% if (recentBookings && recentBookings.length > 0) { %>
                <% recentBookings.forEach(booking => { %>
                    <a href="/admin/bookings/<%= booking._id %>" class="bg-surface-lowest p-4 rounded-2xl flex flex-col gap-2 hover:bg-surface-high hover:translate-x-1 transition-all group">
                        <div class="flex justify-between items-start">
                            <div>
                                <span class="font-semibold text-white block group-hover:text-primary transition-colors"><%= booking.user ? booking.user.name : 'Unknown Entity' %></span>
                                <span class="text-xs text-on-surface-variant uppercase tracking-wider"><%= booking.field ? booking.field.name : 'Unknown Arena' %></span>
                            </div>
                            <span class="text-xs font-bold font-mono text-on-surface-variant bg-surface px-2 py-1 rounded"><%= booking.startTime %></span>
                        </div>
                        <div class="flex justify-between items-end mt-1">
                            <span class="text-sm text-white font-medium"><%= booking.totalPrice.toLocaleString('vi-VN') %>₫</span>
                            <% if (booking.status === 'pending') { %>
                                <span class="w-2 h-2 rounded-full bg-warning animate-pulse shadow-[0_0_8px_#FFD166]"></span>
                            <% } else if (booking.status === 'confirmed') { %>
                                <span class="w-2 h-2 rounded-full bg-primary shadow-[0_0_8px_#4EDE63]"></span>
                            <% } else { %>
                                <span class="w-2 h-2 rounded-full bg-danger"></span>
                            <% } %>
                        </div>
                    </a>
                <% }) %>
            <% } else { %>
                <div class="flex-1 flex flex-col items-center justify-center text-on-surface-variant opacity-50">
                    <svg class="w-12 h-12 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path></svg>
                    <span class="text-sm tracking-wide uppercase">No Signals</span>
                </div>
            <% } %>
        </div>
    </div>
</div>