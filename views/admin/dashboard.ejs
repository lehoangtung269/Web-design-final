<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | Admin</title>
</head>
<body>
  <%- include('partials/sidebar', { activeNav: 'dashboard' }) %>

  <div class="main-content">
    <div class="topbar">
      <h1>📊 Dashboard</h1>
      <div class="topbar-user">
        <span>Xin chào, <strong><%= currentUser.name %></strong></span>
        <a href="/auth/logout">Đăng xuất</a>
      </div>
    </div>

    <div class="page-content">
      <% if (typeof error !== 'undefined' && error.length > 0) { %>
        <div class="alert alert-error"><%= error[0] %></div>
      <% } %>
      <% if (typeof success !== 'undefined' && success.length > 0) { %>
        <div class="alert alert-success"><%= success[0] %></div>
      <% } %>

      <!-- Stat Cards -->
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 32px;">
        <div class="card" style="border-left: 4px solid #3b82f6;">
          <div style="color: #94a3b8; font-size: 13px; margin-bottom: 8px;">Tổng người dùng</div>
          <div style="font-size: 32px; font-weight: 700; color: #f8fafc;"><%= stats.totalUsers %></div>
        </div>
        <div class="card" style="border-left: 4px solid #fbbf24;">
          <div style="color: #94a3b8; font-size: 13px; margin-bottom: 8px;">Đơn chờ duyệt</div>
          <div style="font-size: 32px; font-weight: 700; color: #fbbf24;"><%= stats.pendingBookings %></div>
        </div>
        <div class="card" style="border-left: 4px solid #10b981;">
          <div style="color: #94a3b8; font-size: 13px; margin-bottom: 8px;">Tổng đơn đặt</div>
          <div style="font-size: 32px; font-weight: 700; color: #f8fafc;"><%= stats.totalBookings %></div>
        </div>
        <div class="card" style="border-left: 4px solid #a78bfa;">
          <div style="color: #94a3b8; font-size: 13px; margin-bottom: 8px;">Số sân bóng</div>
          <div style="font-size: 32px; font-weight: 700; color: #f8fafc;"><%= stats.totalFields %></div>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="card">
        <h3 style="margin-bottom: 16px; color: #f8fafc;">⚡ Thao tác nhanh</h3>
        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
          <a href="/admin/bookings?status=pending" class="btn btn-blue">📋 Đơn chờ duyệt</a>
          <a href="/admin/fields/create" class="btn btn-green">➕ Thêm sân mới</a>
          <a href="/admin/users" class="btn btn-outline">👥 Quản lý người dùng</a>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
