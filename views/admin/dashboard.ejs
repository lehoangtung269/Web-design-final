<div class="grid grid-cols-12 gap-8">
    <!-- Left Column (75%) -->
    <div class="col-span-12 lg:col-span-9 space-y-8">
        
        <!-- KPI Bento Grid -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div class="bg-surface-container p-5 rounded-xl border border-transparent hover:border-primary/10 transition-colors">
                <div class="flex justify-between items-start mb-4">
                    <span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">stadium</span>
                    <!-- You can add dynamic calculations here if you want +2 New context -->
                </div>
                <p class="text-on-surface-variant text-xs font-medium uppercase tracking-wider mb-1">Total Fields</p>
                <h3 class="text-2xl font-bold tracking-tight"><%= stats.totalFields %></h3>
            </div>
            
            <div class="bg-surface-container p-5 rounded-xl border border-transparent hover:border-primary/10 transition-colors">
                <div class="flex justify-between items-start mb-4">
                    <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">event_available</span>
                    <% if (stats.pendingBookings > 0) { %>
                        <span class="text-[10px] font-bold text-error px-2 py-0.5 bg-error/10 rounded-full"><%= stats.pendingBookings %> Pending</span>
                    <% } %>
                </div>
                <p class="text-on-surface-variant text-xs font-medium uppercase tracking-wider mb-1">Total Bookings</p>
                <h3 class="text-2xl font-bold tracking-tight"><%= stats.totalBookings %></h3>
            </div>
            
            <div class="bg-surface-container p-5 rounded-xl border border-transparent hover:border-primary/10 transition-colors">
                <div class="flex justify-between items-start mb-4">
                    <span class="material-symbols-outlined text-tertiary-container" style="font-variation-settings: 'FILL' 1;">group</span>
                </div>
                <p class="text-on-surface-variant text-xs font-medium uppercase tracking-wider mb-1">Total Users</p>
                <h3 class="text-2xl font-bold tracking-tight"><%= stats.totalUsers %></h3>
            </div>
            
            <div class="bg-surface-container p-5 rounded-xl border border-transparent hover:border-primary/10 transition-colors">
                <div class="flex justify-between items-start mb-4">
                    <span class="material-symbols-outlined text-secondary-container" style="font-variation-settings: 'FILL' 1;">pending_actions</span>
                </div>
                <p class="text-on-surface-variant text-xs font-medium uppercase tracking-wider mb-1">Pending Actions</p>
                <h3 class="text-2xl font-bold tracking-tight text-error"><%= stats.pendingBookings %></h3>
            </div>
        </div>

        <!-- Booking Trends Chart (Visual Mock) -->
        <div class="bg-surface-container rounded-xl p-6 relative overflow-hidden group">
            <div class="flex justify-between items-center mb-8">
                <div>
                    <h2 class="text-lg font-bold tracking-tight text-on-surface">Booking Trends</h2>
                    <p class="text-sm text-on-surface-variant">Real-time pitch utilization analytics (Mock)</p>
                </div>
                <div class="flex gap-2">
                    <a href="/admin/dashboard?range=7" class="text-xs font-semibold px-3 py-1.5 rounded-lg <%= currentRange === 7 ? 'bg-surface-container-highest text-on-surface' : 'text-on-surface-variant hover:text-white' %> transition-colors">7 Days</a>
                    <a href="/admin/dashboard?range=30" class="text-xs font-semibold px-3 py-1.5 rounded-lg <%= currentRange === 30 ? 'bg-surface-container-highest text-on-surface' : 'text-on-surface-variant hover:text-white' %> transition-colors">30 Days</a>
                </div>
            </div>
            
            <div class="h-64 flex items-end justify-between gap-1 px-2">
                <% if (typeof chartData !== 'undefined' && chartData.length > 0) { 
                    chartData.forEach((point, i) => { 
                        const heightPercent = point.count > 0 ? (point.count / maxBookings) * 100 : 5; // 5% minimum so bar is barely visible
                        const isToday = i === chartData.length - 1;
                %>
                    <div class="flex-1 bg-surface-container-low rounded-t-sm md:rounded-t-lg relative group/bar" style="height: <%= heightPercent %>%;">
                        <div class="absolute inset-0 <%= isToday && point.count > 0 ? 'bg-primary shadow-[0_-4px_12px_rgba(78,222,163,0.3)]' : point.count === 0 ? 'bg-surface-variant/30' : 'bg-primary/20 group-hover/bar:bg-primary/40' %> rounded-t-sm md:rounded-t-lg transition-all"></div>
                        <!-- Tooltip -->
                        <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 opacity-0 group-hover/bar:opacity-100 transition-opacity pointer-events-none z-10 w-max bg-[#0A0E13] text-on-surface text-[10px] font-bold px-2 py-1 rounded-md border border-outline-variant/20 whitespace-nowrap">
                            <%= point.count %> Bookings<br><span class="text-on-surface-variant font-medium"><%= point.date %></span>
                        </div>
                    </div>
                <% 
                    });
                } else { 
                %>
                    <div class="w-full flex items-center justify-center h-full text-on-surface-variant text-sm">No data available for this range.</div>
                <% } %>
            </div>
            <div class="flex justify-between mt-4 px-2 text-[8px] sm:text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">
                <% if (typeof chartData !== 'undefined' && chartData.length > 0) { 
                    const step = chartData.length > 15 ? Math.ceil(chartData.length / 5) : 1;
                    chartData.forEach((point, i) => {
                        if (i % step === 0 || i === chartData.length - 1) {
                %>
                    <span><%= point.label %></span>
                <%      } else if (chartData.length <= 15) { %>
                    <span class="opacity-0 sm:opacity-100"><%= point.label %></span>
                <%      }
                    });
                } %>
            </div>
        </div>

        <!-- Booking Table -->
        <div class="bg-surface-container rounded-xl overflow-hidden border border-transparent hover:border-outline-variant/10 transition-all">
            <div class="p-6 flex justify-between items-center border-b border-[#1C2025]">
                <h2 class="text-lg font-bold tracking-tight text-on-surface">Recent Bookings</h2>
                <a href="/admin/bookings" class="text-xs font-bold text-primary hover:underline">View All Bookings</a>
            </div>
            
            <% if (typeof recentBookings !== 'undefined' && recentBookings.length > 0) { %>
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-surface-container-low/50">
                        <th class="px-6 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest hidden sm:table-cell">ID</th>
                        <th class="px-6 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">Customer</th>
                        <th class="px-6 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">Field</th>
                        <th class="px-6 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest hidden md:table-cell">Time</th>
                        <th class="px-6 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-[#1C2025]">
                    <% recentBookings.forEach(booking => { %>
                    <tr class="hover:bg-surface-container-high transition-colors group" onclick="window.location='/admin/bookings/<%= booking._id %>';" style="cursor: pointer;">
                        <td class="px-6 py-4 text-xs font-mono text-on-surface-variant hidden sm:table-cell">#<%= booking._id.toString().substring(booking._id.toString().length - 6).toUpperCase() %></td>
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full bg-surface-container-highest flex items-center justify-center border border-outline-variant/30 text-xs font-bold text-on-surface overflow-hidden">
                                    <%= booking.user && booking.user.name ? booking.user.name.substring(0, 2).toUpperCase() : 'NA' %>
                                </div>
                                <span class="text-sm font-medium text-on-surface"><%= booking.user ? booking.user.name : 'Unknown User' %></span>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-sm font-medium text-on-surface"><%= booking.field ? booking.field.name : 'Unknown Field' %></td>
                        <td class="px-6 py-4 text-sm text-on-surface-variant hidden md:table-cell"><%= booking.startTime %> - <%= booking.endTime %></td>
                        <td class="px-6 py-4">
                            <% if (booking.status === 'confirmed') { %>
                                <span class="px-2.5 py-1 rounded-full text-[10px] font-bold bg-primary/10 text-primary uppercase tracking-wider">Confirmed</span>
                            <% } else if (booking.status === 'pending') { %>
                                <span class="px-2.5 py-1 rounded-full text-[10px] font-bold bg-secondary/10 text-secondary uppercase tracking-wider">Pending</span>
                            <% } else { %>
                                <span class="px-2.5 py-1 rounded-full text-[10px] font-bold bg-error/10 text-error uppercase tracking-wider">Rejected</span>
                            <% } %>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
            <% } else { %>
            <div class="p-8 text-center text-on-surface-variant text-sm">
                No recent bookings found.
            </div>
            <% } %>
        </div>
    </div>

    <!-- Right Column (25%) -->
    <aside class="col-span-12 lg:col-span-3 space-y-8">
        
        <!-- Quick Actions -->
        <div class="bg-surface-container rounded-xl p-6 space-y-4">
            <h2 class="text-sm font-bold uppercase tracking-widest text-on-surface-variant mb-4">Quick Actions</h2>
            
            <a href="/admin/fields/create" class="w-full flex items-center gap-3 p-3 rounded-lg bg-surface-container-high hover:bg-surface-container-highest border border-outline-variant/10 transition-all text-sm font-medium group text-on-surface">
                <span class="material-symbols-outlined text-primary group-hover:scale-110 transition-transform">add_box</span>
                Add New Field
            </a>
            
            <a href="/admin/bookings?status=pending" class="w-full flex items-center gap-3 p-3 rounded-lg bg-surface-container-high hover:bg-surface-container-highest border border-outline-variant/10 transition-all text-sm font-medium group text-on-surface">
                <span class="material-symbols-outlined text-secondary group-hover:scale-110 transition-transform">fact_check</span>
                Review Pending
            </a>
            
            <a href="/admin/users" class="w-full flex items-center gap-3 p-3 rounded-lg bg-surface-container-high hover:bg-surface-container-highest border border-outline-variant/10 transition-all text-sm font-medium group text-on-surface">
                <span class="material-symbols-outlined text-tertiary-container group-hover:scale-110 transition-transform">manage_accounts</span>
                Manage Customers
            </a>
        </div>

        <!-- Recent Activity Feed (Mocked Context from HTML) -->
        <div class="bg-surface-container rounded-xl p-6">
            <h2 class="text-sm font-bold uppercase tracking-widest text-on-surface-variant mb-6">Live Feed</h2>
            <div class="space-y-6 relative before:absolute before:left-3 before:top-2 before:bottom-2 before:w-px before:bg-outline-variant/20">
                
                <div class="relative pl-8 flex flex-col gap-1">
                    <div class="absolute left-1.5 top-1 w-3 h-3 rounded-full bg-primary ring-4 ring-surface"></div>
                    <span class="text-[10px] font-bold text-primary uppercase">Just Now</span>
                    <p class="text-sm font-medium leading-snug text-on-surface-variant">System initialized on <span class="text-on-surface">Node.js Server</span></p>
                </div>
                
                <div class="relative pl-8 flex flex-col gap-1">
                    <div class="absolute left-1.5 top-1 w-3 h-3 rounded-full bg-secondary ring-4 ring-surface"></div>
                    <span class="text-[10px] font-bold text-on-surface-variant uppercase">Recent</span>
                    <p class="text-sm font-medium leading-snug text-on-surface-variant">Dashboard UI <span class="text-on-surface">successfully updated to Tailwind template</span></p>
                </div>
                
            </div>
        </div>

        <!-- System Tip / Context Card -->
        <div class="bg-gradient-to-br from-primary-container/20 to-surface-container-lowest border border-primary/20 rounded-xl p-5">
            <div class="flex items-center gap-2 text-primary mb-3">
                <span class="material-symbols-outlined text-sm">tips_and_updates</span>
                <span class="text-[10px] font-bold uppercase tracking-widest">Tactical Tip</span>
            </div>
            <p class="text-xs text-on-surface leading-relaxed">
                You have <span class="font-bold text-error"><%= stats.pendingBookings %> pending bookings</span> requiring your attention. Keep your response time under 15 minutes to increase customer retention.
            </p>
        </div>
        
    </aside>
</div>