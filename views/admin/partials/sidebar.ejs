<!-- Mobile Hamburger Button -->
<button id="admin-mobile-menu-btn" class="fixed top-4 left-4 z-[60] lg:hidden w-10 h-10 rounded-xl bg-surface-container text-on-surface-variant hover:text-white hover:bg-surface-container-high ghost-border flex items-center justify-center transition-all" aria-label="Mở menu điều hướng">
  <span class="material-symbols-outlined text-[20px]" id="admin-menu-icon">menu</span>
</button>

<!-- Mobile Backdrop Overlay -->
<div id="admin-sidebar-backdrop" class="fixed inset-0 z-[55] bg-black/50 backdrop-blur-sm hidden lg:hidden transition-opacity duration-300 opacity-0"></div>

<!-- Sidebar (desktop: always visible, mobile: slide-in) -->
<aside id="admin-sidebar" class="fixed left-0 top-0 z-[60] h-screen w-64 bg-surface-lowest border-r border-white/5 flex flex-col transition-transform duration-300 -translate-x-full lg:translate-x-0">
    <!-- Close button for mobile -->
    <button id="admin-sidebar-close" class="lg:hidden absolute top-6 right-4 w-8 h-8 rounded-lg bg-surface-container text-on-surface-variant hover:text-white hover:bg-surface-container-high ghost-border flex items-center justify-center transition-all">
      <span class="material-symbols-outlined text-[18px]">close</span>
    </button>

    <div class="px-6 py-7 border-b border-white/5">
        <a href="/admin/dashboard" class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-primary text-on-primary flex items-center justify-center shadow-glow">
                <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">sports_soccer</span>
            </div>
            <div>
                <h1 class="text-lg font-extrabold tracking-tight text-primary">DatSan.vn</h1>
                <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant">Khu quản trị</p>
            </div>
        </a>
    </div>

    <nav class="flex-1 px-4 py-6 space-y-1">
        <a href="/admin/dashboard" class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-all duration-150 <%= activeNav === 'dashboard' ? 'bg-primary/10 text-primary border-r-2 border-primary' : 'text-on-surface-variant hover:text-white hover:bg-surface-container' %>">
            <span class="material-symbols-outlined text-[20px]">dashboard</span>
            Tổng quan
        </a>
        <a href="/admin/schedule" class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-all duration-150 <%= activeNav === 'schedule' ? 'bg-primary/10 text-primary border-r-2 border-primary' : 'text-on-surface-variant hover:text-white hover:bg-surface-container' %>">
            <span class="material-symbols-outlined text-[20px]">calendar_today</span>
            Lịch sân
        </a>
        <a href="/admin/bookings" class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-all duration-150 <%= activeNav === 'bookings' ? 'bg-primary/10 text-primary border-r-2 border-primary' : 'text-on-surface-variant hover:text-white hover:bg-surface-container' %>">
            <span class="material-symbols-outlined text-[20px]">confirmation_number</span>
            Đơn đặt sân
        </a>
        <a href="/admin/fields" class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-all duration-150 <%= activeNav === 'fields' ? 'bg-primary/10 text-primary border-r-2 border-primary' : 'text-on-surface-variant hover:text-white hover:bg-surface-container' %>">
            <span class="material-symbols-outlined text-[20px]">stadium</span>
            Quản lý sân
        </a>
        <a href="/admin/users" class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-all duration-150 <%= activeNav === 'users' ? 'bg-primary/10 text-primary border-r-2 border-primary' : 'text-on-surface-variant hover:text-white hover:bg-surface-container' %>">
            <span class="material-symbols-outlined text-[20px]">group</span>
            Người dùng
        </a>
    </nav>

    <div class="px-4 pb-4">
        <div class="rounded-xl bg-surface-container p-4 mb-3 ghost-border">
            <div class="flex items-center gap-2 text-primary mb-2">
                <span class="w-2 h-2 rounded-full bg-primary shadow-glow"></span>
                <span class="label-sm">Trạng thái hệ thống</span>
            </div>
            <p class="text-sm text-on-surface">Hoạt động ổn định</p>
            <p class="text-xs text-on-surface-variant mt-1">Toàn bộ luồng quản trị đang vận hành bình thường.</p>
        </div>

        <a href="/auth/logout" class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium text-on-surface-variant hover:text-error hover:bg-surface-container transition-all duration-150">
            <span class="material-symbols-outlined text-[20px]">logout</span>
            Đăng xuất
        </a>
    </div>
</aside>

<script>
(function() {
  var btn = document.getElementById('admin-mobile-menu-btn');
  var sidebar = document.getElementById('admin-sidebar');
  var backdrop = document.getElementById('admin-sidebar-backdrop');
  var closeBtn = document.getElementById('admin-sidebar-close');
  var menuIcon = document.getElementById('admin-menu-icon');
  if (!btn || !sidebar || !backdrop) return;

  function openSidebar() {
    sidebar.classList.remove('-translate-x-full');
    sidebar.classList.add('translate-x-0');
    backdrop.classList.remove('hidden', 'opacity-0');
    backdrop.classList.add('opacity-100');
    menuIcon.textContent = 'close';
    document.body.style.overflow = 'hidden';
  }

  function closeSidebar() {
    sidebar.classList.add('-translate-x-full');
    sidebar.classList.remove('translate-x-0');
    backdrop.classList.add('opacity-0');
    setTimeout(function() {
      backdrop.classList.add('hidden');
    }, 300);
    menuIcon.textContent = 'menu';
    document.body.style.overflow = '';
  }

  btn.addEventListener('click', function() {
    var isOpen = sidebar.classList.contains('translate-x-0');
    isOpen ? closeSidebar() : openSidebar();
  });

  backdrop.addEventListener('click', closeSidebar);
  if (closeBtn) closeBtn.addEventListener('click', closeSidebar);

  // Close on nav link click (mobile)
  sidebar.querySelectorAll('nav a').forEach(function(link) {
    link.addEventListener('click', function() {
      if (window.innerWidth < 1024) closeSidebar();
    });
  });

  // Handle resize
  window.addEventListener('resize', function() {
    if (window.innerWidth >= 1024) {
      sidebar.classList.remove('-translate-x-full');
      sidebar.classList.add('translate-x-0');
      backdrop.classList.add('hidden', 'opacity-0');
      document.body.style.overflow = '';
    } else {
      if (!sidebar.classList.contains('-translate-x-full')) {
        sidebar.classList.add('-translate-x-full');
        sidebar.classList.remove('translate-x-0');
        backdrop.classList.add('hidden', 'opacity-0');
      }
    }
  });
})();
</script>
