<div class="space-y-6">
    <!-- Filter HUD -->
    <div class="flex flex-col sm:flex-row justify-between items-center gap-4 bg-surface p-4 rounded-2xl ghost-border shadow-ambient">
        <div class="flex bg-surface-low rounded-xl p-1 ghost-border w-full sm:w-auto">
            <a href="?status=all" class="flex-1 sm:flex-none text-center px-6 py-2 rounded-lg text-sm font-medium transition-all <%= currentStatus === 'all' ? 'bg-primary/20 text-primary shadow-glow' : 'text-on-surface-variant hover:text-white' %>">All Signals</a>
            <a href="?status=pending" class="flex-1 sm:flex-none text-center px-6 py-2 rounded-lg text-sm font-medium transition-all flex items-center justify-center gap-2 <%= currentStatus === 'pending' ? 'bg-warning/20 text-warning shadow-[0_0_15px_rgba(255,209,102,0.2)]' : 'text-on-surface-variant hover:text-white' %>">
                Pending <% if(stats.pendingConf > 0) { %><span class="bg-warning text-black text-[10px] px-1.5 rounded font-bold"><%= stats.pendingConf %></span><% } %>
            </a>
            <a href="?status=confirmed" class="flex-1 sm:flex-none text-center px-6 py-2 rounded-lg text-sm font-medium transition-all <%= currentStatus === 'confirmed' ? 'bg-primary/20 text-primary shadow-glow' : 'text-on-surface-variant hover:text-white' %>">Confirmed</a>
        </div>
        
        <div class="label-sm text-on-surface-variant text-right">
            Vol: <span class="text-white ml-1"><%= stats.totalVolume %></span> <br/>
            Rev: <span class="text-primary ml-1"><%= stats.totalRevenue.toLocaleString('vi-VN') %>₫</span>
        </div>
    </div>

    <!-- Data Matrix (No-Line Table) -->
    <div class="bg-surface rounded-3xl p-6 ghost-border shadow-ambient overflow-x-auto">
        <table class="w-full text-left whitespace-nowrap border-spacing-y-2 border-separate">
            <thead>
                <tr class="!bg-transparent hover:!bg-transparent hover:!translate-y-0">
                    <th class="px-6 py-4 label-sm text-on-surface-variant font-medium">Transmission ID / Time</th>
                    <th class="px-6 py-4 label-sm text-on-surface-variant font-medium">Entity</th>
                    <th class="px-6 py-4 label-sm text-on-surface-variant font-medium">Arena Details</th>
                    <th class="px-6 py-4 label-sm text-on-surface-variant font-medium text-right">Value</th>
                    <th class="px-6 py-4 label-sm text-on-surface-variant font-medium text-center">Status</th>
                    <th class="px-6 py-4 label-sm text-on-surface-variant font-medium text-right">Action</th>
                </tr>
            </thead>
            <tbody>
                <% if (bookings.length > 0) { %>
                    <% bookings.forEach(booking => { %>
                        <tr class="group cursor-pointer hover:shadow-ambient" onclick="window.location='/admin/bookings/<%= booking._id %>'">
                            <td class="px-6 py-5">
                                <div class="font-mono text-xs text-on-surface-variant mb-1">#<%= booking._id.toString().slice(-8).toUpperCase() %></div>
                                <div class="text-sm text-white font-medium"><%= booking.date.toLocaleDateString('vi-VN') %></div>
                                <div class="text-xs text-primary bg-primary/10 inline-block px-2 py-0.5 rounded mt-1 font-mono"><%= booking.startTime %> - <%= booking.endTime %></div>
                            </td>
                            <td class="px-6 py-5">
                                <div class="text-sm font-semibold text-white"><%= booking.user ? booking.user.name : 'Unknown' %></div>
                                <div class="text-xs text-on-surface-variant mt-1"><%= booking.user ? booking.user.phone : '' %></div>
                            </td>
                            <td class="px-6 py-5">
                                <div class="text-sm text-white"><%= booking.field ? booking.field.name : 'Deleted Arena' %></div>
                            </td>
                            <td class="px-6 py-5 text-right">
                                <div class="text-sm font-bold text-white"><%= booking.totalPrice.toLocaleString('vi-VN') %>₫</div>
                            </td>
                            <td class="px-6 py-5 text-center">
                                <% if (booking.status === 'pending') { %>
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-warning/10 text-warning border border-warning/20">
                                        <span class="w-1.5 h-1.5 rounded-full bg-warning animate-pulse"></span> Pending
                                    </span>
                                <% } else if (booking.status === 'confirmed') { %>
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-primary/10 text-primary border border-primary/20">
                                        <span class="w-1.5 h-1.5 rounded-full bg-primary"></span> Confirmed
                                    </span>
                                <% } else { %>
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-danger/10 text-danger border border-danger/20">
                                        <span class="w-1.5 h-1.5 rounded-full bg-danger"></span> Rejected
                                    </span>
                                <% } %>
                            </td>
                            <td class="px-6 py-5 text-right">
                                <button class="w-8 h-8 rounded-full bg-surface-low flex items-center justify-center text-on-surface-variant group-hover:text-white group-hover:bg-primary/20 transition-all hover:shadow-glow">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                                </button>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="6" class="px-6 py-12 text-center !bg-transparent">
                            <div class="inline-flex justify-center items-center w-16 h-16 rounded-full bg-surface-high mb-4">
                                <svg class="w-8 h-8 text-on-surface-variant" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path></svg>
                            </div>
                            <h3 class="text-lg font-medium text-white mb-1">No signals detected</h3>
                            <p class="text-sm text-on-surface-variant">Adjust your parameters to find transmissions.</p>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>

        <!-- Pagination HUD -->
        <% if (totalPages > 1) { %>
            <div class="flex justify-center items-center gap-2 mt-8 pt-4">
                <% for (let i = 1; i <= totalPages; i++) { %>
                    <a href="?status=<%= currentStatus %>&page=<%= i %>" 
                       class="w-10 h-10 flex items-center justify-center rounded-xl text-sm font-medium transition-all ghost-border
                              <%= currentPage === i ? 'bg-primary/20 text-primary shadow-glow' : 'bg-surface-lowest text-on-surface-variant hover:bg-surface-high hover:text-white' %>">
                        <%= i %>
                    </a>
                <% } %>
            </div>
        <% } %>
    </div>
</div>