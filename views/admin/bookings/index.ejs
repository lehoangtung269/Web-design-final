<%
    const fieldQuery = currentFieldId !== 'all' ? '&fieldId=' + currentFieldId : '';
%>

<div class="space-y-8">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
        <div>
            <h2 class="text-3xl font-extrabold headline-tight text-white">Sổ đơn đặt sân</h2>
            <p class="text-sm text-on-surface-variant mt-2">Theo dõi phê duyệt, luồng thanh toán và các lượt đặt sân trong toàn hệ thống.</p>
        </div>

        <div class="flex flex-col sm:flex-row gap-3">
            <a href="/admin/bookings/export?status=<%= currentStatus %>&fieldId=<%= currentFieldId %>"
               class="flex items-center gap-2 px-5 py-3 rounded-2xl bg-surface-container text-on-surface-variant text-sm font-bold ghost-border hover:bg-surface-container-high hover:-translate-y-0.5 transition-all duration-300">
                <span class="material-symbols-outlined text-[18px]">download</span>
                Xuất CSV
            </a>
            <form action="/admin/bookings" method="GET" class="flex flex-col sm:flex-row gap-3">
            <input type="hidden" name="status" value="<%= currentStatus %>">
            <select name="fieldId" class="min-w-[220px] rounded-lg bg-surface-container border-none text-sm text-white focus:ring-1 focus:ring-primary/30">
                <option value="all" <%= currentFieldId === 'all' ? 'selected' : '' %>>Tất cả sân</option>
                <% fieldOptions.forEach((field) => { %>
                    <option value="<%= field._id %>" <%= currentFieldId === field._id.toString() ? 'selected' : '' %>><%= field.name %></option>
                <% }) %>
            </select>
            <button type="submit" class="px-5 py-3 rounded-2xl bg-surface-container-high text-white text-sm font-bold hover:bg-surface-variant hover:-translate-y-0.5 transition-all duration-300">
                Áp dụng phạm vi
            </button>
            </form>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
        <div class="rounded-xl bg-surface-container p-6 border border-[rgba(134,148,138,0.15)]">
            <p class="text-[11px] font-bold uppercase tracking-[0.14em] text-on-surface-variant mb-2">Tổng số đơn</p>
            <p class="text-3xl font-bold headline-tight text-white"><%= stats.totalVolume %></p>
            <p class="mt-3 text-xs <%= trends.volumeChange >= 0 ? 'text-primary' : 'text-error' %>">
                <%= trends.volumeChange >= 0 ? '+' : '' %><%= trends.volumeChange %>% so với tuần trước
            </p>
        </div>
        <div class="rounded-xl bg-surface-container p-6 border border-[rgba(134,148,138,0.15)]">
            <p class="text-[11px] font-bold uppercase tracking-[0.14em] text-on-surface-variant mb-2">Doanh thu</p>
            <p class="text-3xl font-bold headline-tight text-white"><%= stats.totalRevenue.toLocaleString('vi-VN') %>đ</p>
            <p class="mt-3 text-xs <%= trends.revenueChange >= 0 ? 'text-primary' : 'text-error' %>">
                <%= trends.revenueChange >= 0 ? '+' : '' %><%= trends.revenueChange %>% so với tuần trước
            </p>
        </div>
        <div class="rounded-xl bg-surface-container p-6 border border-[rgba(134,148,138,0.15)]">
            <p class="text-[11px] font-bold uppercase tracking-[0.14em] text-on-surface-variant mb-2">Đơn chờ duyệt</p>
            <p class="text-3xl font-bold headline-tight text-secondary"><%= stats.pendingConf %></p>
            <p class="mt-3 text-xs text-on-surface-variant">Cần quản trị viên xử lý thủ công</p>
        </div>
        <div class="rounded-xl bg-surface-container p-6 border border-[rgba(134,148,138,0.15)]">
            <p class="text-[11px] font-bold uppercase tracking-[0.14em] text-on-surface-variant mb-2">Tỷ lệ khai thác sân</p>
            <div class="flex items-center justify-between">
                <p class="text-3xl font-bold headline-tight text-white"><%= stats.utilization %>%</p>
                <div class="w-14 h-14 rounded-full border-4 border-surface-container-high border-t-primary border-r-primary flex items-center justify-center">
                    <span class="material-symbols-outlined text-primary">stadium</span>
                </div>
            </div>
        </div>
    </div>

    <div class="rounded-xl bg-surface-container border border-[rgba(134,148,138,0.15)] overflow-hidden shadow-ambient">
        <div class="p-4 bg-surface-container-high/40 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
            <div class="flex flex-wrap gap-2">
                <a href="?status=all<%= fieldQuery %>" class="px-4 py-2 rounded-lg text-xs font-bold uppercase tracking-[0.14em] transition-all <%= currentStatus === 'all' ? 'bg-surface-lowest text-primary' : 'text-on-surface-variant hover:text-white hover:bg-surface-container-high' %>">
                    Tất cả
                </a>
                <a href="?status=pending<%= fieldQuery %>" class="px-4 py-2 rounded-lg text-xs font-bold uppercase tracking-[0.14em] transition-all <%= currentStatus === 'pending' ? 'bg-surface-lowest text-secondary' : 'text-on-surface-variant hover:text-white hover:bg-surface-container-high' %>">
                    Chờ duyệt
                </a>
                <a href="?status=confirmed<%= fieldQuery %>" class="px-4 py-2 rounded-lg text-xs font-bold uppercase tracking-[0.14em] transition-all <%= currentStatus === 'confirmed' ? 'bg-surface-lowest text-primary' : 'text-on-surface-variant hover:text-white hover:bg-surface-container-high' %>">
                    Đã duyệt
                </a>
                <a href="?status=rejected<%= fieldQuery %>" class="px-4 py-2 rounded-lg text-xs font-bold uppercase tracking-[0.14em] transition-all <%= currentStatus === 'rejected' ? 'bg-surface-lowest text-error' : 'text-on-surface-variant hover:text-white hover:bg-surface-container-high' %>">
                    Từ chối
                </a>
            </div>
            <div class="text-xs text-on-surface-variant">
                Hiển thị <%= startItem %>-<%= endItem %> trên tổng <%= totalItems %> đơn
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="bg-surface-lowest text-[10px] uppercase tracking-[0.14em] text-on-surface-variant">
                        <th class="py-4 px-6 font-bold">ID</th>
                        <th class="py-4 px-6 font-bold">Khách hàng</th>
                        <th class="py-4 px-6 font-bold">Sân</th>
                        <th class="py-4 px-6 font-bold">Ngày & giờ</th>
                        <th class="py-4 px-6 font-bold text-right">Số tiền</th>
                        <th class="py-4 px-6 font-bold">Trạng thái</th>
                        <th class="py-4 px-6 font-bold text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="text-sm">
                    <% if (bookings.length > 0) { %>
                        <% bookings.forEach((booking) => { %>
                            <% const displayAmount = booking.finalTotal ?? booking.totalPrice ?? 0; %>
                            <tr class="hover:bg-surface-container-high/50 transition-colors group">
                                <td class="py-4 px-6 text-xs font-mono text-on-surface-variant">#<%= booking._id.toString().slice(-6).toUpperCase() %></td>
                                <td class="py-4 px-6">
                                    <div>
                                        <p class="font-semibold text-white"><%= booking.user ? booking.user.name : 'Người dùng không xác định' %></p>
                                        <p class="text-xs text-on-surface-variant mt-1"><%= booking.user ? booking.user.phone || booking.user.email || 'Không có liên hệ' : 'Không có liên hệ' %></p>
                                    </div>
                                </td>
                                <td class="py-4 px-6 text-white font-medium"><%= booking.field ? booking.field.name : 'Sân đã xóa' %></td>
                                <td class="py-4 px-6">
                                    <p class="text-white"><%= new Date(booking.date).toLocaleDateString('vi-VN') %></p>
                                    <p class="text-xs text-on-surface-variant mt-1"><%= booking.startTime %> - <%= booking.endTime %></p>
                                </td>
                                <td class="py-4 px-6 text-right font-semibold text-white"><%= displayAmount.toLocaleString('vi-VN') %>đ</td>
                                <td class="py-4 px-6">
                                    <% if (booking.status === 'confirmed') { %>
                                        <span class="inline-flex items-center px-2.5 py-1 rounded text-[10px] font-bold uppercase tracking-[0.14em] bg-primary/10 text-primary border border-primary/20">Đã duyệt</span>
                                    <% } else if (booking.status === 'pending') { %>
                                        <span class="inline-flex items-center px-2.5 py-1 rounded text-[10px] font-bold uppercase tracking-[0.14em] bg-secondary/10 text-secondary border border-secondary/20">Chờ duyệt</span>
                                    <% } else if (booking.status === 'cancelled') { %>
                                        <span class="inline-flex items-center px-2.5 py-1 rounded text-[10px] font-bold uppercase tracking-[0.14em] bg-surface-variant text-on-surface border border-white/10">Đã hủy</span>
                                    <% } else { %>
                                        <span class="inline-flex items-center px-2.5 py-1 rounded text-[10px] font-bold uppercase tracking-[0.14em] bg-error/10 text-error border border-error/20">Từ chối</span>
                                    <% } %>
                                </td>
                                <td class="py-4 px-6 text-center">
                                    <a href="/admin/bookings/<%= booking._id %>" class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-surface-container-high text-on-surface-variant hover:text-white hover:bg-surface-variant transition-colors">
                                        <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="7" class="px-6 py-16 text-center">
                                <div class="w-16 h-16 rounded-full bg-surface-container-high flex items-center justify-center mx-auto mb-4">
                                    <span class="material-symbols-outlined text-on-surface-variant">event_busy</span>
                                </div>
                                <p class="text-lg font-semibold text-white mb-1">Không tìm thấy đơn đặt sân</p>
                                <p class="text-sm text-on-surface-variant">Hãy điều chỉnh phạm vi hoặc bộ lọc trạng thái để xem nhóm đơn khác.</p>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <% if (totalPages > 1) { %>
            <div class="px-4 py-4 bg-surface-lowest flex items-center justify-between">
                <a href="?status=<%= currentStatus %>&fieldId=<%= currentFieldId %>&page=<%= Math.max(currentPage - 1, 1) %>" class="text-xs font-bold uppercase tracking-[0.14em] text-on-surface-variant hover:text-white transition-colors <%= currentPage === 1 ? 'pointer-events-none opacity-40' : '' %>">
                    Trước
                </a>
                <div class="flex items-center gap-1">
                    <% for (let i = 1; i <= totalPages; i++) { %>
                        <a href="?status=<%= currentStatus %>&fieldId=<%= currentFieldId %>&page=<%= i %>" class="w-8 h-8 rounded-md flex items-center justify-center text-xs font-bold transition-colors <%= currentPage === i ? 'bg-surface-container-high text-white border border-[rgba(134,148,138,0.15)]' : 'text-on-surface-variant hover:bg-surface-container-high hover:text-white' %>">
                            <%= i %>
                        </a>
                    <% } %>
                </div>
                <a href="?status=<%= currentStatus %>&fieldId=<%= currentFieldId %>&page=<%= Math.min(currentPage + 1, totalPages) %>" class="text-xs font-bold uppercase tracking-[0.14em] text-on-surface-variant hover:text-white transition-colors <%= currentPage === totalPages ? 'pointer-events-none opacity-40' : '' %>">
                    Sau
                </a>
            </div>
        <% } %>
    </div>
</div>
