<div class="space-y-6">
    <!-- Control Header -->
    <div class="bg-surface p-6 rounded-3xl ghost-border shadow-ambient flex flex-col md:flex-row justify-between items-center gap-4">
        <div>
            <h2 class="headline-md text-xl text-white">Entity Matrix</h2>
            <p class="text-sm text-on-surface-variant mt-1">Manage system access and roles.</p>
        </div>
        <div class="bg-surface-low px-6 py-3 rounded-2xl ghost-border">
            <%- topbarRight %> <!-- Render the total users count string from backend -->
        </div>
    </div>

    <!-- Entity Grid/List -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% if (users.length > 0) { %>
            <% users.forEach(user => { %>
                <div class="bg-surface rounded-3xl p-6 ghost-border flex flex-col relative overflow-hidden group hover:bg-surface-high hover:-translate-y-1 transition-all duration-300">
                    
                    <!-- Avatar & Status -->
                    <div class="flex justify-between items-start mb-6 relative z-10">
                        <div class="w-12 h-12 rounded-2xl bg-surface-low flex items-center justify-center text-xl font-black text-white ghost-border group-hover:text-primary transition-colors">
                            <%= user.name.charAt(0).toUpperCase() %>
                        </div>
                        <% if (user.isActive) { %>
                            <span class="bg-primary/10 text-primary px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider border border-primary/20 shadow-glow">Active</span>
                        <% } else { %>
                            <span class="bg-danger/10 text-danger px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider border border-danger/20">Terminated</span>
                        <% } %>
                    </div>

                    <!-- Info -->
                    <div class="relative z-10 flex-1">
                        <h3 class="text-lg font-bold text-white mb-1 truncate"><%= user.name %></h3>
                        <div class="text-sm font-mono text-on-surface-variant truncate"><%= user.email %></div>
                        <div class="text-sm font-mono text-on-surface-variant mt-1"><%= user.phone || 'No Comm Link' %></div>
                    </div>

                    <!-- Role Badge -->
                    <div class="mt-6 flex justify-between items-center relative z-10">
                        <span class="label-sm bg-surface-lowest px-3 py-1.5 rounded-lg ghost-border">
                            <%= user.role === 'admin' ? 'SYS_ADMIN' : (user.role === 'field_owner' ? 'OWNER_NODE' : 'USER_NODE') %>
                        </span>
                        
                        <!-- Actions -->
                        <form action="/admin/users/<%= user._id %>/toggle" method="POST" onsubmit="return confirm('Toggle operational status for this entity?');" class="inline">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="w-10 h-10 flex items-center justify-center rounded-xl bg-surface-low hover:bg-surface-lowest ghost-border transition-all <%= user.isActive ? 'text-danger hover:shadow-[0_0_15px_rgba(255,76,76,0.2)]' : 'text-primary hover:shadow-glow' %>" title="<%= user.isActive ? 'Terminate Access' : 'Restore Access' %>">
                                <% if (user.isActive) { %>
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                                <% } else { %>
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z"></path></svg>
                                <% } %>
                            </button>
                        </form>
                    </div>

                    <!-- Background graphic -->
                    <div class="absolute -bottom-8 -right-8 w-32 h-32 bg-white/[0.02] rounded-full pointer-events-none group-hover:bg-primary/[0.02] transition-colors"></div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-span-full py-12 text-center">
                <span class="text-on-surface-variant font-mono">No entities found in matrix.</span>
            </div>
        <% } %>
    </div>

    <!-- Pagination HUD -->
    <% if (totalPages > 1) { %>
        <div class="flex justify-center items-center gap-2 mt-8 pt-4">
            <% for (let i = 1; i <= totalPages; i++) { %>
                <a href="?page=<%= i %>" 
                   class="w-10 h-10 flex items-center justify-center rounded-xl text-sm font-medium transition-all ghost-border
                          <%= currentPage === i ? 'bg-primary/20 text-primary shadow-glow' : 'bg-surface text-on-surface-variant hover:bg-surface-high hover:text-white' %>">
                    <%= i %>
                </a>
            <% } %>
        </div>
    <% } %>
</div>