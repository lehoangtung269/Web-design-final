<div class="space-y-6">
    <div class="bg-surface p-6 rounded-3xl ghost-border shadow-ambient flex flex-col md:flex-row justify-between items-center gap-4">
        <div>
            <h2 class="headline-md text-xl text-white">Ma trận người dùng</h2>
            <p class="text-sm text-on-surface-variant mt-1">Quản lý quyền truy cập hệ thống, phân quyền chủ sân và gán sân nhanh.</p>
        </div>
        <div class="bg-surface-low px-6 py-3 rounded-2xl ghost-border">
            <%- topbarRight %>
        </div>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
        <% if (users.length > 0) { %>
            <% users.forEach((user) => { %>
                <%
                    const ownedFields = (ownedFieldsMap && ownedFieldsMap[user._id.toString()]) || [];
                    const isProtectedAdmin = user.role === 'admin';
                    const isSelf = currentUser && currentUser._id && currentUser._id.toString() === user._id.toString();
                    const toggleOnsubmit = isSelf ? 'return false;' : "return confirm('Thay đổi trạng thái hoạt động của tài khoản này?');";
                %>
                <div class="bg-surface rounded-3xl p-6 ghost-border flex flex-col relative overflow-hidden group hover:bg-surface-high transition-all duration-300">
                    <div class="flex justify-between items-start gap-4 mb-6 relative z-10">
                        <div class="flex items-center gap-4 min-w-0">
                            <div class="w-12 h-12 rounded-2xl bg-surface-low flex items-center justify-center text-xl font-black text-white ghost-border group-hover:text-primary transition-colors shrink-0">
                                <%= user.name.charAt(0).toUpperCase() %>
                            </div>
                            <div class="min-w-0">
                                <h3 class="text-lg font-bold text-white truncate"><%= user.name %></h3>
                                <div class="text-sm font-mono text-on-surface-variant truncate"><%= user.email %></div>
                                <div class="text-sm font-mono text-on-surface-variant mt-1"><%= user.phone || 'Chưa có số liên hệ' %></div>
                            </div>
                        </div>

                        <% if (user.isActive) { %>
                            <span class="bg-primary/10 text-primary px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider border border-primary/20 shadow-glow shrink-0">Hoạt động</span>
                        <% } else { %>
                            <span class="bg-danger/10 text-danger px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider border border-danger/20 shrink-0">Đã khóa</span>
                        <% } %>
                    </div>

                    <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-4 items-start relative z-10">
                        <div class="flex flex-wrap gap-2 items-center">
                            <span class="label-sm bg-surface-lowest px-3 py-1.5 rounded-lg ghost-border">
                                <%= user.role === 'admin' ? 'QUẢN TRỊ VIÊN' : (user.role === 'field_owner' ? 'CHỦ SÂN' : 'NGƯỜI DÙNG') %>
                            </span>
                            <% if (user.role === 'field_owner') { %>
                                <span class="text-[11px] font-semibold text-primary bg-primary/10 px-3 py-1.5 rounded-lg border border-primary/20">
                                    Hoa hồng <%= user.commissionRate || 5 %>%
                                </span>
                            <% } %>
                            <% if (isSelf) { %>
                                <span class="text-[11px] font-semibold text-secondary bg-secondary/10 px-3 py-1.5 rounded-lg border border-secondary/20">
                                    Phiên hiện tại
                                </span>
                            <% } %>
                        </div>

                        <form action="/admin/users/<%= user._id %>/toggle" method="POST" onsubmit="<%= toggleOnsubmit %>" class="inline">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" <%= isSelf ? 'disabled' : '' %> class="w-10 h-10 flex items-center justify-center rounded-xl bg-surface-low hover:bg-surface-lowest ghost-border transition-all <%= isSelf ? 'opacity-40 cursor-not-allowed text-on-surface-variant' : (user.isActive ? 'text-danger hover:shadow-[0_0_15px_rgba(255,76,76,0.2)]' : 'text-primary hover:shadow-glow') %>" title="<%= isSelf ? 'Không thể tự khóa chính mình' : (user.isActive ? 'Khóa tài khoản' : 'Mở khóa tài khoản') %>">
                                <% if (user.isActive) { %>
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                                <% } else { %>
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z"></path></svg>
                                <% } %>
                            </button>
                        </form>
                    </div>

                    <div class="mt-5 relative z-10">
                        <p class="text-[10px] font-bold uppercase tracking-[0.14em] text-on-surface-variant mb-2">Sân đang sở hữu</p>
                        <% if (ownedFields.length > 0) { %>
                            <div class="flex flex-wrap gap-2">
                                <% ownedFields.forEach((field) => { %>
                                    <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-surface-lowest border border-outline-variant/20 text-xs font-medium text-white">
                                        <span class="w-1.5 h-1.5 rounded-full <%= field.status === 'active' ? 'bg-primary' : 'bg-warning' %>"></span>
                                        <%= field.name %>
                                    </span>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <p class="text-sm text-on-surface-variant">Chưa sở hữu sân nào.</p>
                        <% } %>
                    </div>

                    <div class="mt-6 relative z-10">
                        <% if (isProtectedAdmin) { %>
                            <div class="rounded-2xl bg-surface-low p-4 ghost-border">
                                <p class="text-sm font-semibold text-white mb-1">Tài khoản admin được bảo vệ</p>
                                <p class="text-xs text-on-surface-variant">Không chỉnh vai trò admin tại màn này để tránh khóa nhầm quyền truy cập hoặc sai ownership.</p>
                            </div>
                        <% } else { %>
                            <form action="/admin/users/<%= user._id %>/permissions" method="POST" class="rounded-2xl bg-surface-low p-4 ghost-border space-y-4">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <div>
                                        <label class="block text-[10px] font-bold uppercase tracking-[0.14em] text-on-surface-variant mb-2">Vai trò</label>
                                        <select name="role" class="w-full rounded-xl bg-surface-lowest border-none text-sm text-white focus:ring-1 focus:ring-primary/30">
                                            <option value="user" <%= user.role === 'user' ? 'selected' : '' %>>Người dùng</option>
                                            <option value="field_owner" <%= user.role === 'field_owner' ? 'selected' : '' %>>Chủ sân</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label class="block text-[10px] font-bold uppercase tracking-[0.14em] text-on-surface-variant mb-2">Hoa hồng %</label>
                                        <input type="number" name="commissionRate" min="2" max="10" step="0.5" value="<%= user.commissionRate || 5 %>" class="w-full rounded-xl bg-surface-lowest border-none text-sm text-white focus:ring-1 focus:ring-primary/30" />
                                    </div>
                                </div>

                                <div>
                                    <label class="block text-[10px] font-bold uppercase tracking-[0.14em] text-on-surface-variant mb-2">Gán sân nhanh</label>
                                    <select name="assignedFieldId" class="w-full rounded-xl bg-surface-lowest border-none text-sm text-white focus:ring-1 focus:ring-primary/30">
                                        <option value="">Giữ nguyên quyền sở hữu hiện tại</option>
                                        <% fieldOptions.forEach((field) => { %>
                                            <option value="<%= field._id %>">
                                                <%= field.name %><%= field.owner && (!ownedFields.some((owned) => owned._id.toString() === field._id.toString())) ? ' · owner hiện tại: ' + field.owner.name : '' %>
                                            </option>
                                        <% }) %>
                                    </select>
                                </div>

                                <div class="flex items-center justify-between gap-4 pt-1">
                                    <p class="text-xs text-on-surface-variant">
                                        Chuyển về vai trò `người dùng` sẽ gỡ toàn bộ sân đang sở hữu. Gán sân tại đây sẽ chuyển quyền sở hữu sang tài khoản này.
                                    </p>
                                    <button type="submit" class="shrink-0 inline-flex items-center gap-2 px-4 py-2.5 rounded-xl bg-primary text-on-primary text-sm font-bold hover:opacity-90 transition-opacity">
                                        <span class="material-symbols-outlined text-[18px]">verified_user</span>
                                        Áp dụng
                                    </button>
                                </div>
                            </form>
                        <% } %>
                    </div>

                    <div class="absolute -bottom-8 -right-8 w-32 h-32 bg-white/[0.02] rounded-full pointer-events-none group-hover:bg-primary/[0.02] transition-colors"></div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-span-full py-12 text-center">
                <span class="text-on-surface-variant font-mono">Không tìm thấy người dùng nào.</span>
            </div>
        <% } %>
    </div>

    <% if (totalPages > 1) { %>
        <div class="flex justify-center items-center gap-2 mt-8 pt-4">
            <% for (let i = 1; i <= totalPages; i++) { %>
                <a href="?page=<%= i %>" class="w-10 h-10 flex items-center justify-center rounded-xl text-sm font-medium transition-all ghost-border <%= currentPage === i ? 'bg-primary/20 text-primary shadow-glow' : 'bg-surface text-on-surface-variant hover:bg-surface-high hover:text-white' %>">
                    <%= i %>
                </a>
            <% } %>
        </div>
    <% } %>
</div>
