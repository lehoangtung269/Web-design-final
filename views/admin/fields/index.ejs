<div class="space-y-8">
    <!-- Header Controls -->
    <div class="flex justify-between items-center">
        <div class="flex gap-4">
            <div class="bg-surface ghost-border px-6 py-3 rounded-2xl flex flex-col justify-center">
                <span class="label-sm text-on-surface-variant">Active Arenas</span>
                <span class="headline-md text-xl text-primary"><%= stats.activeFields %> / <%= stats.totalFields %></span>
            </div>
            <% if(stats.maintenanceFields > 0) { %>
            <div class="bg-surface ghost-border px-6 py-3 rounded-2xl flex flex-col justify-center border-l border-warning/50">
                <span class="label-sm text-on-surface-variant">Maintenance</span>
                <span class="headline-md text-xl text-warning"><%= stats.maintenanceFields %></span>
            </div>
            <% } %>
        </div>
        <a href="/admin/fields/create" class="flex items-center gap-2 bg-primary text-black px-6 py-3 rounded-xl font-bold hover:bg-primary/90 hover:shadow-glow transition-all duration-300">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Deploy New Arena
        </a>
    </div>

    <!-- Arenas Grid (No-Line Cards) -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        <% if (fields && fields.length > 0) { %>
            <% fields.forEach(field => { %>
                <div class="bg-surface rounded-3xl overflow-hidden group ghost-border hover:-translate-y-2 hover:shadow-ambient transition-all duration-500 flex flex-col">
                    <!-- Image Wrapper -->
                    <div class="relative h-48 overflow-hidden bg-surface-low">
                        <% if (field.images && field.images.length > 0) { %>
                            <img src="<%= field.images[0] %>" alt="<%= field.name %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 opacity-80 group-hover:opacity-100">
                        <% } else { %>
                            <div class="w-full h-full flex flex-col items-center justify-center text-on-surface-variant opacity-30 group-hover:opacity-50 transition-opacity">
                                <svg class="w-12 h-12 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L28 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                <span class="label-sm">No Visual Data</span>
                            </div>
                        <% } %>
                        <!-- Status Badge Overlay -->
                        <div class="absolute top-4 right-4">
                            <% if (field.status === 'active') { %>
                                <span class="bg-surface/80 backdrop-blur-md text-primary px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider ghost-border flex items-center gap-1.5">
                                    <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span> Active
                                </span>
                            <% } else { %>
                                <span class="bg-surface/80 backdrop-blur-md text-warning px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider ghost-border flex items-center gap-1.5">
                                    <span class="w-1.5 h-1.5 rounded-full bg-warning"></span> Maint.
                                </span>
                            <% } %>
                        </div>
                        <!-- Type Badge -->
                        <div class="absolute bottom-4 left-4 bg-surface/80 backdrop-blur-md text-white px-3 py-1 rounded-lg text-xs font-bold font-mono ghost-border">
                            <%= field.type %>
                        </div>
                    </div>

                    <!-- Content -->
                    <div class="p-6 flex flex-col flex-1">
                        <h3 class="text-xl headline-md text-white group-hover:text-primary transition-colors line-clamp-1 mb-1"><%= field.name %></h3>
                        <p class="text-sm text-on-surface-variant flex items-start gap-1.5 mb-4 line-clamp-2 min-h-[40px]">
                            <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                            <%= field.address %>
                        </p>
                        
                        <div class="mt-auto pt-4 flex items-center justify-between">
                            <div class="flex flex-col">
                                <span class="label-sm text-on-surface-variant">Rate/Slot</span>
                                <span class="text-lg font-bold text-white"><%= field.pricePerSlot.toLocaleString('vi-VN') %>₫</span>
                            </div>
                            
                            <div class="flex gap-2">
                                <a href="/admin/fields/<%= field._id %>/edit" class="w-10 h-10 rounded-xl bg-surface-low hover:bg-primary/20 flex items-center justify-center text-on-surface-variant hover:text-primary transition-all ghost-border hover:shadow-glow">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                                </a>
                                <form action="/admin/fields/<%= field._id %>/delete" method="POST" onsubmit="return confirm('Initiate self-destruct for this arena? This cannot be undone.');" class="inline">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <button type="submit" class="w-10 h-10 rounded-xl bg-surface-low hover:bg-danger/20 flex items-center justify-center text-on-surface-variant hover:text-danger transition-all ghost-border hover:shadow-[0_0_15px_rgba(255,76,76,0.2)]">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-span-full bg-surface rounded-3xl p-12 ghost-border shadow-ambient flex flex-col items-center justify-center text-center">
                <div class="w-20 h-20 rounded-full bg-surface-low flex items-center justify-center mb-4">
                    <svg class="w-10 h-10 text-on-surface-variant" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                </div>
                <h3 class="text-xl headline-md text-white mb-2">No Arenas Deployed</h3>
                <p class="text-on-surface-variant mb-6 max-w-md">Initialize the system by deploying your first arena entity. Ensure all parameters are correctly set.</p>
                <a href="/admin/fields/create" class="bg-primary text-black px-6 py-3 rounded-xl font-bold hover:bg-primary/90 transition-all shadow-glow">Deploy Arena</a>
            </div>
        <% } %>
    </div>
</div>