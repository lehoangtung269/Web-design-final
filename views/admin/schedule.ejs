<%
    const fieldSuffix = selectedFieldId !== 'all' ? '&fieldId=' + selectedFieldId : '';
%>

<div class="space-y-6">
    <div class="flex flex-col gap-6">
        <div class="flex flex-col xl:flex-row xl:items-end xl:justify-between gap-6">
            <div>
                <h2 class="text-3xl font-extrabold headline-tight text-white">Pitch Schedule</h2>
                <p class="text-sm text-on-surface-variant mt-2">
                    <%= selectedField ? selectedField.name : 'All Fields' %> · Weekly operational grid built from actual booking slots.
                </p>
            </div>

            <div class="flex flex-wrap items-center gap-3">
                <div class="rounded-lg bg-surface-container p-1 flex items-center">
                    <a href="?date=<%= prevWeekStr %><%= fieldSuffix %>" class="w-10 h-10 rounded-md flex items-center justify-center text-on-surface-variant hover:text-white hover:bg-surface-container-high transition-colors">
                        <span class="material-symbols-outlined text-[20px]">chevron_left</span>
                    </a>
                    <div class="px-4 min-w-[160px] text-center">
                        <p class="text-sm font-bold text-white"><%= weekTitle %></p>
                    </div>
                    <a href="?date=<%= nextWeekStr %><%= fieldSuffix %>" class="w-10 h-10 rounded-md flex items-center justify-center text-on-surface-variant hover:text-white hover:bg-surface-container-high transition-colors">
                        <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                    </a>
                </div>
                <a href="?date=<%= todayStr %><%= fieldSuffix %>" class="px-4 py-3 rounded-lg bg-surface-container-high text-white text-sm font-bold hover:bg-surface-variant transition-colors">
                    Today
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 xl:grid-cols-[1.4fr_1fr] gap-4">
            <form action="/admin/schedule" method="GET" class="rounded-xl bg-surface-container p-5">
                <input type="hidden" name="date" value="<%= currentDateStr %>">
                <div class="flex flex-col md:flex-row md:items-center gap-4">
                    <div class="flex-1">
                        <p class="text-[11px] font-bold uppercase tracking-[0.14em] text-on-surface-variant mb-2">Field Scope</p>
                        <select name="fieldId" class="w-full rounded-lg bg-surface-container-high border-none text-sm text-white focus:ring-1 focus:ring-primary/30">
                            <option value="all" <%= selectedFieldId === 'all' ? 'selected' : '' %>>All Fields</option>
                            <% fieldOptions.forEach((field) => { %>
                                <option value="<%= field._id %>" <%= selectedFieldId === field._id.toString() ? 'selected' : '' %>>
                                    <%= field.name %> · <%= field.type %>
                                </option>
                            <% }) %>
                        </select>
                    </div>
                    <button type="submit" class="px-5 py-3 rounded-lg bg-primary text-on-primary font-bold text-sm self-end">
                        Apply Filter
                    </button>
                </div>
            </form>

            <div class="grid grid-cols-3 gap-3">
                <div class="rounded-xl bg-surface-container p-4">
                    <p class="text-[10px] font-bold uppercase tracking-[0.14em] text-on-surface-variant mb-2">Total</p>
                    <p class="text-2xl font-bold headline-tight text-white"><%= weekStats.total %></p>
                </div>
                <div class="rounded-xl bg-surface-container p-4">
                    <p class="text-[10px] font-bold uppercase tracking-[0.14em] text-on-surface-variant mb-2">Confirmed</p>
                    <p class="text-2xl font-bold headline-tight text-primary"><%= weekStats.confirmed %></p>
                </div>
                <div class="rounded-xl bg-surface-container p-4">
                    <p class="text-[10px] font-bold uppercase tracking-[0.14em] text-on-surface-variant mb-2">Pending</p>
                    <p class="text-2xl font-bold headline-tight text-secondary"><%= weekStats.pending %></p>
                </div>
            </div>
        </div>

        <div class="flex flex-wrap items-center gap-6">
            <div class="flex items-center gap-2">
                <span class="w-2.5 h-2.5 rounded-full bg-primary shadow-glow"></span>
                <span class="text-[10px] font-bold uppercase tracking-[0.14em] text-on-surface-variant">Confirmed</span>
            </div>
            <div class="flex items-center gap-2">
                <span class="w-2.5 h-2.5 rounded-full bg-secondary"></span>
                <span class="text-[10px] font-bold uppercase tracking-[0.14em] text-on-surface-variant">Pending</span>
            </div>
            <div class="flex items-center gap-2">
                <span class="w-2.5 h-2.5 rounded-full bg-surface-variant"></span>
                <span class="text-[10px] font-bold uppercase tracking-[0.14em] text-on-surface-variant">Closed</span>
            </div>
            <% if (selectedField && selectedField.status === 'maintenance') { %>
                <div class="px-3 py-1.5 rounded-full bg-error/10 text-error text-[10px] font-bold uppercase tracking-[0.14em]">
                    Selected field is in maintenance mode
                </div>
            <% } %>
        </div>
    </div>

    <div class="overflow-auto rounded-xl bg-surface-container-low">
        <div class="min-w-[1120px]">
            <div class="grid grid-cols-[100px_repeat(7,minmax(0,1fr))] bg-surface-container-high/60">
                <div class="px-4 py-4 text-[10px] font-bold uppercase tracking-[0.14em] text-on-surface-variant">Time</div>
                <% weekDays.forEach((day) => { %>
                    <div class="px-4 py-4 text-center <%= day.isToday ? 'bg-primary/8' : '' %>">
                        <p class="text-[10px] font-bold uppercase tracking-[0.12em] <%= day.isToday ? 'text-primary' : 'text-on-surface-variant' %>"><%= day.name %></p>
                        <p class="text-2xl font-bold headline-tight mt-1 <%= day.isToday ? 'text-primary' : 'text-white' %>"><%= day.dateNum %></p>
                    </div>
                <% }) %>
            </div>

            <% scheduleRows.forEach((row) => { %>
                <div class="grid grid-cols-[100px_repeat(7,minmax(0,1fr))] border-t border-white/5">
                    <div class="px-4 py-5 text-[11px] font-bold uppercase tracking-[0.12em] text-on-surface-variant bg-surface-container-high/30">
                        <div><%= row.startTime %></div>
                        <div class="text-[10px] text-on-surface-variant/60 mt-1"><%= row.endTime %></div>
                    </div>

                    <% row.cells.forEach((cell, index) => { %>
                        <div class="min-h-[112px] p-2 border-l border-white/5 <%= weekDays[index].isToday ? 'bg-primary/5' : 'bg-surface-container-low' %> hover:bg-surface-container-high/40 transition-colors">
                            <% if (cell.bookings.length > 0) { %>
                                <div class="space-y-2">
                                    <% cell.bookings.forEach((booking) => { %>
                                        <%
                                            const statusClass = booking.status === 'confirmed'
                                                ? 'bg-primary text-on-primary border border-primary/30'
                                                : booking.status === 'pending'
                                                    ? 'bg-secondary text-slate-900 border border-secondary/40'
                                                    : 'bg-surface-variant text-on-surface border border-white/10';
                                        %>
                                        <a href="/admin/bookings/<%= booking._id %>" class="block rounded-md p-2.5 <%= statusClass %>">
                                            <p class="text-[10px] font-bold uppercase tracking-[0.12em] opacity-80"><%= booking.startTime %> - <%= booking.endTime %></p>
                                            <p class="text-sm font-bold mt-1 truncate">
                                                <%= selectedFieldId === 'all' ? (booking.field ? booking.field.name : 'Unknown Field') : (booking.user ? booking.user.name : 'Unknown User') %>
                                            </p>
                                            <p class="text-[11px] mt-1 truncate opacity-80">
                                                <%= selectedFieldId === 'all' ? (booking.user ? booking.user.name : 'Unknown User') : booking.status %>
                                            </p>
                                        </a>
                                    <% }) %>
                                </div>
                            <% } else { %>
                                <div class="h-full min-h-[96px] rounded-md border border-dashed border-white/5 flex items-center justify-center">
                                    <span class="text-[10px] font-bold uppercase tracking-[0.14em] text-on-surface-variant/40">Open</span>
                                </div>
                            <% } %>
                        </div>
                    <% }) %>
                </div>
            <% }) %>
        </div>
    </div>
</div>
