<div class="space-y-6">
    <!-- Visualizer Controls -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 bg-surface p-4 rounded-3xl ghost-border shadow-ambient">
        <h2 class="headline-lg text-2xl text-white ml-2 flex items-center gap-3">
            <span class="w-2 h-8 bg-primary rounded-full shadow-glow inline-block"></span>
            <%= weekTitle %>
        </h2>
        
        <div class="flex items-center gap-2 bg-surface-low p-1.5 rounded-2xl ghost-border">
            <a href="?date=<%= prevWeekStr %>" class="w-10 h-10 flex items-center justify-center rounded-xl text-on-surface-variant hover:text-white hover:bg-surface-high transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
            </a>
            <a href="?date=<%= todayStr %>" class="px-6 py-2 rounded-xl text-sm font-bold bg-surface hover:bg-surface-high text-white transition-all shadow-ambient">
                TODAY
            </a>
            <a href="?date=<%= nextWeekStr %>" class="w-10 h-10 flex items-center justify-center rounded-xl text-on-surface-variant hover:text-white hover:bg-surface-high transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            </a>
        </div>
    </div>

    <!-- The Kinetic Pitch Grid -->
    <div class="grid grid-cols-1 md:grid-cols-7 gap-4">
        <% weekDays.forEach(day => { %>
            <div class="bg-surface rounded-3xl ghost-border p-2 flex flex-col relative overflow-hidden group <%= day.isToday ? 'ring-1 ring-primary shadow-glow' : 'hover:bg-surface-high transition-colors duration-500' %>">
                
                <!-- Day Header -->
                <div class="p-4 text-center rounded-2xl mb-4 relative z-10 <%= day.isToday ? 'bg-primary/10' : 'bg-surface-low' %>">
                    <span class="block label-sm <%= day.isToday ? 'text-primary' : 'text-on-surface-variant' %>"><%= day.name %></span>
                    <span class="block text-3xl headline-md mt-1 <%= day.isToday ? 'text-white' : 'text-on-surface-variant group-hover:text-white transition-colors' %>"><%= day.dateNum %></span>
                </div>

                <!-- Slot List -->
                <div class="flex-1 flex flex-col gap-2 relative z-10">
                    <% if (day.bookings && day.bookings.length > 0) { %>
                        <% 
                        // Sắp xếp booking theo giờ
                        day.bookings.sort((a,b) => a.startTime.localeCompare(b.startTime));
                        day.bookings.forEach(booking => { 
                            let statusClass = "bg-surface-lowest text-on-surface-variant";
                            if(booking.status === 'confirmed') statusClass = "bg-primary/10 border border-primary/20 text-primary shadow-[0_0_10px_rgba(78,222,99,0.1)]";
                            if(booking.status === 'pending') statusClass = "bg-warning/10 border border-warning/20 text-warning";
                        %>
                            <a href="/admin/bookings/<%= booking._id %>" class="block p-3 rounded-xl text-xs transition-all hover:scale-[1.02] <%= statusClass %>">
                                <div class="font-mono font-bold mb-1"><%= booking.startTime %></div>
                                <div class="font-medium truncate text-white"><%= booking.field ? booking.field.name : 'Unknown' %></div>
                                <div class="truncate opacity-80 mt-0.5"><%= booking.user ? booking.user.name : '' %></div>
                            </a>
                        <% }) %>
                    <% } else { %>
                        <div class="flex-1 flex items-center justify-center opacity-20">
                            <div class="w-1 h-12 rounded-full bg-white/20"></div>
                        </div>
                    <% } %>
                </div>

                <!-- Subtle Pitch Background Graphic per column -->
                <div class="absolute bottom-0 left-0 w-full h-1/2 border-t border-white/5 rounded-t-full opacity-30 pointer-events-none translate-y-1/2"></div>
            </div>
        <% }) %>
    </div>
</div>