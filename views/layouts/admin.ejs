<!DOCTYPE html>
<html class="dark" lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Quản trị DatSan.vn</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        background: '#101419',
                        surface: '#1c2025',
                        'surface-low': '#181c21',
                        'surface-high': '#262a30',
                        'surface-lowest': '#0a0e13',
                        'surface-variant': '#31353b',
                        'surface-container-lowest': '#0a0e13',
                        'surface-container-low': '#181c21',
                        'surface-container': '#1c2025',
                        'surface-container-high': '#262a30',
                        'surface-container-highest': '#31353b',
                        primary: '#4EDE63',
                        'primary-container': '#10B981',
                        secondary: '#ADC6FF',
                        outline: '#86948a',
                        'outline-variant': '#3c4a42',
                        'on-surface': '#e0e2ea',
                        'on-surface-variant': '#bbcabf',
                        'on-primary': '#003824',
                        error: '#ffb4ab',
                        danger: '#ffb4ab',
                        warning: '#f6c75a',
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    boxShadow: {
                        ambient: '0 12px 40px -10px rgba(0, 0, 0, 0.5)',
                        glow: '0 0 24px rgba(78, 222, 99, 0.16)',
                    },
                    transitionTimingFunction: {
                        tactical: 'cubic-bezier(0.4, 0, 0.2, 1)',
                    },
                },
            },
        };
    </script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #101419;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 450, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }

        .label-sm {
            font-size: 0.68rem;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
        }

        .headline-lg {
            font-weight: 800;
            letter-spacing: -0.04em;
        }

        .headline-md {
            font-weight: 700;
            letter-spacing: -0.02em;
        }

        .headline-tight {
            letter-spacing: -0.04em;
        }

        .ghost-border {
            border: 1px solid rgba(134, 148, 138, 0.15);
        }

        .glass-panel {
            background: rgba(28, 32, 37, 0.8);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            border-radius: 1rem;
            padding: 0.75rem 1rem;
            font-size: 0.875rem;
            font-weight: 700;
            transition: all 300ms cubic-bezier(0.4, 0, 0.2, 1);
        }
        .btn:hover { transform: translateY(-2px); }
        .btn:active { transform: translateY(0) scale(0.98); }

        .btn-sm {
            padding: 0.5rem 0.875rem;
            font-size: 0.75rem;
        }

        .btn-outline {
            background: #1c2025;
            color: #e0e2ea;
            border: 1px solid rgba(134, 148, 138, 0.15);
        }

        .btn-outline:hover {
            background: #262a30;
            box-shadow: 0 8px 20px -4px rgba(0, 0, 0, 0.3);
        }

        .btn-primary {
            background: linear-gradient(135deg, #4EDE63, #10B981);
            color: #003824;
            box-shadow: 0 8px 24px -6px rgba(78, 222, 99, 0.3);
        }

        .btn-primary:hover {
            filter: brightness(1.04);
            box-shadow: 0 12px 28px -4px rgba(78, 222, 99, 0.4);
        }

        .btn-blue {
            background: #10B981;
            color: #003824;
        }

        .card {
            background: #1c2025;
            border: 1px solid rgba(134, 148, 138, 0.15);
            border-radius: 1rem;
            padding: 1.5rem;
            box-shadow: 0 12px 40px -10px rgba(0, 0, 0, 0.5);
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            border-radius: 999px;
            padding: 0.3rem 0.65rem;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .badge-pending {
            background: rgba(173, 198, 255, 0.12);
            color: #ADC6FF;
            border: 1px solid rgba(173, 198, 255, 0.18);
        }

        .badge-confirmed {
            background: rgba(78, 222, 99, 0.12);
            color: #4EDE63;
            border: 1px solid rgba(78, 222, 99, 0.18);
        }

        .badge-rejected {
            background: rgba(255, 180, 171, 0.12);
            color: #ffb4ab;
            border: 1px solid rgba(255, 180, 171, 0.18);
        }

        .empty-state {
            padding: 3rem;
            border-radius: 1rem;
            border: 1px solid rgba(134, 148, 138, 0.15);
            background: #1c2025;
            text-align: center;
        }

        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        ::-webkit-scrollbar-track {
            background: #101419;
        }

        ::-webkit-scrollbar-thumb {
            background: #31353b;
            border-radius: 999px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #3b4149;
        }
    </style>
</head>
<body class="bg-background text-on-surface min-h-screen overflow-x-hidden">
    <%- include('../admin/partials/sidebar') %>

    <div class="lg:ml-64 min-h-screen">
        <header class="sticky top-0 z-40 h-16 px-4 lg:px-8 bg-background/80 backdrop-blur-xl border-b border-white/5 flex items-center justify-between">
            <div class="min-w-0">
                <p class="label-sm text-on-surface-variant mb-1">Trung tâm điều hành DatSan.vn</p>
                <h1 class="text-xl md:text-2xl font-extrabold headline-tight text-white truncate">
                    <%= typeof pageTitle !== 'undefined' ? pageTitle : title %>
                </h1>
            </div>

            <div class="flex items-center gap-4 pl-6">
                <% if (typeof topbarRight !== 'undefined' && topbarRight) { %>
                    <div class="hidden lg:flex items-center">
                        <%- topbarRight %>
                    </div>
                <% } %>

                <a href="/" class="hidden lg:inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-container text-on-surface-variant hover:text-white hover:bg-surface-container-high ghost-border transition-all">
                    <span class="material-symbols-outlined text-[18px]">public</span>
                    <span class="text-sm font-semibold">Xem trang web</span>
                </a>

                <div class="hidden xl:flex items-center gap-2 rounded-full bg-surface-container px-4 py-2 ghost-border w-80 relative" id="admin-search-wrapper">
                    <span class="material-symbols-outlined text-on-surface-variant text-[18px]">search</span>
                    <input type="text" id="admin-search-input" placeholder="Tìm kiếm trong khu vực quản trị..." autocomplete="off"
                        class="w-full bg-transparent border-none p-0 text-sm text-on-surface placeholder:text-on-surface-variant/60 focus:ring-0" />
                    <kbd class="text-[10px] text-on-surface-variant bg-surface-container-high px-1.5 py-0.5 rounded font-mono">/</kbd>
                    <!-- Search Results Dropdown -->
                    <div id="admin-search-results" class="absolute top-full left-0 right-0 mt-2 bg-surface-container rounded-2xl border border-white/10 shadow-2xl overflow-hidden z-50 hidden">
                        <div id="search-results-list" class="max-h-80 overflow-y-auto"></div>
                        <div id="search-empty" class="hidden px-4 py-8 text-center text-sm text-on-surface-variant">
                            <span class="material-symbols-outlined text-2xl mb-2 block opacity-40">search_off</span>
                            Không tìm thấy kết quả
                        </div>
                        <div id="search-loading" class="hidden px-4 py-4 text-center">
                            <div class="inline-block w-5 h-5 border-2 border-on-surface-variant/20 border-t-primary rounded-full animate-spin"></div>
                        </div>
                    </div>
                </div>

                <button type="button" class="w-10 h-10 rounded-full bg-surface-container text-on-surface-variant hover:text-white hover:bg-surface-container-high transition-all ghost-border">
                    <span class="material-symbols-outlined text-[18px]">notifications</span>
                </button>

                <button type="button" class="w-10 h-10 rounded-full bg-surface-container text-on-surface-variant hover:text-white hover:bg-surface-container-high transition-all ghost-border">
                    <span class="material-symbols-outlined text-[18px]">help_outline</span>
                </button>

                <div class="flex items-center gap-3 pl-4 border-l border-white/10">
                    <div class="text-right hidden md:block">
                        <p class="text-sm font-semibold text-white"><%= currentUser.name %></p>
                        <p class="text-[11px] text-on-surface-variant">Quản trị viên</p>
                    </div>
                    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-primary to-primary-container text-on-primary font-bold flex items-center justify-center shadow-glow">
                        <%= currentUser.name.charAt(0).toUpperCase() %>
                    </div>
                </div>
            </div>
        </header>

        <div class="px-8 pt-6">
            <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
                <% success.forEach((msg) => { %>
                    <div class="flash-banner mb-3 rounded-xl border border-primary/20 bg-primary/10 px-4 py-3 text-sm text-primary shadow-glow flex items-center gap-2" role="alert">
                        <span class="flex-1"><%= msg %></span>
                        <button type="button" onclick="this.parentElement.style.opacity='0';setTimeout(()=>this.parentElement.remove(),200)" class="p-1 rounded-lg hover:bg-primary/20 transition-colors" aria-label="Đóng">
                            <span class="material-symbols-outlined text-[16px]">close</span>
                        </button>
                    </div>
                <% }) %>
            <% } %>
            <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
                <% error.forEach((msg) => { %>
                    <div class="flash-banner mb-3 rounded-xl border border-error/20 bg-error/10 px-4 py-3 text-sm text-error shadow-ambient flex items-center gap-2" role="alert">
                        <span class="flex-1"><%= msg %></span>
                        <button type="button" onclick="this.parentElement.style.opacity='0';setTimeout(()=>this.parentElement.remove(),200)" class="p-1 rounded-lg hover:bg-error/20 transition-colors" aria-label="Đóng">
                            <span class="material-symbols-outlined text-[16px]">close</span>
                        </button>
                    </div>
                <% }) %>
            <% } %>
        </div>

        <main class="px-8 pb-10">
            <div class="space-y-8">
                <%- body %>
            </div>
        </main>
    </div>

    <script>
        setTimeout(function () {
            document.querySelectorAll('.flash-banner').forEach(function (banner) {
                banner.style.transition = 'opacity 400ms ease';
                banner.style.opacity = '0';
                setTimeout(function () {
                    banner.remove();
                }, 420);
            });
        }, 8000);

        // ── Admin Search ──
        (function () {
            var input = document.getElementById('admin-search-input');
            var wrapper = document.getElementById('admin-search-wrapper');
            var dropdown = document.getElementById('admin-search-results');
            var listEl = document.getElementById('search-results-list');
            var emptyEl = document.getElementById('search-empty');
            var loadingEl = document.getElementById('search-loading');
            if (!input || !dropdown) return;

            var timer = null;
            var typeColors = {
                field: { bg: 'rgba(78,222,99,0.1)', color: '#4EDE63' },
                user: { bg: 'rgba(96,165,250,0.1)', color: '#60A5FA' },
                booking: { bg: 'rgba(251,191,36,0.1)', color: '#FBBF24' }
            };

            function showDropdown() { dropdown.classList.remove('hidden'); }
            function hideDropdown() { dropdown.classList.add('hidden'); }

            function renderResults(results) {
                loadingEl.classList.add('hidden');
                if (!results || results.length === 0) {
                    listEl.innerHTML = '';
                    emptyEl.classList.remove('hidden');
                    return;
                }
                emptyEl.classList.add('hidden');
                var html = '';
                results.forEach(function (r) {
                    var tc = typeColors[r.type] || typeColors.field;
                    html += '<a href="' + r.url + '" class="flex items-center gap-3 px-4 py-3 hover:bg-surface-container-high transition-colors">'
                        + '<div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background:' + tc.bg + '">'
                        + '<span class="material-symbols-outlined text-[18px]" style="color:' + tc.color + '">' + r.icon + '</span>'
                        + '</div>'
                        + '<div class="min-w-0 flex-1">'
                        + '<p class="text-sm font-semibold text-white truncate">' + r.title + '</p>'
                        + '<p class="text-xs text-on-surface-variant truncate">' + r.subtitle + '</p>'
                        + '</div>'
                        + '<span class="text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full" style="background:' + tc.bg + ';color:' + tc.color + '">' + r.type + '</span>'
                        + '</a>';
                });
                listEl.innerHTML = html;
            }

            input.addEventListener('input', function () {
                var q = input.value.trim();
                clearTimeout(timer);
                if (q.length < 2) { hideDropdown(); return; }

                showDropdown();
                listEl.innerHTML = '';
                emptyEl.classList.add('hidden');
                loadingEl.classList.remove('hidden');

                timer = setTimeout(function () {
                    fetch('/admin/api/search?q=' + encodeURIComponent(q))
                        .then(function (r) { return r.json(); })
                        .then(function (data) { renderResults(data.results); })
                        .catch(function () {
                            loadingEl.classList.add('hidden');
                            emptyEl.classList.remove('hidden');
                        });
                }, 350);
            });

            input.addEventListener('focus', function () {
                if (input.value.trim().length >= 2) showDropdown();
            });

            document.addEventListener('click', function (e) {
                if (!wrapper.contains(e.target)) hideDropdown();
            });

            document.addEventListener('keydown', function (e) {
                if (e.key === '/' && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA') {
                    e.preventDefault();
                    input.focus();
                }
                if (e.key === 'Escape') { hideDropdown(); input.blur(); }
            });
        })();
    </script>
    <script src="/public/js/form-autosave.js"></script>
</body>
</html>
