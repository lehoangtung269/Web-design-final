<!DOCTYPE html>
<html class="dark" lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title><%= title %> | Kinetic Admin</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,700;0,900;1,900&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f4f6ff;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
        /* Custom scrollbar for premium feel */
        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #f4f6ff;
        }
        ::-webkit-scrollbar-thumb {
            background: #cdd9f4;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #b7c5e4;
        }
    </style>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-surface": "#0b1c30",
                        "primary": "#6a37d3",
                        "surface": "#f4f6ff",
                        "surface-variant": "#dde9ff",
                        "surface-container-low": "#ebf1ff",
                        "outline": "#91a4c8",
                        "tertiary-container": "#dbeafe",
                        "on-surface-variant": "#334155",
                        "secondary": "#00675c",
                        "surface-container-high": "#dde9ff",
                        "surface-container": "#dde9ff",
                        "secondary-container": "#b9f0e6",
                        "error": "#dc2626",
                        "surface-container-highest": "#cfdcf8",
                        "surface-container-lowest": "#ffffff",
                        "tertiary": "#a78bfa",
                        "outline-variant": "#a5b4cf",
                        "on-primary": "#ffffff",
                        "background": "#f4f6ff",
                        "primary-container": "#ae8dff",
                    },
                    "borderRadius": {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    "fontFamily": {
                        "headline": ["Inter"],
                        "body": ["Inter"],
                        "label": ["Inter"]
                    }
                },
            },
        }
    </script>
</head>
    <body class="text-on-surface overflow-x-hidden bg-background">
    <!-- SideNavBar Anchor -->
    <%- include('../admin/partials/sidebar', { activeNav: typeof activeNav !=='undefined' ? activeNav : '' }) %>

    <!-- TopNavBar Anchor -->
    <header class="bg-white/80 backdrop-blur-md sticky top-0 z-40 lg:ml-64 w-full lg:w-[calc(100%-16rem)] flex justify-between items-center h-16 px-8">
        <div class="flex items-center w-full max-w-md">
            <div class="relative w-full">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-xl">search</span>
                <input class="w-full bg-surface-container-low border-none rounded-full pl-10 pr-4 py-2 text-sm text-on-surface focus:ring-1 focus:ring-primary/40 placeholder-on-surface-variant/70 transition-all" placeholder="Tim analytics, users, bookings..." type="text"/>
            </div>
        </div>
        <div class="flex items-center gap-6">
            <div class="flex items-center gap-4 text-on-surface-variant">
                <button class="material-symbols-outlined hover:text-white transition-colors">notifications</button>
                <div class="h-4 w-px bg-outline-variant/30"></div>
                <button class="flex items-center gap-2 hover:text-white transition-colors">
                    <span class="material-symbols-outlined">account_circle</span>
                    <span class="text-xs font-medium"><%= currentUser ? currentUser.name : 'Admin Portal' %></span>
                </button>
            </div>
            <a href="/admin/bookings" class="bg-primary text-on-primary px-4 py-2 rounded-lg text-sm font-semibold hover:opacity-80 transition-all active:scale-[0.98]">
                View Bookings
            </a>
        </div>
    </header>

    <!-- Main Content Canvas -->
    <main class="lg:ml-64 p-8 min-h-screen">
        <% if (typeof error !=='undefined' && error.length > 0) { %>
            <div class="mb-4 p-4 rounded-lg bg-red-900/20 border border-red-500/50 text-red-200 text-sm font-medium flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">warning</span> <%= error[0] %>
            </div>
        <% } %>
        <% if (typeof success !=='undefined' && success.length > 0) { %>
            <div class="mb-4 p-4 rounded-lg bg-primary/10 border border-primary/30 text-primary text-sm font-medium flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">check_circle</span> <%= success[0] %>
            </div>
        <% } %>

        <%- body %>
    </main>
</body>
</html>