<!DOCTYPE html>
<html class="dark" lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title><%= title %> | Kinetic Admin</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800;900&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #101419;
            color: #ffffff;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
        
        /* Tactical HUD Scrollbar */
        ::-webkit-scrollbar {
            width: 4px;
        }
        ::-webkit-scrollbar-track {
            background: #0A0E13;
        }
        ::-webkit-scrollbar-thumb {
            background: #1C2025;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #4EDE63;
        }

        /* Typography Presets */
        .headline-lg {
            font-size: 2.25rem;
            letter-spacing: -0.04em;
            font-weight: 700;
        }
        .headline-sm {
            font-size: 1.5rem;
            letter-spacing: -0.02em;
            font-weight: 700;
        }
        .label-sm {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            font-weight: 700;
        }
        .label-md {
            font-size: 0.875rem;
            letter-spacing: 0.02em;
            font-weight: 500;
        }

        /* Component Utils */
        .ghost-border {
            border: 1px solid rgba(134, 148, 138, 0.15);
        }
        .ambient-shadow {
            box-shadow: 0 12px 40px -10px rgba(0, 0, 0, 0.5);
        }
        .primary-gradient-text {
            background: linear-gradient(135deg, #4EDE63, #10B981);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .input-tactical {
            background-color: #1A1F26;
            border: none;
            transition: all 150ms cubic-bezier(0.4, 0, 0.2, 1);
        }
        .input-tactical:focus {
            outline: none;
            border: 1px solid rgba(134, 148, 138, 0.3);
            box-shadow: 0 0 0 2px rgba(78, 222, 163, 0.1);
        }
    </style>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        background: "#101419",
                        surface: "#101419",
                        "surface-container-lowest": "#0A0E13",
                        "surface-container": "#1C2025",
                        "surface-container-high": "#262A30",
                        "surface-container-highest": "#323840",
                        primary: "#4EDE63",
                        "primary-container": "#10B981",
                        "on-primary": "#003824",
                        secondary: "#ADC6FF",
                        "on-surface": "#ffffff",
                        "on-surface-variant": "#BBCABF",
                        "outline-variant": "rgba(134, 148, 138, 0.15)",
                        error: "#FF5449"
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif']
                    }
                }
            }
        }
    </script>
</head>
<body class="text-on-surface overflow-x-hidden bg-background min-h-screen">
    <!-- SideNavBar Anchor -->
    <%- include('../admin/partials/sidebar', { activeNav: typeof activeNav !=='undefined' ? activeNav : '' }) %>

    <!-- TopNavBar -->
    <header class="sticky top-0 z-40 lg:ml-64 w-full lg:w-[calc(100%-16rem)] flex justify-between items-center h-20 px-10 bg-background/80 backdrop-blur-[20px]">
        <div class="flex items-center w-full max-w-lg">
            <div class="relative w-full">
                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">search</span>
                <input class="w-full input-tactical rounded-md pl-12 pr-4 py-3 text-sm text-on-surface placeholder-on-surface-variant/50" placeholder="Search operations, bookings, or intel..." type="text"/>
            </div>
        </div>
        <div class="flex items-center gap-6">
            <div class="flex items-center gap-6 text-on-surface-variant">
                <button class="material-symbols-outlined hover:text-primary transition-colors duration-150">notifications</button>
                <div class="h-5 w-px bg-on-surface-variant/20"></div>
                <button class="flex items-center gap-3 hover:text-white transition-colors duration-150 group">
                    <div class="w-8 h-8 rounded-full bg-surface-container-highest flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-on-primary transition-colors">
                        <span class="material-symbols-outlined text-[18px]">admin_panel_settings</span>
                    </div>
                    <span class="text-sm font-bold tracking-wide"><%= typeof currentUser !== 'undefined' && currentUser ? currentUser.name : 'Tactical Admin' %></span>
                </button>
            </div>
        </div>
    </header>

    <!-- Main Workspace Area -->
    <main class="lg:ml-64 p-10 pt-4">
        <% if (typeof error !=='undefined' && error.length > 0) { %>
            <div class="mb-6 px-5 py-4 rounded-md bg-error/10 ghost-border text-error text-sm font-medium flex items-center gap-3">
                <span class="material-symbols-outlined text-[18px]">warning</span> <%= error[0] %>
            </div>
        <% } %>
        <% if (typeof success !=='undefined' && success.length > 0) { %>
            <div class="mb-6 px-5 py-4 rounded-md bg-primary/10 ghost-border text-primary text-sm font-medium flex items-center gap-3">
                <span class="material-symbols-outlined text-[18px]">check_circle</span> <%= success[0] %>
            </div>
        <% } %>

        <%- body %>
    </main>
</body>
</html>