<!DOCTYPE html>
<html class="light" lang="vi">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= title %> | ĐặtSân.vn
  </title>
  <meta name="description"
    content="Hệ thống đặt sân bóng đá online nhanh chóng, tiện lợi. Tìm sân, chọn giờ, đặt ngay!" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,500;1,900&family=Space+Grotesk:wght@400;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            "primary": "#6a37d3",
            "primary-container": "#ae8dff",
            "on-primary": "#ffffff",
            "secondary": "#00675c",
            "background": "#f4f6ff",
            "surface": "#f4f6ff",
            "surface-container-low": "#ebf1ff",
            "surface-container": "#dde9ff",
            "surface-container-lowest": "#ffffff",
            "on-surface": "#0b1c30",
            "outline-variant": "rgba(11, 28, 48, 0.15)"
          },
          fontFamily: { 
            headline: ["Inter", "sans-serif"], 
            title: ["Inter", "sans-serif"],
            body: ["Inter", "sans-serif"],
            display: ["Inter", "sans-serif"],
            label: ["Space Grotesk", "sans-serif"] 
          },
        },
      },
    }
  </script>
  <style>
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }

    body {
      font-family: 'Inter', sans-serif;
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(24px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .animate-fade-in {
      animation: fadeInUp 0.7s ease-out both;
    }

    .animate-delay-1 {
      animation-delay: 0.1s;
    }

    .animate-delay-2 {
      animation-delay: 0.2s;
    }

    .animate-delay-3 {
      animation-delay: 0.3s;
    }

    .animate-delay-4 {
      animation-delay: 0.4s;
    }
  </style>
</head>

<body class="bg-surface text-on-surface min-h-screen flex flex-col">

  <!-- ===== KINETIC NAVBAR ===== -->
  <header class="fixed top-6 left-0 right-0 z-50 flex justify-center px-6 pointer-events-none">
    <nav class="pointer-events-auto bg-white/80 backdrop-blur-md shadow-[0_10px_25px_-5px_rgba(0,0,0,0.05)] rounded-full flex justify-between items-center px-3 py-2 max-w-5xl w-full border border-gray-100/50">
      <a href="/" class="pl-4 text-xl font-black italic tracking-tighter text-[#0b1c30]">
        OBSIDIAN
      </a>
      <div class="hidden md:flex flex-row items-center space-x-1">
        <a class="px-5 py-2 text-[10px] uppercase tracking-[0.15em] font-['Space_Grotesk'] font-bold text-[#6a37d3] border-b-2 border-[#6a37d3]" href="/">COLLECTIONS</a>
        <a class="px-5 py-2 text-[10px] uppercase tracking-[0.15em] font-['Space_Grotesk'] text-[#0b1c30] hover:text-[#6a37d3] transition-colors" href="/fields">CURATED MATCHES</a>
        <a class="px-5 py-2 text-[10px] uppercase tracking-[0.15em] font-['Space_Grotesk'] text-[#0b1c30] hover:text-[#6a37d3] transition-colors" href="#">MEMBERSHIP</a>
        <a class="px-5 py-2 text-[10px] uppercase tracking-[0.15em] font-['Space_Grotesk'] text-[#0b1c30] hover:text-[#6a37d3] transition-colors" href="#">THE ARCHIVE</a>
      </div>
      <div class="flex items-center gap-4 pr-1">
        <a href="#" class="text-[#0b1c30] flex items-center justify-center rounded-full hover:bg-gray-100 transition-colors w-8 h-8">
          <span class="material-symbols-outlined text-[18px]">shopping_bag</span>
        </a>
        <a href="/auth/login" class="text-[#0b1c30] flex items-center justify-center rounded-full hover:bg-gray-100 transition-colors w-8 h-8">
          <span class="material-symbols-outlined text-[18px]">account_circle</span>
        </a>
        <a href="/fields" class="bg-[#6a37d3] text-white px-5 py-2.5 rounded-full text-[10px] uppercase tracking-[0.15em] font-bold shadow-[0_10px_25px_-5px_rgba(107,56,212,0.4)] hover:bg-[#ae8dff] hover:-translate-y-0.5 transition-all">
          BOOK NOW
        </a>
      </div>
    </nav>
  </header>

  <main class="pt-[72px] flex-1">
    <!-- ===== FLASH MESSAGES ===== -->
    <% if (typeof success !=='undefined' && success && success.length> 0) { %>
      <div class="max-w-7xl mx-auto px-6 pt-4">
        <% success.forEach(msg=> { %>
          <div
            class="bg-emerald-50 border-l-4 border-emerald-500 text-emerald-800 px-5 py-3 rounded-xl mb-2 flex items-center gap-3 animate-fade-in">
            <span class="material-symbols-outlined text-emerald-600">check_circle</span>
            <%= msg %>
          </div>
          <% }); %>
      </div>
      <% } %>
        <% if (typeof error !=='undefined' && error && error.length> 0) { %>
          <div class="max-w-7xl mx-auto px-6 pt-4">
            <% error.forEach(msg=> { %>
              <div
                class="bg-red-50 border-l-4 border-red-500 text-red-800 px-5 py-3 rounded-xl mb-2 flex items-center gap-3 animate-fade-in">
                <span class="material-symbols-outlined text-red-600">error</span>
                <%= msg %>
              </div>
              <% }); %>
          </div>
          <% } %>

            <%- body %>
  </main>

  <!-- ===== KINETIC FOOTER ===== -->
  <footer class="w-full py-20 bg-slate-950 flex flex-col items-center justify-center mt-auto">
    <div class="text-4xl font-black italic tracking-tighter text-white mb-8">OBSIDIAN</div>
    <div class="flex flex-wrap justify-center gap-10 mb-12">
      <a class="text-gray-400 text-[10px] uppercase tracking-[0.15em] hover:text-white transition-colors" href="#">PRIVACY</a>
      <a class="text-gray-400 text-[10px] uppercase tracking-[0.15em] hover:text-white transition-colors" href="#">TERMS</a>
      <a class="text-gray-400 text-[10px] uppercase tracking-[0.15em] hover:text-white transition-colors" href="#">CAREERS</a>
      <a class="text-gray-400 text-[10px] uppercase tracking-[0.15em] hover:text-white transition-colors" href="#">CONTACT</a>
    </div>
    <div class="text-[9px] uppercase tracking-[0.2em] text-gray-500 font-['Space_Grotesk']">
      © 2026 KINETIC OBSIDIAN ARCHIVE. ALL RIGHTS RESERVED.
    </div>
  </footer>

  <script>
    // Navbar scroll shadow
    window.addEventListener('scroll', () => {
      const header = document.querySelector('header');
      header.classList.toggle('shadow-md', window.scrollY > 10);
    });
  </script>
</body>

</html>