<!DOCTYPE html>
<html class="light" lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | DatSan.vn</title>
  <meta name="description" content="DatSan.vn - Kinetic Editorial football booking experience." />
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,700;0,900;1,900&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: "#6a37d3",
            "primary-container": "#ae8dff",
            secondary: "#00675c",
            background: "#f4f6ff",
            surface: "#f4f6ff",
            "surface-container-low": "#ebf1ff",
            "surface-container": "#dde9ff",
            "surface-container-lowest": "#ffffff",
            "on-surface": "#0b1c30",
            "on-surface-variant": "#334155",
            "outline-variant": "#a5b4cf",
            "on-primary": "#ffffff"
          },
          fontFamily: {
            headline: ["Inter", "sans-serif"],
            body: ["Inter", "sans-serif"],
            label: ["Space Grotesk", "sans-serif"]
          },
          boxShadow: {
            "cta-glow": "0 10px 25px -5px rgba(107, 56, 212, 0.4)",
            "ambient": "0 22px 40px -24px rgba(11, 28, 48, 0.12)"
          }
        }
      }
    };
  </script>
  <style>
    .material-symbols-outlined { font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24; }
    body { font-family: Inter, sans-serif; }
    .kinetic-display { font-style: italic; font-weight: 900; letter-spacing: -0.05em; }
    .kinetic-headline { font-style: italic; font-weight: 900; letter-spacing: -0.02em; }
    .kinetic-label {
      font-family: "Space Grotesk", sans-serif;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      font-size: 0.72rem;
    }

    /* ── Unified Button System ── */
    .btn-unified {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      border-radius: 1rem;
      padding: 0.7rem 1.5rem;
      font-size: 0.875rem;
      font-weight: 700;
      transition: all 300ms cubic-bezier(0.4, 0, 0.2, 1);
      cursor: pointer;
      border: none;
      text-decoration: none;
      line-height: 1.4;
    }
    .btn-unified:hover { transform: translateY(-2px); }
    .btn-unified:active { transform: translateY(0) scale(0.98); }

    .btn-primary-unified {
      background: linear-gradient(135deg, #6a37d3, #ae8dff);
      color: #ffffff;
      box-shadow: 0 8px 24px -6px rgba(106, 55, 211, 0.35);
    }
    .btn-primary-unified:hover {
      box-shadow: 0 12px 28px -4px rgba(106, 55, 211, 0.45);
    }

    .btn-secondary-unified {
      background: #ebf1ff;
      color: #0b1c30;
      box-shadow: 0 4px 12px -4px rgba(11, 28, 48, 0.08);
    }
    .btn-secondary-unified:hover {
      background: #dde9ff;
      box-shadow: 0 8px 20px -4px rgba(11, 28, 48, 0.12);
    }

    .btn-outline-unified {
      background: transparent;
      color: #6a37d3;
      border: 2px solid #c4b5fd;
    }
    .btn-outline-unified:hover {
      background: #f4f0ff;
      border-color: #ae8dff;
    }

    .btn-danger-unified {
      background: rgba(239, 68, 68, 0.08);
      color: #dc2626;
      border: 1px solid rgba(239, 68, 68, 0.2);
    }
    .btn-danger-unified:hover {
      background: rgba(239, 68, 68, 0.15);
      box-shadow: 0 4px 16px -4px rgba(239, 68, 68, 0.25);
    }

    .btn-unified.btn-sm {
      padding: 0.5rem 1rem;
      font-size: 0.75rem;
    }
    .btn-unified.btn-lg {
      padding: 1rem 2rem;
      font-size: 1rem;
    }
    .btn-unified:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none !important;
      box-shadow: none !important;
    }
  </style>
</head>
<body class="bg-background text-on-surface min-h-screen flex flex-col">
  <header class="fixed top-4 left-0 right-0 z-50 px-4 md:px-6">
    <nav class="max-w-7xl mx-auto rounded-full bg-white/80 backdrop-blur-md shadow-ambient px-4 md:px-6 py-3 flex items-center justify-between">
      <a href="/" class="font-black italic tracking-tight text-lg md:text-xl text-on-surface">⚽ DatSan.vn</a>
      <div class="hidden md:flex items-center gap-7 text-sm">
        <a href="/" class="<%= typeof activeNav !== 'undefined' && activeNav === 'home' ? 'text-primary border-b-2 border-primary pb-1' : 'text-on-surface-variant hover:text-primary' %> font-semibold transition-all duration-300">Trang chủ</a>
        <a href="/fields" class="<%= typeof activeNav !== 'undefined' && activeNav === 'fields' ? 'text-primary border-b-2 border-primary pb-1' : 'text-on-surface-variant hover:text-primary' %> font-semibold transition-all duration-300">Sân bóng</a>
        <a href="/#about" class="text-on-surface-variant hover:text-primary font-semibold transition-all duration-300">Giới thiệu</a>
      </div>
      <div class="hidden md:flex items-center gap-3">
        <% if (typeof currentUser !== 'undefined' && currentUser) { %>
          <% if (currentUser.role === 'admin') { %><a href="/admin/dashboard" class="text-xs font-semibold rounded-full px-4 py-2 bg-surface-container-low text-primary">Admin</a><% } %>
          <% if (currentUser.role === 'field_owner') { %><a href="/owner/dashboard" class="text-xs font-semibold rounded-full px-4 py-2 bg-surface-container-low text-primary">Chủ sân</a><% } %>
          <a href="/history" class="text-sm text-on-surface-variant hover:text-primary px-2 font-semibold transition-all duration-300">Lịch sử</a>
          <!-- Avatar Dropdown -->
          <div class="relative" id="avatar-dropdown-container">
            <button
              id="avatar-dropdown-btn"
              class="w-9 h-9 rounded-full bg-gradient-to-br from-primary to-primary-container text-white font-bold text-sm flex items-center justify-center transition-all duration-300 hover:shadow-cta-glow hover:scale-105 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:ring-offset-2"
              aria-label="Menu tài khoản"
              aria-expanded="false"
              aria-haspopup="true"
            >
              <%= currentUser.name.charAt(0).toUpperCase() %>
            </button>
            <!-- Dropdown Menu -->
            <div
              id="avatar-dropdown-menu"
              class="absolute right-0 top-full mt-3 w-56 rounded-2xl bg-white/90 backdrop-blur-xl shadow-ambient border border-outline-variant/20 overflow-hidden opacity-0 invisible translate-y-2 transition-all duration-300 z-50"
              role="menu"
            >
              <!-- User info header -->
              <div class="px-4 py-3 bg-surface-container-low/50">
                <p class="text-sm font-semibold text-on-surface truncate"><%= currentUser.name %></p>
                <p class="text-xs text-on-surface-variant truncate"><%= currentUser.email %></p>
              </div>
              <!-- Menu items -->
              <div class="py-1">
                <a href="/profile" class="flex items-center gap-3 px-4 py-2.5 text-sm text-on-surface-variant hover:bg-surface-container-low hover:text-primary transition-all duration-300" role="menuitem">
                  <span class="material-symbols-outlined text-lg">person</span>
                  Hồ sơ cá nhân
                </a>
                <a href="/auth/logout" class="flex items-center gap-3 px-4 py-2.5 text-sm text-on-surface-variant hover:bg-red-50 hover:text-red-600 transition-all duration-300" role="menuitem">
                  <span class="material-symbols-outlined text-lg">logout</span>
                  Đăng xuất
                </a>
              </div>
            </div>
          </div>
        <% } else { %>
          <a href="/auth/login" class="text-sm text-on-surface-variant hover:text-primary px-2">Đăng nhập</a>
          <a href="/auth/register" class="rounded-full bg-gradient-to-r from-primary to-primary-container text-white px-5 py-2.5 font-semibold transition-all duration-300 hover:-translate-y-0.5 hover:shadow-cta-glow">Đăng ký</a>
        <% } %>
      </div>
      <button id="mobile-menu-btn" class="md:hidden rounded-full p-2 text-on-surface hover:bg-surface-container-low" aria-label="Mở menu điều hướng">
        <span class="material-symbols-outlined">menu</span>
      </button>
    </nav>
    <div id="mobile-menu" class="hidden mt-3 max-w-7xl mx-auto rounded-2xl bg-white/90 backdrop-blur-md p-4 shadow-ambient">
      <div class="flex flex-col gap-3">
        <a href="/" class="px-3 py-2 rounded-xl bg-surface-container-low text-on-surface font-medium">Trang chủ</a>
        <a href="/fields" class="px-3 py-2 rounded-xl text-on-surface-variant hover:bg-surface-container-low">Sân bóng</a>
        <a href="/#about" class="px-3 py-2 rounded-xl text-on-surface-variant hover:bg-surface-container-low">Giới thiệu</a>
        <a href="/#contact" class="px-3 py-2 rounded-xl text-on-surface-variant hover:bg-surface-container-low">Liên hệ</a>
        <% if (typeof currentUser !== 'undefined' && currentUser) { %>
          <a href="/profile" class="px-3 py-2 rounded-xl text-on-surface-variant hover:bg-surface-container-low flex items-center gap-2">
            <span class="material-symbols-outlined text-lg">person</span>
            Hồ sơ cá nhân
          </a>
          <a href="/history" class="px-3 py-2 rounded-xl text-on-surface-variant hover:bg-surface-container-low flex items-center gap-2">
            <span class="material-symbols-outlined text-lg">history</span>
            Lịch sử đặt sân
          </a>
          <a href="/auth/logout" class="px-3 py-2 rounded-xl text-red-600 hover:bg-red-50 flex items-center gap-2">
            <span class="material-symbols-outlined text-lg">logout</span>
            Đăng xuất
          </a>
        <% } else { %>
          <a href="/auth/login" class="px-3 py-2 rounded-xl text-on-surface-variant hover:bg-surface-container-low">Đăng nhập</a>
          <a href="/auth/register" class="px-3 py-2 rounded-xl bg-primary text-white text-center font-semibold">Đăng ký</a>
        <% } %>
      </div>
    </div>
  </header>

  <main class="pt-24 md:pt-28 flex-1">
    <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
      <div class="max-w-7xl mx-auto px-6 pt-2">
        <% success.forEach(msg => { %>
          <div class="flash-msg bg-surface-container-low text-on-surface px-4 py-3 rounded-2xl mb-2 flex items-center gap-2 transition-all duration-500" role="alert">
            <span class="material-symbols-outlined text-secondary">check_circle</span>
            <span class="flex-1"><%= msg %></span>
            <button type="button" onclick="this.parentElement.style.opacity='0';setTimeout(()=>this.parentElement.remove(),300)" class="ml-auto p-1 rounded-full hover:bg-surface-container transition-colors" aria-label="Đóng thông báo">
              <span class="material-symbols-outlined text-on-surface-variant text-lg">close</span>
            </button>
          </div>
        <% }) %>
      </div>
    <% } %>
    <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
      <div class="max-w-7xl mx-auto px-6 pt-2">
        <% error.forEach(msg => { %>
          <div class="flash-msg bg-red-50 text-red-700 px-4 py-3 rounded-2xl mb-2 flex items-center gap-2 transition-all duration-500" role="alert">
            <span class="material-symbols-outlined text-red-500">error</span>
            <span class="flex-1"><%= msg %></span>
            <button type="button" onclick="this.parentElement.style.opacity='0';setTimeout(()=>this.parentElement.remove(),300)" class="ml-auto p-1 rounded-full hover:bg-red-100 transition-colors" aria-label="Đóng thông báo">
              <span class="material-symbols-outlined text-red-400 text-lg">close</span>
            </button>
          </div>
        <% }) %>
      </div>
    <% } %>
    <%- body %>
  </main>

  <footer id="contact" class="bg-slate-950 text-slate-300 py-14 mt-10">
    <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-8">
      <div class="text-center md:text-left">
        <p class="text-3xl font-black italic text-white">DatSan.vn</p>
        <p class="kinetic-label text-slate-500 mt-2">Premium Football Booking Archive</p>
      </div>
      <div class="flex flex-wrap justify-center gap-6 text-xs uppercase tracking-[0.14em]">
        <a href="/#about" class="hover:text-white transition-colors duration-300">Giới thiệu</a>
        <a href="/#policy" class="hover:text-white transition-colors duration-300">Điều khoản</a>
        <a href="/#policy" class="hover:text-white transition-colors duration-300">Bảo mật</a>
        <a href="/#contact" class="hover:text-white transition-colors duration-300">Liên hệ</a>
      </div>
    </div>
  </footer>

  <script src="/public/js/analytics.js"></script>
  <script src="/public/js/form-autosave.js"></script>
  <script>
    // Mobile menu toggle
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    if (menuBtn && mobileMenu) {
      menuBtn.addEventListener('click', function () {
        mobileMenu.classList.toggle('hidden');
      });
    }

    // Avatar dropdown toggle
    const avatarBtn = document.getElementById('avatar-dropdown-btn');
    const avatarMenu = document.getElementById('avatar-dropdown-menu');
    if (avatarBtn && avatarMenu) {
      avatarBtn.addEventListener('click', function (e) {
        e.stopPropagation();
        const isOpen = !avatarMenu.classList.contains('invisible');
        if (isOpen) {
          // Close
          avatarMenu.classList.add('opacity-0', 'invisible', 'translate-y-2');
          avatarMenu.classList.remove('opacity-100', 'visible', 'translate-y-0');
          avatarBtn.setAttribute('aria-expanded', 'false');
        } else {
          // Open
          avatarMenu.classList.remove('opacity-0', 'invisible', 'translate-y-2');
          avatarMenu.classList.add('opacity-100', 'visible', 'translate-y-0');
          avatarBtn.setAttribute('aria-expanded', 'true');
        }
      });

      // Close dropdown when clicking outside
      document.addEventListener('click', function (e) {
        if (!avatarBtn.contains(e.target) && !avatarMenu.contains(e.target)) {
          avatarMenu.classList.add('opacity-0', 'invisible', 'translate-y-2');
          avatarMenu.classList.remove('opacity-100', 'visible', 'translate-y-0');
          avatarBtn.setAttribute('aria-expanded', 'false');
        }
      });

      // Close dropdown on Escape key
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') {
          avatarMenu.classList.add('opacity-0', 'invisible', 'translate-y-2');
          avatarMenu.classList.remove('opacity-100', 'visible', 'translate-y-0');
          avatarBtn.setAttribute('aria-expanded', 'false');
          avatarBtn.focus();
        }
      });
    }

    // Auto-dismiss flash messages after 8 seconds (with fade-out)
    setTimeout(function () {
      document.querySelectorAll('.flash-msg').forEach(function (el) {
        el.style.opacity = '0';
        setTimeout(function () { el.remove(); }, 500);
      });
    }, 8000);
  </script>
</body>
</html>