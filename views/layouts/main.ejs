<!DOCTYPE html>
<html class="light" lang="vi">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= title %> | ĐặtSân.vn
  </title>
  <meta name="description"
    content="Hệ thống đặt sân bóng đá online nhanh chóng, tiện lợi. Tìm sân, chọn giờ, đặt ngay!" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
    rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            "primary": "#006c49",
            "primary-container": "#10b981",
            "primary-fixed": "#6ffbbe",
            "on-primary": "#ffffff",
            "on-primary-container": "#00422b",
            "on-primary-fixed-variant": "#005236",
            "secondary": "#545f73",
            "secondary-container": "#d5e0f8",
            "tertiary": "#855300",
            "tertiary-container": "#e29100",
            "on-tertiary-container": "#523200",
            "surface": "#f7f9fb",
            "surface-container-lowest": "#ffffff",
            "surface-container-low": "#f2f4f6",
            "surface-container": "#eceef0",
            "surface-container-high": "#e6e8ea",
            "on-surface": "#191c1e",
            "on-surface-variant": "#3c4a42",
            "on-background": "#191c1e",
            "outline": "#6c7a71",
            "outline-variant": "#bbcabf",
            "surface-variant": "#e0e3e5",
            "error": "#ba1a1a",
          },
          borderRadius: { DEFAULT: "0.25rem", lg: "0.5rem", xl: "0.75rem", full: "9999px" },
          fontFamily: { headline: ["Inter"], body: ["Inter"], label: ["Inter"] },
        },
      },
    }
  </script>
  <style>
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }

    body {
      font-family: 'Inter', sans-serif;
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(24px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .animate-fade-in {
      animation: fadeInUp 0.7s ease-out both;
    }

    .animate-delay-1 {
      animation-delay: 0.1s;
    }

    .animate-delay-2 {
      animation-delay: 0.2s;
    }

    .animate-delay-3 {
      animation-delay: 0.3s;
    }

    .animate-delay-4 {
      animation-delay: 0.4s;
    }
  </style>
</head>

<body class="bg-surface text-on-surface min-h-screen flex flex-col">

  <!-- ===== TOP NAVBAR ===== -->
  <header class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-md shadow-sm">
    <nav class="flex justify-between items-center px-6 py-4 max-w-7xl mx-auto w-full">
      <a href="/"
        class="text-2xl font-black text-emerald-700 italic tracking-tight hover:scale-105 transition-transform">
        ⚽ ĐặtSân.vn
      </a>
      <div class="hidden md:flex items-center space-x-8">
        <a class="<%= typeof activeNav !== 'undefined' && activeNav === 'home' ? 'text-emerald-700 border-b-2 border-emerald-600 pb-1' : 'text-slate-600 hover:text-emerald-600' %> font-bold tracking-tight transition-all duration-200"
          href="/">Home</a>
        <a class="<%= typeof activeNav !== 'undefined' && activeNav === 'fields' ? 'text-emerald-700 border-b-2 border-emerald-600 pb-1' : 'text-slate-600 hover:text-emerald-600' %> font-bold tracking-tight transition-all duration-200"
          href="/fields">Sân bóng</a>
        <a class="text-slate-600 hover:text-emerald-600 font-bold tracking-tight transition-all duration-200"
          href="#">Giới thiệu</a>
      </div>
      <div class="flex items-center gap-3">
        <% if (typeof currentUser !=='undefined' && currentUser) { %>
          <span class="text-slate-500 text-sm hidden md:inline">Xin chào, <strong class="text-slate-800">
              <%= currentUser.name %>
            </strong></span>
          <% if (currentUser.role==='admin' ) { %>
            <a href="/admin/dashboard"
              class="text-emerald-600 font-bold px-4 py-2 transition-all hover:bg-emerald-50 rounded-lg text-sm">Admin</a>
            <% } else if (currentUser.role==='field_owner' ) { %>
              <a href="/owner/dashboard"
                class="text-blue-600 font-bold px-4 py-2 transition-all hover:bg-blue-50 rounded-lg text-sm">Chủ sân</a>
              <% } %>
                <a href="/history"
                  class="text-slate-600 hover:text-emerald-600 font-bold px-3 py-2 transition-all text-sm">Lịch sử</a>
                <a href="/auth/logout"
                  class="text-slate-600 hover:text-emerald-600 font-bold px-4 py-2 transition-all">Đăng xuất</a>
                <% } else { %>
                  <a href="/auth/login"
                    class="text-slate-600 hover:text-emerald-600 font-bold px-4 py-2 transition-all">Đăng nhập</a>
                  <a href="/auth/register"
                    class="bg-emerald-600 text-white px-6 py-2.5 rounded-xl font-bold shadow-md hover:bg-emerald-700 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200">Đăng
                    ký</a>
                  <% } %>
      </div>
    </nav>
  </header>

  <main class="pt-[72px] flex-1">
    <!-- ===== FLASH MESSAGES ===== -->
    <% if (typeof success !=='undefined' && success && success.length> 0) { %>
      <div class="max-w-7xl mx-auto px-6 pt-4">
        <% success.forEach(msg=> { %>
          <div
            class="bg-emerald-50 border-l-4 border-emerald-500 text-emerald-800 px-5 py-3 rounded-xl mb-2 flex items-center gap-3 animate-fade-in">
            <span class="material-symbols-outlined text-emerald-600">check_circle</span>
            <%= msg %>
          </div>
          <% }); %>
      </div>
      <% } %>
        <% if (typeof error !=='undefined' && error && error.length> 0) { %>
          <div class="max-w-7xl mx-auto px-6 pt-4">
            <% error.forEach(msg=> { %>
              <div
                class="bg-red-50 border-l-4 border-red-500 text-red-800 px-5 py-3 rounded-xl mb-2 flex items-center gap-3 animate-fade-in">
                <span class="material-symbols-outlined text-red-600">error</span>
                <%= msg %>
              </div>
              <% }); %>
          </div>
          <% } %>

            <%- body %>
  </main>

  <!-- ===== FOOTER ===== -->
  <footer class="w-full py-12 border-t border-slate-200 bg-slate-50">
    <div class="flex flex-col md:flex-row justify-between items-center px-8 max-w-7xl mx-auto gap-8">
      <div class="flex flex-col items-center md:items-start">
        <div class="text-lg font-bold text-slate-900 mb-2">⚽ ĐặtSân.vn</div>
        <p class="text-slate-500 text-xs uppercase tracking-widest text-center md:text-left">
          © 2026 ĐặtSân.vn. Nền tảng đặt sân bóng hàng đầu Việt Nam.
        </p>
      </div>
      <div class="flex flex-wrap justify-center gap-8">
        <a class="text-slate-500 text-xs uppercase tracking-widest hover:text-emerald-500 transition-all underline-offset-4 hover:underline"
          href="#">Điều khoản</a>
        <a class="text-slate-500 text-xs uppercase tracking-widest hover:text-emerald-500 transition-all underline-offset-4 hover:underline"
          href="#">Bảo mật</a>
        <a class="text-slate-500 text-xs uppercase tracking-widest hover:text-emerald-500 transition-all underline-offset-4 hover:underline"
          href="#">Liên hệ</a>
        <a class="text-emerald-600 font-bold text-xs uppercase tracking-widest hover:text-emerald-500 transition-all underline-offset-4 hover:underline"
          href="#">Hợp tác chủ sân</a>
      </div>
    </div>
  </footer>

  <script>
    // Navbar scroll shadow
    window.addEventListener('scroll', () => {
      const header = document.querySelector('header');
      header.classList.toggle('shadow-md', window.scrollY > 10);
    });
  </script>
</body>

</html>