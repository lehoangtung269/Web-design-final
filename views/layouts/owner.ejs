<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title><%= title %> | Kinetic Owner</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,700;0,900;1,900&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            "on-surface": "#0b1c30",
            "primary": "#6a37d3",
            "surface": "#f4f6ff",
            "surface-variant": "#dde9ff",
            "surface-container-low": "#ebf1ff",
            "outline": "#91a4c8",
            "on-surface-variant": "#334155",
            "secondary": "#00675c",
            "surface-container-high": "#dde9ff",
            "surface-container": "#dde9ff",
            "secondary-container": "#b9f0e6",
            "error": "#dc2626",
            "surface-container-highest": "#cfdcf8",
            "surface-container-lowest": "#ffffff",
            "tertiary": "#a78bfa",
            "outline-variant": "#a5b4cf",
            "on-primary": "#ffffff",
            "background": "#f4f6ff",
            "primary-container": "#ae8dff"
          },
          boxShadow: {
            "ambient": "0 18px 40px rgba(11, 28, 48, 0.07)",
            "cta": "0 10px 25px -5px rgba(107, 56, 212, 0.4)"
          }
        }
      }
    }
  </script>
  <style>
    body { font-family: 'Inter', sans-serif; background: #f4f6ff; }
    .kinetic-display { font-family: 'Inter', sans-serif; font-style: italic; font-weight: 900; letter-spacing: -0.05em; }
    .kinetic-headline { font-family: 'Inter', sans-serif; font-style: italic; font-weight: 900; letter-spacing: -0.02em; }
    .kinetic-label { font-family: 'Space Grotesk', sans-serif; text-transform: uppercase; letter-spacing: .15em; font-size: 11px; }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 500, 'GRAD' 0, 'opsz' 24; vertical-align: middle; }
  </style>
</head>
<body class="text-on-surface overflow-x-hidden bg-background">
  <%- include('../owner/partials/sidebar', { activeNav: typeof activeNav !== 'undefined' ? activeNav : '' }) %>

  <header class="sticky top-0 z-40 lg:ml-72 lg:w-[calc(100%-18rem)] px-4 md:px-8 py-5">
    <div class="rounded-full bg-white/75 backdrop-blur-xl px-5 md:px-8 py-3 shadow-ambient">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="kinetic-label text-on-surface-variant">Kinetic Owner Suite</p>
          <h1 class="kinetic-headline text-2xl md:text-3xl text-on-surface"><%= title %></h1>
        </div>
        <div class="flex items-center gap-3">
          <div class="hidden sm:flex items-center gap-2 px-4 py-2 rounded-full bg-surface-container-low">
            <span class="material-symbols-outlined text-on-surface-variant text-lg">account_circle</span>
            <span class="text-sm font-medium"><%= currentUser ? currentUser.name : 'Owner' %></span>
          </div>
          <a href="/owner/bookings" class="rounded-full bg-gradient-to-r from-primary to-primary-container text-white px-5 py-2.5 text-sm font-semibold hover:-translate-y-1 transition-all duration-300 shadow-cta">View Bookings</a>
        </div>
      </div>
    </div>
  </header>

  <main class="lg:ml-72 px-4 md:px-8 pb-10">
    <% if (typeof error !== 'undefined' && error.length > 0) { %>
      <div class="mb-5 rounded-3xl bg-red-50 text-error px-5 py-4 text-sm font-medium shadow-ambient">
        <span class="material-symbols-outlined text-base mr-1">warning</span><%= error[0] %>
      </div>
    <% } %>
    <% if (typeof success !== 'undefined' && success.length > 0) { %>
      <div class="mb-5 rounded-3xl bg-primary/10 text-primary px-5 py-4 text-sm font-medium shadow-ambient">
        <span class="material-symbols-outlined text-base mr-1">check_circle</span><%= success[0] %>
      </div>
    <% } %>
    <%- body %>
  </main>
</body>
</html>