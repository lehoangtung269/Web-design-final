<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title><%= title %> | Cổng chủ sân</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700;900&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            "on-surface": "#0b1c30",
            "primary": "#6a37d3",
            "surface": "#f4f6ff",
            "surface-variant": "#dde9ff",
            "surface-container-low": "#ebf1ff",
            "outline": "#91a4c8",
            "on-surface-variant": "#334155",
            "secondary": "#00675c",
            "surface-container-high": "#dde9ff",
            "surface-container": "#dde9ff",
            "secondary-container": "#b9f0e6",
            "error": "#dc2626",
            "surface-container-highest": "#cfdcf8",
            "surface-container-lowest": "#ffffff",
            "tertiary": "#a78bfa",
            "outline-variant": "#a5b4cf",
            "on-primary": "#ffffff",
            "background": "#f4f6ff",
            "primary-container": "#ae8dff"
          },
          boxShadow: {
            "ambient": "0 18px 40px rgba(11, 28, 48, 0.07)",
            "cta": "0 10px 25px -5px rgba(107, 56, 212, 0.4)"
          }
        }
      }
    }
  </script>
  <style>
    body { font-family: 'Inter', sans-serif; background: #f4f6ff; }
    .kinetic-display { font-family: 'Inter', sans-serif; font-style: normal; font-weight: 900; letter-spacing: -0.05em; }
    .kinetic-headline { font-family: 'Inter', sans-serif; font-style: normal; font-weight: 900; letter-spacing: -0.02em; }
    .kinetic-label { font-family: 'Space Grotesk', sans-serif; text-transform: uppercase; letter-spacing: .15em; font-size: 11px; }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 500, 'GRAD' 0, 'opsz' 24; vertical-align: middle; }
    .picker-shell {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      border-radius: 1.35rem;
      background: #eef4ff;
      border: 1px solid rgba(145, 164, 200, 0.35);
      padding: 0.95rem 1rem;
      cursor: pointer;
      transition: all 220ms ease;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.65);
    }
    .picker-shell:hover {
      transform: translateY(-1px);
      border-color: rgba(106, 55, 211, 0.3);
      background: #ffffff;
      box-shadow: 0 14px 24px -18px rgba(11, 28, 48, 0.25);
    }
    .picker-shell:focus-within {
      border-color: rgba(106, 55, 211, 0.5);
      box-shadow: 0 0 0 4px rgba(106, 55, 211, 0.1);
      background: #ffffff;
    }
    .picker-shell[data-picker-shell] * {
      pointer-events: none;
    }
    .picker-shell[data-picker-shell] input,
    .picker-shell[data-picker-shell] select {
      pointer-events: auto;
    }
    .picker-meta {
      display: flex;
      flex: 1;
      min-width: 0;
      flex-direction: column;
      gap: 0.18rem;
    }
    .picker-caption {
      font-size: 0.68rem;
      line-height: 1;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: #64748b;
    }
    .picker-input {
      width: 100%;
      min-width: 0;
      border: none;
      background: transparent;
      padding: 0;
      font-size: 0.95rem;
      font-weight: 600;
      color: #0b1c30;
      cursor: pointer;
    }
    .picker-input:focus {
      outline: none;
      box-shadow: none;
    }
    .picker-input::-webkit-calendar-picker-indicator {
      cursor: pointer;
      opacity: 0.85;
    }
  </style>
</head>
<body class="text-on-surface overflow-x-hidden bg-background">
  <%- include('../owner/partials/sidebar', { activeNav: typeof activeNav !== 'undefined' ? activeNav : '' }) %>

  <header class="sticky top-0 z-40 lg:ml-72 lg:w-[calc(100%-18rem)] px-4 md:px-8 py-5">
    <div class="rounded-full bg-white/75 backdrop-blur-xl px-5 md:px-8 py-3 shadow-ambient">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="kinetic-label text-on-surface-variant">Cổng quản lý chủ sân</p>
          <h1 class="kinetic-headline text-2xl md:text-3xl text-on-surface"><%= title %></h1>
        </div>
        <div class="flex items-center gap-3">
          <div class="hidden sm:flex items-center gap-2 px-4 py-2 rounded-full bg-surface-container-low">
            <span class="material-symbols-outlined text-on-surface-variant text-lg">account_circle</span>
            <span class="text-sm font-medium"><%= currentUser ? currentUser.name : 'Chủ sân' %></span>
          </div>
          <a href="/owner/bookings" class="rounded-full bg-gradient-to-r from-primary to-primary-container text-white px-5 py-2.5 text-sm font-semibold hover:-translate-y-1 transition-all duration-300 shadow-cta">Xem đơn đặt sân</a>
        </div>
      </div>
    </div>
  </header>

  <main class="lg:ml-72 px-4 md:px-8 pb-10">
    <% if (typeof error !== 'undefined' && error.length > 0) { %>
      <div class="flash-msg mb-5 rounded-3xl bg-red-50 text-error px-5 py-4 text-sm font-medium shadow-ambient flex items-center gap-2" role="alert">
        <span class="material-symbols-outlined text-base">warning</span>
        <span class="flex-1"><%= error[0] %></span>
        <button type="button" onclick="this.parentElement.style.opacity='0';setTimeout(()=>this.parentElement.remove(),300)" class="p-1 rounded-full hover:bg-red-100 transition-colors" aria-label="Đóng">
          <span class="material-symbols-outlined text-error text-lg">close</span>
        </button>
      </div>
    <% } %>
    <% if (typeof success !== 'undefined' && success.length > 0) { %>
      <div class="flash-msg mb-5 rounded-3xl bg-primary/10 text-primary px-5 py-4 text-sm font-medium shadow-ambient flex items-center gap-2" role="alert">
        <span class="material-symbols-outlined text-base">check_circle</span>
        <span class="flex-1"><%= success[0] %></span>
        <button type="button" onclick="this.parentElement.style.opacity='0';setTimeout(()=>this.parentElement.remove(),300)" class="p-1 rounded-full hover:bg-primary/10 transition-colors" aria-label="Đóng">
          <span class="material-symbols-outlined text-primary text-lg">close</span>
        </button>
      </div>
    <% } %>
    <%- body %>
  </main>

  <script src="/public/js/form-autosave.js"></script>
  <script>
    // Auto-dismiss flash messages after 8 seconds
    setTimeout(function () {
      document.querySelectorAll('.flash-msg').forEach(function (el) {
        el.style.transition = 'opacity 400ms ease';
        el.style.opacity = '0';
        setTimeout(function () { el.remove(); }, 420);
      });
    }, 8000);

    document.querySelectorAll('[data-picker-shell]').forEach(function (shell) {
      if (shell.dataset.pickerBound === '1') return;
      shell.dataset.pickerBound = '1';

      const input = shell.querySelector('[data-picker-input]');
      if (!input) return;

      const openPicker = function () {
        if (typeof input.showPicker === 'function') {
          try {
            input.showPicker();
            return;
          } catch (error) {
            // fallback
          }
        }
        input.focus();
        input.click();
      };

      shell.setAttribute('tabindex', shell.getAttribute('tabindex') || '0');
      shell.addEventListener('click', function (event) {
        if (event.target === input) return;
        openPicker();
      });
      shell.addEventListener('keydown', function (event) {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          openPicker();
        }
      });
    });
  </script>
</body>
</html>
