<div class="flex items-center justify-center min-h-[70vh] px-4 py-12 relative overflow-hidden">
  
  <div class="w-full max-w-md z-10">
    <!-- Brand -->
    <div class="mb-8 text-center animate-fade-in">
      <h2 class="kinetic-display text-4xl text-on-surface mb-2 tracking-tighter">ĐĂNG NHẬP</h2>
      <p class="kinetic-label text-on-surface-variant font-medium">TRUY CẬP TÀI KHOẢN ĐẶT SÂN</p>
    </div>

    <!-- Login Card -->
    <div class="bg-surface-container-lowest rounded-3xl shadow-ambient overflow-hidden animate-fade-in animate-delay-1 transition-shadow duration-300">
      <div class="p-8 md:p-10">

        <form action="/auth/login" method="POST" class="space-y-6">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" />
          
          <div class="space-y-2">
            <label class="kinetic-label text-on-surface-variant flex items-center gap-2" for="email">
              Email
            </label>
            <input id="email" name="email" type="email" required
              class="w-full bg-surface-container-low border border-outline-variant rounded-2xl px-5 py-4 text-on-surface font-medium placeholder-gray-400 focus:border-primary focus:bg-white focus:ring-1 focus:ring-primary focus:outline-none transition-all"
              placeholder="bạn@vidu.com" />
          </div>

          <!-- Password -->
          <div class="space-y-2">
            <label class="kinetic-label text-on-surface-variant flex items-center gap-2" for="password">
              Mật khẩu
            </label>
            <input id="password" name="password" type="password" required
              class="w-full bg-surface-container-low border border-outline-variant rounded-2xl px-5 py-4 text-on-surface font-medium placeholder-gray-400 focus:border-primary focus:bg-white focus:ring-1 focus:ring-primary focus:outline-none transition-all"
              placeholder="••••••••" />
          </div>

          <!-- Submit -->
          <button type="submit"
            class="w-full bg-primary text-white font-semibold py-4 rounded-full shadow-cta-glow hover:-translate-y-1 hover:bg-primary-container hover:text-primary transition-all duration-300 flex items-center justify-center gap-2 mt-4 group">
            <span class="kinetic-label text-white group-hover:text-primary">ĐĂNG NHẬP</span>
            <span class="material-symbols-outlined text-white group-hover:text-primary group-hover:translate-x-1 transition-transform">arrow_forward</span>
          </button>
        </form>

        <div class="mt-8 text-center">
          <p class="text-sm text-on-surface-variant antialiased border-t border-outline-variant pt-6">
            Lần đầu sử dụng? 
            <a href="/auth/register" class="text-primary font-bold hover:underline underline-offset-4 ml-1 transition-all">Đăng ký tài khoản</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>