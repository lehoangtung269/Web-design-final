<%
  const mode = viewMode || 'directory';
  const isSearchMode = mode === 'search';
  const params = searchParams || {};
  const queryKeyword = params.keyword || '';
  const queryDate = params.date || '';
  const queryTime = params.time || '';
  const queryType = params.type || 'all';
  const queryCity = params.city || 'all';
  const queryDistrict = params.district || 'all';
  const meta = resultMeta || {};
  const resultCount = Number.isFinite(meta.total) ? meta.total : ((fields || []).length);
  const activeFilterCount = Number.isFinite(meta.activeFilterCount) ? meta.activeFilterCount : 0;
  const cityCount = Number.isFinite(meta.cityCount) ? meta.cityCount : 0;
  const minPriceLabel = Number.isFinite(meta.minPrice) ? meta.minPrice.toLocaleString('vi-VN') + 'đ' : '--';
  const maxPriceLabel = Number.isFinite(meta.maxPrice) ? meta.maxPrice.toLocaleString('vi-VN') + 'đ' : '--';
  const typeLabel = queryType === '5-a-side' ? 'Sân 5 người' : queryType === '7-a-side' ? 'Sân 7 người' : queryType === '11-a-side' ? 'Sân 11 người' : 'Tất cả loại sân';
  const queryParts = [];
  if (queryKeyword) queryParts.push('keyword=' + encodeURIComponent(queryKeyword));
  if (queryDate) queryParts.push('date=' + encodeURIComponent(queryDate));
  if (queryTime) queryParts.push('time=' + encodeURIComponent(queryTime));
  if (queryCity !== 'all') queryParts.push('city=' + encodeURIComponent(queryCity));
  if (queryDistrict !== 'all') queryParts.push('district=' + encodeURIComponent(queryDistrict));
  const allTypeHref = (isSearchMode ? '/search' : '/fields') + (queryParts.length ? '?' + queryParts.join('&') : '');
  const typePrefix = isSearchMode ? '/search?type=' : '/fields?type=';
  const typeSuffix = queryParts.length ? '&' + queryParts.join('&') : '';
%>

<section class="px-6 pb-10">
  <div class="max-w-7xl mx-auto rounded-[2.25rem] bg-gradient-to-br from-surface-container-low via-surface-container to-surface-container-low p-6 md:p-10">
    <div class="flex flex-col lg:flex-row gap-8 lg:items-end lg:justify-between">
      <div class="max-w-3xl">
        <p class="kinetic-label text-on-surface-variant mb-3"><%= isSearchMode ? 'Kết quả tìm kiếm' : 'Danh mục sân bóng' %></p>
        <h1 class="kinetic-headline text-4xl md:text-5xl text-on-surface leading-tight">
          <% if (isSearchMode) { %>
            KẾT QUẢ CHO <span class="kinetic-display text-primary">TRUY VẤN</span> CỦA BẠN
          <% } else { %>
            <span class="kinetic-display text-primary">SÂN</span> ĐƯỢC CHỌN LỌC
          <% } %>
        </h1>
        <p class="mt-4 text-on-surface-variant font-light">
          <% if (isSearchMode) { %>
            Tìm thấy <strong class="text-on-surface font-semibold"><%= resultCount %></strong> sân phù hợp theo điều kiện bạn nhập từ trang chủ.
          <% } else { %>
            Khám phá toàn bộ sân đang hoạt động và tinh chỉnh bộ lọc theo khu vực, thời gian, loại sân.
          <% } %>
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 w-full lg:max-w-xl">
        <div class="rounded-2xl bg-white/80 p-4">
          <p class="kinetic-label text-on-surface-variant mb-2">Số sân</p>
          <p class="text-2xl font-black text-on-surface"><%= resultCount %></p>
        </div>
        <div class="rounded-2xl bg-white/80 p-4">
          <p class="kinetic-label text-on-surface-variant mb-2">Khu vực</p>
          <p class="text-2xl font-black text-on-surface"><%= cityCount %></p>
        </div>
        <div class="rounded-2xl bg-white/80 p-4">
          <p class="kinetic-label text-on-surface-variant mb-2">Mức giá</p>
          <p class="text-sm font-semibold text-on-surface"><%= minPriceLabel %> - <%= maxPriceLabel %></p>
        </div>
      </div>
    </div>

    <form action="<%= isSearchMode ? '/search' : '/fields' %>" method="GET" class="mt-7 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-3">
      <label class="flex items-center gap-2 rounded-full bg-white px-4 py-3 text-sm">
        <span class="material-symbols-outlined text-on-surface-variant">search</span>
        <input name="keyword" value="<%= queryKeyword %>" type="text" placeholder="Tên sân, địa chỉ..." class="w-full border-none focus:ring-0 p-0 bg-transparent" />
      </label>
      <label class="flex items-center gap-2 rounded-full bg-white px-4 py-3 text-sm">
        <span class="material-symbols-outlined text-on-surface-variant">calendar_today</span>
        <input name="date" value="<%= queryDate %>" type="date" class="w-full border-none focus:ring-0 p-0 bg-transparent" />
      </label>
      <label class="flex items-center gap-2 rounded-full bg-white px-4 py-3 text-sm">
        <span class="material-symbols-outlined text-on-surface-variant">schedule</span>
        <input name="time" value="<%= queryTime %>" type="time" class="w-full border-none focus:ring-0 p-0 bg-transparent" />
      </label>
      <select name="city" class="rounded-full bg-white border-none px-4 py-3 text-sm">
        <option value="all">Tất cả thành phố</option>
        <% (cities || []).forEach((item) => { %>
          <option value="<%= item %>" <%= queryCity === item ? 'selected' : '' %>><%= item %></option>
        <% }) %>
      </select>
      <select name="district" class="rounded-full bg-white border-none px-4 py-3 text-sm">
        <option value="all">Tất cả quận/huyện</option>
        <% (districts || []).forEach((item) => { %>
          <option value="<%= item %>" <%= queryDistrict === item ? 'selected' : '' %>><%= item %></option>
        <% }) %>
      </select>
      <div class="flex gap-2">
        <select name="type" class="rounded-full bg-white border-none px-4 py-3 text-sm w-full">
          <option value="all" <%= queryType === 'all' ? 'selected' : '' %>>Tất cả loại sân</option>
          <option value="5-a-side" <%= queryType === '5-a-side' ? 'selected' : '' %>>Sân 5</option>
          <option value="7-a-side" <%= queryType === '7-a-side' ? 'selected' : '' %>>Sân 7</option>
          <option value="11-a-side" <%= queryType === '11-a-side' ? 'selected' : '' %>>Sân 11</option>
        </select>
        <button type="submit" class="shrink-0 rounded-full bg-primary text-white px-5 py-3 font-semibold hover:shadow-cta-glow transition-all duration-300">
          Lọc
        </button>
      </div>
    </form>

    <div class="mt-5 flex flex-wrap items-center gap-2">
      <span class="kinetic-label text-on-surface-variant">Loại sân:</span>
      <a href="<%= allTypeHref %>" class="px-4 py-2 rounded-full text-xs font-bold tracking-[0.14em] uppercase font-['Space_Grotesk'] transition-all duration-300 <%= queryType === 'all' ? 'bg-primary text-white shadow-cta-glow' : 'bg-white text-on-surface-variant hover:text-primary' %>">Tất cả</a>
      <a href="<%= typePrefix %>5-a-side<%= typeSuffix %>" class="px-4 py-2 rounded-full text-xs font-bold tracking-[0.14em] uppercase font-['Space_Grotesk'] transition-all duration-300 <%= queryType === '5-a-side' ? 'bg-primary text-white shadow-cta-glow' : 'bg-white text-on-surface-variant hover:text-primary' %>">Sân 5</a>
      <a href="<%= typePrefix %>7-a-side<%= typeSuffix %>" class="px-4 py-2 rounded-full text-xs font-bold tracking-[0.14em] uppercase font-['Space_Grotesk'] transition-all duration-300 <%= queryType === '7-a-side' ? 'bg-primary text-white shadow-cta-glow' : 'bg-white text-on-surface-variant hover:text-primary' %>">Sân 7</a>
      <a href="<%= typePrefix %>11-a-side<%= typeSuffix %>" class="px-4 py-2 rounded-full text-xs font-bold tracking-[0.14em] uppercase font-['Space_Grotesk'] transition-all duration-300 <%= queryType === '11-a-side' ? 'bg-primary text-white shadow-cta-glow' : 'bg-white text-on-surface-variant hover:text-primary' %>">Sân 11</a>
    </div>
  </div>
</section>

<section class="max-w-7xl mx-auto px-6 pb-14">
  <% if (isSearchMode && activeFilterCount > 0) { %>
    <div class="rounded-2xl bg-surface-container-low p-4 md:p-5 mb-8 flex flex-wrap items-center gap-2">
      <span class="kinetic-label text-on-surface-variant mr-1">Tóm tắt truy vấn</span>
      <% if (queryKeyword) { %>
        <span class="bg-white text-primary px-3 py-1.5 rounded-full text-xs font-bold font-['Space_Grotesk'] tracking-[0.12em]">Từ khóa: <%= queryKeyword %></span>
      <% } %>
      <% if (queryDate) { %>
        <span class="bg-white text-primary px-3 py-1.5 rounded-full text-xs font-bold font-['Space_Grotesk'] tracking-[0.12em]">Ngày: <%= queryDate %></span>
      <% } %>
      <% if (queryTime) { %>
        <span class="bg-white text-primary px-3 py-1.5 rounded-full text-xs font-bold font-['Space_Grotesk'] tracking-[0.12em]">Giờ: <%= queryTime %></span>
      <% } %>
      <span class="bg-white text-primary px-3 py-1.5 rounded-full text-xs font-bold font-['Space_Grotesk'] tracking-[0.12em]"><%= typeLabel %></span>
      <a href="<%= isSearchMode ? '/search' : '/fields' %>" class="ml-auto kinetic-label text-on-surface-variant hover:text-primary transition-colors">Xóa bộ lọc</a>
    </div>
  <% } %>

  <% if (fields && fields.length > 0) { %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% fields.forEach((field) => { %>
        <% const detailHref = '/fields/' + field._id + (queryDate ? '?date=' + encodeURIComponent(queryDate) : ''); %>
        <a href="<%= detailHref %>" data-field-card data-field-id="<%= field._id %>" class="group block h-[500px] relative overflow-hidden rounded-2xl transform hover:-translate-y-2 transition-all duration-700 shadow-sm hover:shadow-ambient">
          <% if (field.images && field.images.length > 0) { %>
            <img class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" src="<%= field.images[0] %>" alt="<%= field.name %>" loading="lazy" />
          <% } else { %>
            <div class="w-full h-full bg-surface-container flex items-center justify-center">
              <span class="material-symbols-outlined text-6xl text-on-surface-variant/30">sports_soccer</span>
            </div>
          <% } %>

          <div class="absolute inset-0 bg-gradient-to-t from-[#0b1c30] via-[#0b1c30]/40 to-transparent opacity-95 group-hover:opacity-100 transition-opacity duration-700"></div>
          <div class="absolute top-6 left-6 flex items-center gap-2">
            <span class="bg-white/20 backdrop-blur-md text-white px-4 py-1.5 rounded-full text-[10px] font-['Space_Grotesk'] font-bold uppercase tracking-[0.18em]">
              <%= field.type === '5-a-side' ? 'Sân 5' : field.type === '7-a-side' ? 'Sân 7' : 'Sân 11' %>
            </span>
            <% if (field.bookingCount && field.bookingCount > 0) { %>
              <span class="bg-primary/80 backdrop-blur-md text-white px-3 py-1.5 rounded-full text-[10px] font-['Space_Grotesk'] font-bold tracking-[0.12em] flex items-center gap-1">
                <span class="material-symbols-outlined text-[12px]">local_fire_department</span>
                <%= field.bookingCount %> lượt đặt
              </span>
            <% } %>
          </div>

          <div class="absolute bottom-0 left-0 right-0 p-7">
            <p class="text-[10px] text-primary-container uppercase font-['Space_Grotesk'] tracking-[0.18em] font-bold mb-2 line-clamp-1">
              <%= [field.district, field.city].filter(Boolean).join(' - ') %>
            </p>
            <h3 class="text-white text-3xl font-black tracking-tighter mb-3 leading-none"><%= field.name %></h3>
            <p class="text-white/80 text-sm line-clamp-1 mb-3"><%= field.address %></p>
            <% if (field.facilities && field.facilities.length > 0) { %>
              <div class="flex flex-wrap gap-1.5 mb-4">
                <% field.facilities.slice(0, 3).forEach(function(f) { %>
                  <span class="bg-white/10 backdrop-blur-sm text-white/90 px-2.5 py-1 rounded-full text-[10px] font-medium"><%= f %></span>
                <% }) %>
                <% if (field.facilities.length > 3) { %>
                  <span class="bg-white/10 backdrop-blur-sm text-white/70 px-2.5 py-1 rounded-full text-[10px] font-medium">+<%= field.facilities.length - 3 %></span>
                <% } %>
              </div>
            <% } %>
            <div class="flex items-center justify-between">
              <p class="text-white font-medium text-lg"><%= field.pricePerSlot.toLocaleString('vi-VN') %>đ <span class="text-white/60 text-xs">/ slot</span></p>
              <div class="w-11 h-11 bg-white/10 backdrop-blur rounded-full flex items-center justify-center text-white group-hover:bg-primary group-hover:shadow-cta-glow transition-all duration-500">
                <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
              </div>
            </div>
          </div>
        </a>
      <% }) %>
    </div>
  <% } else { %>
    <div class="text-center py-28 bg-surface-container-lowest rounded-2xl shadow-ambient">
      <div class="w-24 h-24 bg-surface-container rounded-full flex items-center justify-center mx-auto mb-6">
        <span class="material-symbols-outlined text-5xl text-on-surface-variant">search_off</span>
      </div>
      <h3 class="kinetic-headline text-2xl text-on-surface mb-2">CHƯA TÌM THẤY SÂN PHÙ HỢP</h3>
      <p class="text-on-surface-variant mb-6 font-light">Thử mở rộng khu vực hoặc đổi loại sân để hệ thống gợi ý nhiều hơn.</p>
      <a href="<%= isSearchMode ? '/search' : '/fields' %>" class="inline-flex items-center gap-2 bg-primary text-white px-8 py-3 rounded-full font-bold text-xs font-['Space_Grotesk'] uppercase tracking-widest hover:bg-primary-container hover:text-primary transition-all shadow-cta-glow">
        <span class="material-symbols-outlined text-[16px]">refresh</span>
        THỬ LẠI BỘ LỌC
      </a>
    </div>
  <% } %>
</section>

<script>
  if (window.DatSanAnalytics) {
    window.DatSanAnalytics.track('search_results_view', {
      mode: '<%= isSearchMode ? 'search' : 'directory' %>',
      results: <%= resultCount %>,
      active_filters: <%= activeFilterCount %>,
    });

    document.querySelectorAll('[data-field-card]').forEach(function (card) {
      card.addEventListener('click', function () {
        window.DatSanAnalytics.track('search_result_click', {
          field_id: card.getAttribute('data-field-id'),
          mode: '<%= isSearchMode ? 'search' : 'directory' %>',
        });
      });
    });
  }
</script>
