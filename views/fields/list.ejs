<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | ĐặtSân.vn</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <style>
    :root {
      --green: #22c55e;
      --green-dark: #16a34a;
      --green-light: #dcfce7;
      --blue: #38bdf8;
      --blue-dark: #0ea5e9;
      --blue-light: #e0f2fe;
      --orange: #f97316;
      --orange-light: #fff7ed;
      --bg: #f8fafc;
      --white: #ffffff;
      --dark: #0f172a;
      --gray-900: #1e293b;
      --gray-700: #334155;
      --gray-500: #64748b;
      --gray-300: #cbd5e1;
      --gray-100: #f1f5f9;
      --shadow: 0 4px 20px rgba(0,0,0,0.06);
      --shadow-lg: 0 10px 40px rgba(0,0,0,0.1);
      --radius: 16px;
      --radius-sm: 10px;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Poppins', sans-serif;
      background: var(--bg);
      color: var(--gray-700);
      min-height: 100vh;
    }

    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade { animation: fadeInUp 0.5s ease-out both; }
    .animate-delay-1 { animation-delay: 0.1s; }
    .animate-delay-2 { animation-delay: 0.15s; }
    .animate-delay-3 { animation-delay: 0.2s; }

    /* ===== NAVBAR ===== */
    .navbar {
      background: var(--white);
      box-shadow: 0 2px 20px rgba(0,0,0,0.05);
      padding: 0 2rem;
      height: 70px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 1000;
    }
    .navbar-brand {
      font-size: 1.5rem;
      font-weight: 800;
      color: var(--green);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }
    .navbar-brand i {
      background: linear-gradient(135deg, var(--green), var(--blue));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .navbar-links { display: flex; align-items: center; gap: 0.5rem; }
    .navbar-links a {
      color: var(--gray-700);
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      padding: 0.5rem 1rem;
      border-radius: 8px;
      transition: all 0.2s;
    }
    .navbar-links a:hover { color: var(--green); background: var(--green-light); }
    .btn-nav {
      padding: 0.55rem 1.3rem !important;
      border-radius: 10px !important;
      font-weight: 600 !important;
      font-size: 0.85rem !important;
      transition: all 0.25s !important;
    }
    .btn-login {
      color: var(--green) !important;
      border: 2px solid var(--green);
    }
    .btn-login:hover { background: var(--green) !important; color: var(--white) !important; }
    .btn-register {
      background: linear-gradient(135deg, var(--green), var(--green-dark)) !important;
      color: var(--white) !important;
      border: none;
    }

    /* ===== FLASH ===== */
    .flash-container { padding: 0 2rem; max-width: 1200px; margin: 1rem auto 0; }
    .flash-msg { padding: 0.85rem 1.2rem; border-radius: var(--radius-sm); margin-bottom: 0.5rem; font-size: 0.9rem; display: flex; align-items: center; gap: 0.6rem; animation: fadeInUp 0.4s ease-out; }
    .flash-success { background: var(--green-light); border-left: 4px solid var(--green); color: var(--green-dark); }
    .flash-error { background: #fef2f2; border-left: 4px solid #ef4444; color: #dc2626; }

    /* ===== PAGE HEADER BANNER ===== */
    .page-banner {
      background: linear-gradient(135deg, #ecfdf5, #e0f2fe);
      padding: 2.5rem 2rem 2rem;
    }
    .page-banner-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .page-title {
      font-size: 1.8rem;
      font-weight: 800;
      color: var(--dark);
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }
    .page-title i { color: var(--green); }

    /* ===== FILTER BAR ===== */
    .filter-bar {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .filter-btn {
      padding: 0.5rem 1.2rem;
      border-radius: 50px;
      border: 2px solid var(--gray-300);
      background: var(--white);
      color: var(--gray-500);
      font-family: 'Poppins', sans-serif;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.25s;
    }
    .filter-btn:hover {
      border-color: var(--green);
      color: var(--green);
      transform: translateY(-2px);
    }
    .filter-btn.active {
      background: linear-gradient(135deg, var(--green), var(--green-dark));
      color: var(--white);
      border-color: transparent;
      box-shadow: 0 4px 15px rgba(34, 197, 94, 0.25);
    }

    /* ===== CONTAINER ===== */
    .page-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem;
    }

    /* ===== SEARCH INFO ===== */
    .search-info {
      background: var(--white);
      border: 1px solid rgba(0,0,0,0.05);
      border-radius: var(--radius);
      padding: 1rem 1.5rem;
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.8rem;
      flex-wrap: wrap;
      box-shadow: var(--shadow);
    }
    .search-tag {
      padding: 0.35rem 0.9rem;
      background: var(--green-light);
      border-radius: 50px;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--green-dark);
      display: flex;
      align-items: center;
      gap: 0.3rem;
    }
    .search-clear {
      color: var(--gray-500);
      font-size: 0.8rem;
      text-decoration: none;
      margin-left: auto;
      transition: color 0.2s;
    }
    .search-clear:hover { color: #ef4444; }

    /* ===== RESULT COUNT ===== */
    .result-count {
      font-size: 0.9rem;
      color: var(--gray-500);
      margin-bottom: 1.5rem;
    }
    .result-count strong { color: var(--dark); }

    /* ===== FIELDS GRID ===== */
    .fields-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
      gap: 1.5rem;
    }
    .field-card {
      background: var(--white);
      border: 1px solid rgba(0,0,0,0.05);
      border-radius: var(--radius);
      overflow: hidden;
      transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
      text-decoration: none;
      color: inherit;
      display: block;
      box-shadow: var(--shadow);
    }
    .field-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 20px 50px rgba(0,0,0,0.12);
    }
    .field-card-img-wrap { position: relative; overflow: hidden; }
    .field-card-img {
      width: 100%;
      height: 210px;
      object-fit: cover;
      transition: transform 0.4s;
    }
    .field-card:hover .field-card-img { transform: scale(1.05); }
    .field-card-img-placeholder {
      width: 100%;
      height: 210px;
      background: linear-gradient(135deg, var(--green-light), var(--blue-light));
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--green);
      font-size: 3.5rem;
    }
    .card-badge-top {
      position: absolute;
      top: 12px;
      left: 12px;
      padding: 0.3rem 0.8rem;
      border-radius: 50px;
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      backdrop-filter: blur(8px);
    }
    .badge-5 { background: rgba(34,197,94,0.92); color: #fff; }
    .badge-7 { background: rgba(56,189,248,0.92); color: #fff; }
    .badge-11 { background: rgba(249,115,22,0.92); color: #fff; }
    .field-card-body { padding: 1.3rem; }
    .field-card-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--dark);
      margin-bottom: 0.4rem;
    }
    .field-card-address {
      font-size: 0.82rem;
      color: var(--gray-500);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }
    .field-card-address i { color: var(--orange); font-size: 0.75rem; }
    .field-card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 1rem;
      border-top: 1px solid var(--gray-100);
    }
    .field-price { font-size: 1.15rem; font-weight: 800; color: var(--green); }
    .field-price span { font-size: 0.75rem; font-weight: 400; color: var(--gray-500); }
    .card-book-hint {
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--blue-dark);
      display: flex;
      align-items: center;
      gap: 0.3rem;
      transition: gap 0.2s;
    }
    .field-card:hover .card-book-hint { gap: 0.6rem; color: var(--green); }

    /* ===== EMPTY STATE ===== */
    .empty-state {
      text-align: center;
      padding: 5rem 2rem;
      color: var(--gray-500);
    }
    .empty-icon {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      background: var(--gray-100);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.2rem;
    }
    .empty-icon i { font-size: 2rem; color: var(--gray-300); }
    .empty-state p { font-size: 1.05rem; margin-bottom: 1rem; }
    .empty-state .btn-back {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.6rem 1.5rem;
      background: var(--green-light);
      color: var(--green-dark);
      border-radius: 50px;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.9rem;
      transition: all 0.25s;
    }
    .empty-state .btn-back:hover {
      background: var(--green);
      color: var(--white);
      transform: translateY(-2px);
    }

    .footer {
      text-align: center;
      padding: 2rem;
      color: var(--gray-500);
      font-size: 0.85rem;
      border-top: 1px solid var(--gray-100);
      margin-top: 3rem;
    }

    @media (max-width: 768px) {
      .fields-grid { grid-template-columns: 1fr; }
      .page-banner-inner { flex-direction: column; align-items: flex-start; }
      .page-title { font-size: 1.4rem; }
    }
  </style>
</head>
<body>

  <!-- NAVBAR -->
  <nav class="navbar">
    <a href="/" class="navbar-brand"><i class="fas fa-futbol"></i> ĐặtSân.vn</a>
    <div class="navbar-links">
      <a href="/">Trang chủ</a>
      <a href="/fields">Sân bóng</a>
      <% if (typeof currentUser !== 'undefined' && currentUser) { %>
        <a href="/history">Lịch sử</a>
        <span style="color:var(--gray-500); font-size:0.85rem; padding:0.5rem 0;">Xin chào, <strong style="color:var(--dark);"><%= currentUser.name %></strong></span>
        <a href="/auth/logout" class="btn-nav btn-login">Đăng xuất</a>
      <% } else { %>
        <a href="/auth/login" class="btn-nav btn-login">Đăng nhập</a>
        <a href="/auth/register" class="btn-nav btn-register">Đăng ký</a>
      <% } %>
    </div>
  </nav>

  <!-- FLASH -->
  <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
    <div class="flash-container">
      <% success.forEach(msg => { %>
        <div class="flash-msg flash-success"><i class="fas fa-check-circle"></i> <%= msg %></div>
      <% }); %>
    </div>
  <% } %>
  <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <div class="flash-container">
      <% error.forEach(msg => { %>
        <div class="flash-msg flash-error"><i class="fas fa-exclamation-triangle"></i> <%= msg %></div>
      <% }); %>
    </div>
  <% } %>

  <!-- PAGE BANNER -->
  <div class="page-banner">
    <div class="page-banner-inner">
      <h1 class="page-title"><i class="fas fa-futbol"></i> <%= title %></h1>
      <div class="filter-bar">
        <a href="/fields" class="filter-btn <%= (!searchParams || !searchParams.type || searchParams.type === 'all') ? 'active' : '' %>">
          <i class="fas fa-th-large"></i> Tất cả
        </a>
        <a href="/fields?type=5-a-side" class="filter-btn <%= searchParams && searchParams.type === '5-a-side' ? 'active' : '' %>">
          ⚽ Sân 5
        </a>
        <a href="/fields?type=7-a-side" class="filter-btn <%= searchParams && searchParams.type === '7-a-side' ? 'active' : '' %>">
          ⚽ Sân 7
        </a>
        <a href="/fields?type=11-a-side" class="filter-btn <%= searchParams && searchParams.type === '11-a-side' ? 'active' : '' %>">
          ⚽ Sân 11
        </a>
      </div>
    </div>
  </div>

  <div class="page-container">

    <!-- Search tags -->
    <% if (searchParams && (searchParams.date || searchParams.keyword || searchParams.time)) { %>
      <div class="search-info animate-fade">
        <span style="color:var(--gray-500); font-size:0.85rem;"><i class="fas fa-filter"></i> Bộ lọc:</span>
        <% if (searchParams.keyword) { %>
          <span class="search-tag"><i class="fas fa-search"></i> "<%= searchParams.keyword %>"</span>
        <% } %>
        <% if (searchParams.date) { %>
          <span class="search-tag"><i class="fas fa-calendar"></i> <%= searchParams.date %></span>
        <% } %>
        <% if (searchParams.time) { %>
          <span class="search-tag"><i class="fas fa-clock"></i> <%= searchParams.time %></span>
        <% } %>
        <a href="/fields" class="search-clear"><i class="fas fa-times-circle"></i> Xóa lọc</a>
      </div>
    <% } %>

    <p class="result-count">Tìm thấy <strong><%= fields.length %></strong> sân</p>

    <% if (fields && fields.length > 0) { %>
      <div class="fields-grid">
        <% fields.forEach((field, idx) => { %>
          <a href="/fields/<%= field._id %><%= searchParams && searchParams.date ? '?date=' + searchParams.date : '' %>" class="field-card animate-fade" style="animation-delay: <%= idx * 0.08 %>s;">
            <div class="field-card-img-wrap">
              <% if (field.images && field.images.length > 0) { %>
                <img src="<%= field.images[0] %>" alt="<%= field.name %>" class="field-card-img" />
              <% } else { %>
                <div class="field-card-img-placeholder"><i class="fas fa-futbol"></i></div>
              <% } %>
              <span class="card-badge-top <%= field.type === '5-a-side' ? 'badge-5' : field.type === '7-a-side' ? 'badge-7' : 'badge-11' %>">
                <i class="fas fa-users"></i>
                <%= field.type === '5-a-side' ? 'Sân 5' : field.type === '7-a-side' ? 'Sân 7' : 'Sân 11' %>
              </span>
            </div>
            <div class="field-card-body">
              <h3 class="field-card-title"><%= field.name %></h3>
              <p class="field-card-address"><i class="fas fa-map-marker-alt"></i> <%= field.address %></p>
              <div class="field-card-footer">
                <span class="field-price"><%= field.pricePerSlot.toLocaleString('vi-VN') %>đ <span>/ slot</span></span>
                <span class="card-book-hint">Đặt ngay <i class="fas fa-arrow-right"></i></span>
              </div>
            </div>
          </a>
        <% }); %>
      </div>
    <% } else { %>
      <div class="empty-state animate-fade">
        <div class="empty-icon"><i class="fas fa-search"></i></div>
        <p>Không tìm thấy sân nào phù hợp.</p>
        <a href="/fields" class="btn-back"><i class="fas fa-arrow-left"></i> Xem tất cả sân</a>
      </div>
    <% } %>
  </div>

  <footer class="footer">
    <p>© 2026 ĐặtSân.vn — Hệ thống đặt sân bóng đá online</p>
  </footer>

</body>
</html>
