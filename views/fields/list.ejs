<!-- PAGE HEADER -->
<div class="bg-surface-container-low py-16 px-6">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
    <div>
      <p class="kinetic-label text-on-surface-variant mb-2">DIRECTORY OUTPOST</p>
      <h1 class="kinetic-headline text-4xl md:text-5xl text-on-surface tracking-tighter mb-2">
        <span class="kinetic-display text-primary">CURATED</span> MATCHES
      </h1>
      <p class="text-on-surface-variant font-light">Explore premier athletic environments.</p>
    </div>

    <!-- Filter Tabs -->
    <div class="flex gap-2 flex-wrap">
      <a href="/fields"
        class="px-6 py-3 rounded-full font-bold text-xs uppercase tracking-[0.1em] font-['Space_Grotesk'] transition-all duration-300 <%= (!searchParams || !searchParams.type || searchParams.type === 'all') ? 'bg-primary text-white shadow-cta-glow' : 'bg-surface-container-lowest text-on-surface-variant hover:text-primary hover:bg-white' %>">
        TẤT CẢ
      </a>
      <a href="/fields?type=5-a-side"
        class="px-6 py-3 rounded-full font-bold text-xs uppercase tracking-[0.1em] font-['Space_Grotesk'] transition-all duration-300 <%= searchParams && searchParams.type === '5-a-side' ? 'bg-primary text-white shadow-cta-glow' : 'bg-surface-container-lowest text-on-surface-variant hover:text-primary hover:bg-white' %>">
        SÂN 5
      </a>
      <a href="/fields?type=7-a-side"
        class="px-6 py-3 rounded-full font-bold text-xs uppercase tracking-[0.1em] font-['Space_Grotesk'] transition-all duration-300 <%= searchParams && searchParams.type === '7-a-side' ? 'bg-primary text-white shadow-cta-glow' : 'bg-surface-container-lowest text-on-surface-variant hover:text-primary hover:bg-white' %>">
        SÂN 7
      </a>
      <a href="/fields?type=11-a-side"
        class="px-6 py-3 rounded-full font-bold text-xs uppercase tracking-[0.1em] font-['Space_Grotesk'] transition-all duration-300 <%= searchParams && searchParams.type === '11-a-side' ? 'bg-primary text-white shadow-cta-glow' : 'bg-surface-container-lowest text-on-surface-variant hover:text-primary hover:bg-white' %>">
        SÂN 11
      </a>
    </div>
  </div>
</div>

<div class="max-w-7xl mx-auto px-6 py-12">
  <!-- Active filters -->
  <% if (searchParams && (searchParams.date || searchParams.keyword || searchParams.time)) { %>
    <div class="bg-surface-container rounded-[2rem] p-4 mb-8 flex items-center gap-3 flex-wrap shadow-ambient animate-fade-in">
      <span class="kinetic-label text-on-surface-variant flex items-center gap-2">
        <span class="material-symbols-outlined text-sm">filter_alt</span> ĐANG LỌC:
      </span>
      <% if (searchParams.keyword) { %>
        <span class="bg-white text-primary px-4 py-2 rounded-full text-xs font-['Space_Grotesk'] font-bold tracking-widest flex items-center gap-1 shadow-sm">
          <span class="material-symbols-outlined text-[14px]">search</span> "<%= searchParams.keyword %>"
        </span>
      <% } %>
      <% if (searchParams.date) { %>
        <span class="bg-white text-primary px-4 py-2 rounded-full text-xs font-['Space_Grotesk'] font-bold tracking-widest flex items-center gap-1 shadow-sm">
          <span class="material-symbols-outlined text-[14px]">calendar_today</span>
          <%= searchParams.date %>
        </span>
      <% } %>
      <% if (searchParams.time) { %>
        <span class="bg-white text-primary px-4 py-2 rounded-full text-xs font-['Space_Grotesk'] font-bold tracking-widest flex items-center gap-1 shadow-sm">
          <span class="material-symbols-outlined text-[14px]">schedule</span>
          <%= searchParams.time %>
        </span>
      <% } %>
      <a href="/fields" class="ml-auto kinetic-label text-on-surface-variant hover:text-error flex items-center gap-1 transition-colors pr-2">
        <span class="material-symbols-outlined text-[16px]">close</span> XÓA LỌC
      </a>
    </div>
  <% } %>

  <!-- Fields grid -->
  <% if (fields && fields.length > 0) { %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% fields.forEach((field, idx) => { %>
        <a href="/fields/<%= field._id %><%= searchParams && searchParams.date ? '?date=' + searchParams.date : '' %>"
          class="group block h-[500px] relative overflow-hidden rounded-[2.5rem] transform hover:-translate-y-2 transition-all duration-700 shadow-sm hover:shadow-ambient animate-fade-in"
          style="animation-delay: <%= Math.min(idx * 0.08, 0.5) %>s;">
          
          <!-- Image Layer -->
          <% if (field.images && field.images.length > 0) { %>
            <img class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
              src="<%= field.images[0] %>" alt="<%= field.name %>" />
          <% } else { %>
            <div class="w-full h-full bg-surface-container flex items-center justify-center transition-transform duration-1000 group-hover:scale-105">
              <span class="material-symbols-outlined text-6xl text-on-surface-variant/30">sports_soccer</span>
            </div>
          <% } %>

          <!-- Gradient Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-[#0b1c30] via-[#0b1c30]/40 to-transparent opacity-90 group-hover:opacity-100 transition-opacity duration-700"></div>

          <!-- Top Badge -->
          <div class="absolute top-6 right-6 bg-white/20 backdrop-blur-md border border-white/20 text-white px-4 py-1.5 rounded-full text-[10px] font-['Space_Grotesk'] font-bold uppercase tracking-[0.2em] shadow-sm">
            <%= field.type === '5-a-side' ? 'Sân 5' : field.type === '7-a-side' ? 'Sân 7' : 'Sân 11' %>
          </div>

          <!-- Bottom Content -->
          <div class="absolute bottom-0 left-0 right-0 p-8">
            <p class="text-[9px] text-primary-container uppercase font-['Space_Grotesk'] tracking-[0.2em] font-bold mb-2">
              <span class="material-symbols-outlined text-[10px] align-middle mr-1">location_on</span>
              <span class="align-middle line-clamp-1 block sm:inline"><%= field.address %></span>
            </p>
            <h3 class="text-white text-3xl font-black italic tracking-tighter mb-4 leading-none"><%= field.name %></h3>
            
            <div class="flex items-center justify-between">
              <div>
                <p class="text-[9px] text-white/60 uppercase font-['Space_Grotesk'] tracking-[0.2em] font-bold">GIÁ TỪ</p>
                <p class="text-white font-medium text-lg leading-tight mt-1"><%= field.pricePerSlot.toLocaleString('vi-VN') %>đ <span class="text-white/60 text-xs">/ slot</span></p>
              </div>
              <div class="w-12 h-12 bg-white/10 backdrop-blur rounded-full flex items-center justify-center text-white group-hover:bg-primary group-hover:shadow-cta-glow transition-all duration-500">
                <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
              </div>
            </div>
          </div>
        </a>
      <% }); %>
    </div>
  <% } else { %>
    <div class="text-center py-32 bg-surface-container-lowest rounded-[3rem] animate-fade-in shadow-ambient">
      <div class="w-24 h-24 bg-surface-container rounded-full flex items-center justify-center mx-auto mb-6">
        <span class="material-symbols-outlined text-5xl text-on-surface-variant">search_off</span>
      </div>
      <h3 class="kinetic-headline text-2xl text-on-surface mb-2">KHÔNG TÌM THẤY SÂN</h3>
      <p class="text-on-surface-variant mb-6 font-light">Thử điều chỉnh lại bộ lọc hoặc quay lại thư mục gốc.</p>
      <a href="/fields"
        class="inline-flex items-center gap-2 bg-primary text-white px-8 py-3 rounded-full font-bold text-xs font-['Space_Grotesk'] uppercase tracking-widest hover:bg-primary-container hover:text-primary transition-all shadow-cta-glow">
        <span class="material-symbols-outlined text-[16px]">arrow_back</span>
        XEM TẤT CẢ SÂN
      </a>
    </div>
  <% } %>
</div>