<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | ĐặtSân.vn</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      background: #0a0f1c;
      color: #e0e6ed;
      min-height: 100vh;
    }

    /* ===== NAVBAR ===== */
    .navbar {
      background: rgba(15, 23, 42, 0.85);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      padding: 0 2rem;
      height: 70px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 1000;
    }
    .navbar-brand {
      font-size: 1.5rem;
      font-weight: 800;
      color: #34d399;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .navbar-brand i { font-size: 1.3rem; }
    .navbar-links { display: flex; align-items: center; gap: 1.5rem; }
    .navbar-links a {
      color: #94a3b8;
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      transition: color 0.2s;
    }
    .navbar-links a:hover { color: #34d399; }
    .btn-nav {
      padding: 0.5rem 1.2rem;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.85rem;
      text-decoration: none;
      transition: all 0.2s;
    }
    .btn-login { color: #34d399; border: 1px solid #34d399; }
    .btn-login:hover { background: rgba(52, 211, 153, 0.1); }
    .btn-register {
      background: linear-gradient(135deg, #34d399, #059669);
      color: #fff;
      border: none;
    }

    /* ===== FLASH ===== */
    .flash-container { padding: 0 2rem; max-width: 1200px; margin: 1rem auto 0; }
    .flash-msg { padding: 0.8rem 1.2rem; border-radius: 8px; margin-bottom: 0.5rem; font-size: 0.9rem; display: flex; align-items: center; gap: 0.5rem; }
    .flash-success { background: rgba(52, 211, 153, 0.15); border: 1px solid rgba(52, 211, 153, 0.3); color: #34d399; }
    .flash-error { background: rgba(239, 68, 68, 0.15); border: 1px solid rgba(239, 68, 68, 0.3); color: #ef4444; }

    /* ===== PAGE ===== */
    .page-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem;
    }
    .page-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .page-title {
      font-size: 1.6rem;
      font-weight: 700;
      color: #f1f5f9;
    }

    /* ===== FILTER BAR ===== */
    .filter-bar {
      display: flex;
      gap: 0.8rem;
      flex-wrap: wrap;
    }
    .filter-btn {
      padding: 0.5rem 1rem;
      border-radius: 20px;
      border: 1px solid rgba(255,255,255,0.1);
      background: transparent;
      color: #94a3b8;
      font-family: 'Inter', sans-serif;
      font-size: 0.85rem;
      font-weight: 500;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.2s;
    }
    .filter-btn:hover {
      border-color: #34d399;
      color: #34d399;
    }
    .filter-btn.active {
      background: linear-gradient(135deg, #34d399, #059669);
      color: #fff;
      border-color: transparent;
    }

    /* ===== SEARCH INFO ===== */
    .search-info {
      background: rgba(30, 41, 59, 0.6);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 12px;
      padding: 1rem 1.5rem;
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .search-tag {
      padding: 0.3rem 0.8rem;
      background: rgba(52, 211, 153, 0.1);
      border: 1px solid rgba(52, 211, 153, 0.2);
      border-radius: 20px;
      font-size: 0.8rem;
      color: #34d399;
    }

    /* ===== FIELDS GRID ===== */
    .fields-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
      gap: 1.5rem;
    }
    .field-card {
      background: rgba(30, 41, 59, 0.6);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 16px;
      overflow: hidden;
      transition: all 0.3s;
      text-decoration: none;
      color: inherit;
      display: block;
    }
    .field-card:hover {
      transform: translateY(-4px);
      border-color: rgba(52, 211, 153, 0.3);
      box-shadow: 0 12px 40px rgba(0,0,0,0.3);
    }
    .field-card-img {
      width: 100%;
      height: 200px;
      object-fit: cover;
    }
    .field-card-img-placeholder {
      width: 100%;
      height: 200px;
      background: linear-gradient(135deg, #1e293b, #0f172a);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #475569;
      font-size: 3rem;
    }
    .field-card-body { padding: 1.2rem; }
    .field-card-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: #f1f5f9;
      margin-bottom: 0.3rem;
    }
    .field-card-address {
      font-size: 0.85rem;
      color: #64748b;
      margin-bottom: 0.8rem;
      display: flex;
      align-items: center;
      gap: 0.3rem;
    }
    .field-card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .field-badge {
      padding: 0.3rem 0.7rem;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
    }
    .badge-5 { background: rgba(52, 211, 153, 0.15); color: #34d399; }
    .badge-7 { background: rgba(6, 182, 212, 0.15); color: #06b6d4; }
    .badge-11 { background: rgba(168, 85, 247, 0.15); color: #a855f7; }
    .field-price {
      font-size: 1.05rem;
      font-weight: 700;
      color: #34d399;
    }
    .field-price span {
      font-size: 0.75rem;
      font-weight: 400;
      color: #64748b;
    }

    /* ===== RESULT COUNT ===== */
    .result-count {
      font-size: 0.9rem;
      color: #64748b;
      margin-bottom: 1rem;
    }

    /* ===== EMPTY STATE ===== */
    .empty-state {
      text-align: center;
      padding: 4rem 2rem;
      color: #64748b;
    }
    .empty-state i { font-size: 3rem; margin-bottom: 1rem; display: block; }
    .empty-state p { font-size: 1.1rem; margin-bottom: 1rem; }
    .empty-state a {
      color: #34d399;
      text-decoration: none;
      font-weight: 500;
    }

    .footer {
      text-align: center;
      padding: 2rem;
      color: #475569;
      font-size: 0.85rem;
      border-top: 1px solid rgba(255,255,255,0.05);
      margin-top: 2rem;
    }

    @media (max-width: 768px) {
      .fields-grid { grid-template-columns: 1fr; }
      .page-header { flex-direction: column; align-items: flex-start; }
    }
  </style>
</head>
<body>

  <!-- NAVBAR -->
  <nav class="navbar">
    <a href="/" class="navbar-brand"><i class="fas fa-futbol"></i> ĐặtSân.vn</a>
    <div class="navbar-links">
      <a href="/fields">Danh sách sân</a>
      <% if (typeof currentUser !== 'undefined' && currentUser) { %>
        <span style="color:#64748b; font-size:0.85rem;">Xin chào, <strong style="color:#f1f5f9;"><%= currentUser.name %></strong></span>
        <a href="/auth/logout" class="btn-nav btn-login">Đăng xuất</a>
      <% } else { %>
        <a href="/auth/login" class="btn-nav btn-login">Đăng nhập</a>
        <a href="/auth/register" class="btn-nav btn-register">Đăng ký</a>
      <% } %>
    </div>
  </nav>

  <!-- FLASH -->
  <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
    <div class="flash-container">
      <% success.forEach(msg => { %>
        <div class="flash-msg flash-success"><i class="fas fa-check-circle"></i> <%= msg %></div>
      <% }); %>
    </div>
  <% } %>
  <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <div class="flash-container">
      <% error.forEach(msg => { %>
        <div class="flash-msg flash-error"><i class="fas fa-exclamation-circle"></i> <%= msg %></div>
      <% }); %>
    </div>
  <% } %>

  <div class="page-container">
    <div class="page-header">
      <h1 class="page-title"><i class="fas fa-list" style="color:#34d399; margin-right:0.5rem;"></i><%= title %></h1>
      <div class="filter-bar">
        <a href="/fields" class="filter-btn <%= (!searchParams || !searchParams.type || searchParams.type === 'all') ? 'active' : '' %>">Tất cả</a>
        <a href="/fields?type=5-a-side" class="filter-btn <%= searchParams && searchParams.type === '5-a-side' ? 'active' : '' %>">Sân 5</a>
        <a href="/fields?type=7-a-side" class="filter-btn <%= searchParams && searchParams.type === '7-a-side' ? 'active' : '' %>">Sân 7</a>
        <a href="/fields?type=11-a-side" class="filter-btn <%= searchParams && searchParams.type === '11-a-side' ? 'active' : '' %>">Sân 11</a>
      </div>
    </div>

    <!-- Search info (if coming from search) -->
    <% if (searchParams && (searchParams.date || searchParams.keyword || searchParams.time)) { %>
      <div class="search-info">
        <span style="color:#94a3b8; font-size:0.85rem;"><i class="fas fa-filter"></i> Bộ lọc:</span>
        <% if (searchParams.keyword) { %>
          <span class="search-tag"><i class="fas fa-search"></i> "<%= searchParams.keyword %>"</span>
        <% } %>
        <% if (searchParams.date) { %>
          <span class="search-tag"><i class="fas fa-calendar"></i> <%= searchParams.date %></span>
        <% } %>
        <% if (searchParams.time) { %>
          <span class="search-tag"><i class="fas fa-clock"></i> <%= searchParams.time %></span>
        <% } %>
        <a href="/fields" style="color:#64748b; font-size:0.8rem; text-decoration:none;"><i class="fas fa-times"></i> Xóa lọc</a>
      </div>
    <% } %>

    <p class="result-count">Tìm thấy <strong style="color:#f1f5f9;"><%= fields.length %></strong> sân</p>

    <% if (fields && fields.length > 0) { %>
      <div class="fields-grid">
        <% fields.forEach(field => { %>
          <a href="/fields/<%= field._id %><%= searchParams && searchParams.date ? '?date=' + searchParams.date : '' %>" class="field-card">
            <% if (field.images && field.images.length > 0) { %>
              <img src="<%= field.images[0] %>" alt="<%= field.name %>" class="field-card-img" />
            <% } else { %>
              <div class="field-card-img-placeholder"><i class="fas fa-futbol"></i></div>
            <% } %>
            <div class="field-card-body">
              <h3 class="field-card-title"><%= field.name %></h3>
              <p class="field-card-address"><i class="fas fa-map-marker-alt"></i> <%= field.address %></p>
              <div class="field-card-footer">
                <span class="field-badge <%= field.type === '5-a-side' ? 'badge-5' : field.type === '7-a-side' ? 'badge-7' : 'badge-11' %>">
                  <i class="fas fa-users"></i>
                  <%= field.type === '5-a-side' ? 'Sân 5' : field.type === '7-a-side' ? 'Sân 7' : 'Sân 11' %>
                </span>
                <span class="field-price"><%= field.pricePerSlot.toLocaleString('vi-VN') %>đ <span>/ slot</span></span>
              </div>
            </div>
          </a>
        <% }); %>
      </div>
    <% } else { %>
      <div class="empty-state">
        <i class="fas fa-search"></i>
        <p>Không tìm thấy sân nào phù hợp.</p>
        <a href="/fields"><i class="fas fa-arrow-left"></i> Xem tất cả sân</a>
      </div>
    <% } %>
  </div>

  <footer class="footer">
    <p>© 2026 ĐặtSân.vn — Hệ thống đặt sân bóng đá online</p>
  </footer>

</body>
</html>
