<section class="rounded-2xl bg-surface-container-low p-6 md:p-10 mb-8 shadow-ambient flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4">
  <div>
    <p class="kinetic-label text-on-surface-variant mb-2">Field directory</p>
    <h2 class="kinetic-display text-5xl md:text-6xl">YOUR PITCHES</h2>
    <p class="mt-3 text-on-surface-variant max-w-2xl">
      Admin gán sân cho bạn hoặc sân bạn tự tạo đều hiển thị ở đây. Sân mới của owner phải qua bước duyệt trước khi mở công khai. Các sân bị từ chối sẽ được chuyển sang mục `Notifications`.
    </p>
  </div>
  <div class="flex flex-wrap gap-3">
    <a href="/owner/schedule" class="rounded-full bg-white px-6 py-3 text-sm font-semibold text-on-surface shadow-ambient hover:-translate-y-1 transition-all duration-300">Pitch Schedule</a>
    <a href="/owner/fields/create" class="rounded-full bg-gradient-to-r from-primary to-primary-container text-white px-7 py-3 text-sm font-semibold shadow-cta hover:-translate-y-1 transition-all duration-300">+ Thêm sân</a>
  </div>
</section>

<section class="grid grid-cols-2 xl:grid-cols-4 gap-4 mb-8">
  <div class="rounded-3xl bg-white p-5 shadow-ambient">
    <p class="kinetic-label text-on-surface-variant mb-2">Tổng sân</p>
    <p class="text-3xl font-black text-on-surface"><%= stats.total %></p>
  </div>
  <div class="rounded-3xl bg-white p-5 shadow-ambient">
    <p class="kinetic-label text-on-surface-variant mb-2">Đang live</p>
    <p class="text-3xl font-black text-secondary"><%= stats.live %></p>
  </div>
  <div class="rounded-3xl bg-white p-5 shadow-ambient">
    <p class="kinetic-label text-on-surface-variant mb-2">Chờ duyệt</p>
    <p class="text-3xl font-black text-primary"><%= stats.pending %></p>
  </div>
  <div class="rounded-3xl bg-white p-5 shadow-ambient">
    <p class="kinetic-label text-on-surface-variant mb-2">Thông báo</p>
    <p class="text-3xl font-black text-error"><%= notificationCount %></p>
  </div>
</section>

<% if (notificationCount > 0) { %>
  <section class="mb-8 rounded-2xl bg-red-50 px-6 py-5 shadow-ambient">
    <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
      <div>
        <p class="kinetic-label text-error mb-2">Notifications</p>
        <p class="text-sm text-error">
          Có <span class="font-semibold"><%= notificationCount %></span> sân bị admin từ chối. Xem lý do ở mục thông báo để chỉnh sửa và gửi lại.
        </p>
      </div>
      <a href="/owner/notifications" class="inline-flex items-center justify-center rounded-full bg-error px-5 py-2.5 text-sm font-semibold text-white hover:opacity-90 transition-opacity">
        Mở thông báo
      </a>
    </div>
  </section>
<% } %>

<section>
  <% if (fields && fields.length > 0) { %>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
      <% fields.forEach((field) => { %>
        <%
          const approvalStatus = field.approvalStatus || 'approved';
          const approvalBadgeClass = approvalStatus === 'approved'
            ? 'bg-secondary-container text-secondary'
            : approvalStatus === 'pending'
              ? 'bg-primary/10 text-primary'
              : 'bg-red-50 text-error';
          const operationalBadgeClass = field.status === 'active'
            ? 'bg-white text-on-surface'
            : 'bg-surface-container text-on-surface-variant';
        %>
        <article class="rounded-2xl bg-white overflow-hidden shadow-ambient hover:-translate-y-1 transition-all duration-500">
          <div class="h-52 bg-surface-container relative">
            <% if (field.images && field.images.length > 0) { %>
              <img src="<%= field.images[0] %>" alt="<%= field.name %>" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
            <% } else { %>
              <div class="w-full h-full flex items-center justify-center text-on-surface-variant">
                <span class="material-symbols-outlined text-5xl">stadium</span>
              </div>
            <% } %>
            <div class="absolute top-4 right-4 flex flex-col items-end gap-2">
              <span class="rounded-full px-3 py-1 text-[11px] font-semibold capitalize <%= approvalBadgeClass %>">
                <%= approvalStatus %>
              </span>
              <span class="rounded-full px-3 py-1 text-[11px] font-semibold <%= operationalBadgeClass %>">
                <%= field.status === 'active' ? 'operational' : 'maintenance' %>
              </span>
            </div>
          </div>
          <div class="p-6">
            <p class="kinetic-label text-on-surface-variant mb-1"><%= field.city || '' %> - <%= field.district || '' %></p>
            <h3 class="kinetic-headline text-3xl text-on-surface leading-tight"><%= field.name %></h3>
            <p class="text-sm text-on-surface-variant mt-2 line-clamp-2"><%= field.address %></p>
            <div class="mt-4 flex items-center justify-between">
              <span class="rounded-full bg-surface-container-low px-3 py-1 text-xs font-semibold text-on-surface"><%= field.type %></span>
              <span class="text-sm font-semibold"><%= Number(field.pricePerSlot || 0).toLocaleString('vi-VN') %>đ / slot</span>
            </div>
            <% if (field.approvalNote) { %>
              <div class="mt-4 rounded-2xl bg-surface-container-low px-4 py-3 text-xs text-on-surface-variant">
                <%= field.approvalNote %>
              </div>
            <% } %>
            <div class="mt-4 flex items-center justify-between gap-3">
              <a href="/owner/fields/<%= field._id %>/edit" class="inline-flex text-sm font-semibold text-primary hover:underline">Chỉnh sửa sân</a>
              <% if (approvalStatus === 'approved') { %>
                <a href="/owner/schedule?fieldId=<%= field._id %>" class="inline-flex text-sm font-semibold text-on-surface hover:underline">Xem lịch</a>
              <% } %>
            </div>
          </div>
        </article>
      <% }) %>
    </div>
  <% } else { %>
    <div class="rounded-2xl bg-white p-12 text-center shadow-ambient">
      <div class="w-20 h-20 bg-surface-container-low rounded-full flex items-center justify-center mx-auto mb-6">
        <span class="material-symbols-outlined text-4xl text-on-surface-variant">stadium</span>
      </div>
      <h3 class="kinetic-headline text-2xl text-on-surface mb-2">CHƯA CÓ SÂN NÀO</h3>
      <p class="text-on-surface-variant font-light mb-6">Bạn chưa có sân nào đang hiển thị. Nếu có sân bị từ chối, hãy xem mục Notifications.</p>
      <a href="/owner/fields/create" class="inline-flex items-center gap-2 bg-primary text-white px-8 py-3 rounded-full font-bold text-xs font-['Space_Grotesk'] uppercase tracking-widest hover:shadow-cta transition-all">
        <span class="material-symbols-outlined text-[16px]">add</span>
        THÊM SÂN MỚI
      </a>
    </div>
  <% } %>
</section>
