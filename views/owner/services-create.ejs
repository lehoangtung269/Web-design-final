<div class="max-w-2xl mx-auto">
    <section class="rounded-2xl bg-surface-container-low p-6 md:p-8 mb-8 shadow-ambient">
        <p class="kinetic-label text-on-surface-variant mb-2">Tạo mới</p>
        <h2 class="kinetic-display text-4xl md:text-5xl">THÊM DỊCH VỤ</h2>
        <p class="mt-2 text-on-surface-variant">Điền thông tin bên dưới để tạo dịch vụ bổ sung có thể đặt kèm cho sân của bạn.</p>
    </section>

    <div class="rounded-2xl bg-white shadow-ambient overflow-hidden">
        <form action="/owner/services" method="POST" enctype="multipart/form-data" id="serviceForm"
            class="p-6 md:p-8 space-y-8" novalidate>

            <!-- Basic Info -->
            <fieldset>
                <legend class="kinetic-label text-primary mb-5 flex items-center gap-2">
                    <span class="material-symbols-outlined text-base">info</span>Thông tin cơ bản
                </legend>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="md:col-span-2">
                        <label for="name" class="block text-sm font-semibold mb-1.5">Tên dịch vụ <span
                                class="text-error">*</span></label>
                        <input type="text" id="name" name="name" required maxlength="100"
                            placeholder="Ví dụ: Thuê giày, nước tăng lực, bóng..."
                            class="w-full rounded-xl border border-outline-variant px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/50">
                    </div>
                    <div>
                        <label for="category" class="block text-sm font-semibold mb-1.5">Danh mục</label>
                        <select id="category" name="category"
                            class="w-full rounded-xl border border-outline-variant bg-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/50">
                            <option value="beverage">🥤 Beverage</option>
                            <option value="equipment">⚽ Equipment</option>
                            <option value="rental">👟 Rental</option>
                            <option value="food">🍔 Food</option>
                            <option value="other" selected>📦 Other</option>
                        </select>
                    </div>
                    <div>
                        <label for="field" class="block text-sm font-semibold mb-1.5">Sân <span
                                class="text-error">*</span></label>
                        <select id="field" name="field" required
                            class="w-full rounded-xl border border-outline-variant bg-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/50">
                            <option value="">-- Chọn sân --</option>
                            <% fields.forEach(field=> { %>
                                <option value="<%= field._id %>">
                                    <%= field.name %>
                                </option>
                                <% }) %>
                        </select>
                    </div>
                    <div class="md:col-span-2">
                        <label for="description" class="block text-sm font-semibold mb-1.5">Mô tả</label>
                        <textarea id="description" name="description" rows="3"
                            placeholder="Mô tả dịch vụ, chất lượng, thương hiệu..."
                            class="w-full rounded-xl border border-outline-variant px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/50 resize-none"></textarea>
                    </div>
                </div>
            </fieldset>

            <hr class="border-outline-variant">

            <!-- Pricing -->
            <fieldset>
                <legend class="kinetic-label text-secondary mb-5 flex items-center gap-2">
                    <span class="material-symbols-outlined text-base">payments</span>Giá bán
                </legend>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div>
                        <label for="price" class="block text-sm font-semibold mb-1.5">Giá (VNĐ) <span
                                class="text-error">*</span></label>
                        <div class="relative">
                            <input type="number" id="price" name="price" required min="0" step="any" placeholder="50000"
                                class="w-full rounded-xl border border-outline-variant px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/50 pr-10">
                            <span
                                class="absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-sm">đ</span>
                        </div>
                    </div>
                    <div>
                        <label for="unit" class="block text-sm font-semibold mb-1.5">Đơn vị</label>
                        <select id="unit" name="unit"
                            class="w-full rounded-xl border border-outline-variant bg-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/50">
                            <option value="suất">/ suất</option>
                            <option value="giờ">/ giờ</option>
                            <option value="cái">/ cái</option>
                            <option value="lon">/ lon</option>
                            <option value="chai">/ chai</option>
                            <option value="bộ">/ bộ</option>
                        </select>
                    </div>
                    <div>
                        <label for="maxQuantity" class="block text-sm font-semibold mb-1.5">Số lượng tối đa / booking</label>
                        <input type="number" id="maxQuantity" name="maxQuantity" min="1" placeholder="Không giới hạn"
                            class="w-full rounded-xl border border-outline-variant px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/50">
                    </div>
                </div>
            </fieldset>

            <hr class="border-outline-variant">

            <!-- Image -->
            <fieldset>
                <legend class="kinetic-label text-on-surface-variant mb-5 flex items-center gap-2">
                    <span class="material-symbols-outlined text-base">image</span>Ảnh minh họa (không bắt buộc)
                </legend>
                <div id="imageUploadArea"
                    class="rounded-2xl border-2 border-dashed border-outline-variant p-8 text-center cursor-pointer hover:border-primary transition-colors"
                    onclick="document.getElementById('imageInput').click()">
                    <div id="uploadPrompt">
                        <span
                            class="material-symbols-outlined text-5xl text-on-surface-variant block mb-3">cloud_upload</span>
                        <p class="text-sm text-on-surface-variant mb-2">Kéo thả hoặc bấm để tải ảnh lên</p>
                        <p class="text-xs text-on-surface-variant">JPG, PNG, WebP — max 5 MB</p>
                    </div>
                    <div id="previewContainer" class="hidden">
                        <img id="imagePreview" src="" alt="Preview" class="max-h-48 mx-auto rounded-xl shadow-ambient">
                        <button type="button" onclick="event.stopPropagation(); removeImage()"
                            class="mt-3 inline-flex items-center gap-1 text-error text-xs rounded-full px-3 py-1.5 bg-red-50 hover:bg-red-100 transition-colors">
                            <span class="material-symbols-outlined text-[14px]">close</span>Xóa ảnh
                        </button>
                    </div>
                </div>
                <input type="file" name="image" id="imageInput" accept="image/*" class="hidden"
                    onchange="previewImage(this)">
            </fieldset>

            <hr class="border-outline-variant">

            <!-- Status toggle -->
            <div class="flex items-center gap-4">
                <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" id="isActive" name="isActive" value="true" checked class="sr-only peer">
                    <div
                        class="w-11 h-6 bg-outline-variant rounded-full peer peer-checked:bg-primary transition-colors after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:after:translate-x-5">
                    </div>
                </label>
                <div>
                    <p class="font-semibold text-sm text-on-surface">Kích hoạt ngay</p>
                    <p class="text-xs text-on-surface-variant">Dịch vụ sẽ xuất hiện trong bước thanh toán</p>
                </div>
            </div>

            <!-- Buttons -->
            <div class="flex justify-between pt-2">
                <a href="/owner/services"
                    class="inline-flex items-center gap-2 rounded-full bg-surface-container-low text-on-surface px-6 py-2.5 text-sm font-semibold hover:-translate-y-0.5 transition-all">
                    <span class="material-symbols-outlined text-[16px]">arrow_back</span>Quay lại
                </a>
                <button type="submit" id="submitBtn"
                    class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-primary to-primary-container text-white px-8 py-2.5 text-sm font-semibold shadow-cta hover:-translate-y-0.5 transition-all">
                    <span class="material-symbols-outlined text-[16px]">save</span>Lưu dịch vụ
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    function previewImage(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById('imagePreview').src = e.target.result;
                document.getElementById('previewContainer').classList.remove('hidden');
                document.getElementById('uploadPrompt').classList.add('hidden');
            };
            reader.readAsDataURL(input.files[0]);
        }
    }
    function removeImage() {
        document.getElementById('imageInput').value = '';
        document.getElementById('previewContainer').classList.add('hidden');
        document.getElementById('uploadPrompt').classList.remove('hidden');
    }

    // Show loading state on submit (rely on HTML5 `required` for validation)
    document.getElementById('serviceForm').addEventListener('submit', function (e) {
        if (!this.checkValidity()) return; // let browser show native errors
        document.getElementById('submitBtn').innerHTML = '<span class="material-symbols-outlined text-[16px] animate-spin">progress_activity</span>Đang lưu...';
        document.getElementById('submitBtn').disabled = true;
    });
</script>
