<section class="rounded-[2rem] bg-surface-container-low p-6 md:p-10 mb-8 shadow-ambient">
  <p class="kinetic-label text-on-surface-variant mb-3">Pitch onboarding</p>
  <h2 class="kinetic-display text-5xl md:text-6xl">CREATE NEW FIELD</h2>
  <p class="mt-4 text-on-surface-variant max-w-2xl">
    Sân mới do chủ sân tạo sẽ vào trạng thái <span class="font-semibold text-on-surface">chờ admin duyệt</span>.
    Chỉ sau khi được duyệt, sân mới xuất hiện ở trang công khai và nhận booking.
  </p>
</section>

<form action="/owner/fields" method="POST" enctype="multipart/form-data" class="max-w-5xl rounded-[2rem] bg-white p-6 md:p-8 space-y-6 shadow-ambient">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <input name="name" required placeholder="Tên sân" class="rounded-2xl border-none bg-surface-container-low px-4 py-3" />
    <input name="address" required placeholder="Địa chỉ" class="rounded-2xl border-none bg-surface-container-low px-4 py-3" />
    <input name="city" required placeholder="Thành phố" class="rounded-2xl border-none bg-surface-container-low px-4 py-3" />
    <input name="district" required placeholder="Quận/Huyện" class="rounded-2xl border-none bg-surface-container-low px-4 py-3" />
    <select name="type" required class="rounded-2xl border-none bg-surface-container-low px-4 py-3">
      <option value="5-a-side">Sân 5</option>
      <option value="7-a-side">Sân 7</option>
      <option value="11-a-side">Sân 11</option>
    </select>
    <input name="pricePerSlot" type="number" min="0" required placeholder="Giá/slot" class="rounded-2xl border-none bg-surface-container-low px-4 py-3" />
  </div>

  <textarea name="description" rows="4" placeholder="Mô tả sân" class="w-full rounded-2xl border-none bg-surface-container-low px-4 py-3"></textarea>
  <input name="images" type="file" accept="image/*" multiple class="w-full rounded-2xl border-none bg-surface-container-low px-4 py-3" />

  <div class="grid grid-cols-2 md:grid-cols-3 gap-3 text-sm">
    <label class="flex items-center gap-2 rounded-xl bg-surface-container-low px-3 py-2"><input type="checkbox" name="facilities" value="night_lights" /> Night lights</label>
    <label class="flex items-center gap-2 rounded-xl bg-surface-container-low px-3 py-2"><input type="checkbox" name="facilities" value="spectator_stands" /> Stands</label>
    <label class="flex items-center gap-2 rounded-xl bg-surface-container-low px-3 py-2"><input type="checkbox" name="facilities" value="restrooms" /> Restrooms</label>
    <label class="flex items-center gap-2 rounded-xl bg-surface-container-low px-3 py-2"><input type="checkbox" name="facilities" value="showers" /> Showers</label>
    <label class="flex items-center gap-2 rounded-xl bg-surface-container-low px-3 py-2"><input type="checkbox" name="facilities" value="lounge_ac" /> Lounge AC</label>
    <label class="flex items-center gap-2 rounded-xl bg-surface-container-low px-3 py-2"><input type="checkbox" name="facilities" value="free_wifi" /> Wifi</label>
  </div>

  <div class="flex gap-3">
    <button type="submit" class="rounded-full bg-gradient-to-r from-primary to-primary-container text-white px-7 py-3 text-sm font-semibold shadow-cta hover:-translate-y-1 transition-all duration-300">Gửi admin duyệt</button>
    <a href="/owner/fields" class="rounded-full bg-surface-container-low px-6 py-3 text-sm font-semibold text-on-surface hover:bg-surface-container">Quay lại</a>
  </div>
</form>
