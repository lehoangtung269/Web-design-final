<div class="max-w-4xl space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-on-surface">Thêm sân mới</h1>
    <a href="/owner/fields" class="px-4 py-2 rounded-lg bg-surface-container-low text-on-surface-variant hover:text-on-surface">Quay lại</a>
  </div>

  <form action="/owner/fields" method="POST" enctype="multipart/form-data" class="bg-white rounded-xl p-6 space-y-5 shadow-sm">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <input name="name" required placeholder="Tên sân" class="rounded-lg border border-outline-variant px-4 py-3" />
      <input name="address" required placeholder="Địa chỉ" class="rounded-lg border border-outline-variant px-4 py-3" />
      <input name="city" required placeholder="Thành phố" class="rounded-lg border border-outline-variant px-4 py-3" />
      <input name="district" required placeholder="Quận/Huyện" class="rounded-lg border border-outline-variant px-4 py-3" />
      <select name="type" required class="rounded-lg border border-outline-variant px-4 py-3">
        <option value="5-a-side">Sân 5</option>
        <option value="7-a-side">Sân 7</option>
        <option value="11-a-side">Sân 11</option>
      </select>
      <input name="pricePerSlot" type="number" min="0" required placeholder="Giá/slot" class="rounded-lg border border-outline-variant px-4 py-3" />
    </div>

    <textarea name="description" rows="4" placeholder="Mô tả sân" class="w-full rounded-lg border border-outline-variant px-4 py-3"></textarea>
    <input name="images" type="file" accept="image/*" multiple class="w-full rounded-lg border border-outline-variant px-4 py-3" />

    <div class="grid grid-cols-2 md:grid-cols-3 gap-3 text-sm">
      <label class="flex items-center gap-2"><input type="checkbox" name="facilities" value="night_lights" /> Night lights</label>
      <label class="flex items-center gap-2"><input type="checkbox" name="facilities" value="spectator_stands" /> Stands</label>
      <label class="flex items-center gap-2"><input type="checkbox" name="facilities" value="restrooms" /> Restrooms</label>
      <label class="flex items-center gap-2"><input type="checkbox" name="facilities" value="showers" /> Showers</label>
      <label class="flex items-center gap-2"><input type="checkbox" name="facilities" value="lounge_ac" /> Lounge AC</label>
      <label class="flex items-center gap-2"><input type="checkbox" name="facilities" value="free_wifi" /> Wifi</label>
    </div>

    <button type="submit" class="px-6 py-3 rounded-lg bg-primary text-white font-semibold">Lưu sân</button>
  </form>
</div>
