<section class="rounded-2xl bg-surface-container-low p-6 md:p-10 mb-8 shadow-ambient">
  <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <p class="kinetic-label text-on-surface-variant mb-2">Owner notifications</p>
      <h2 class="kinetic-display text-5xl md:text-6xl">ADMIN</h2>
      <h2 class="kinetic-display -mt-2 text-5xl md:text-6xl text-primary">NOTICES</h2>
      <p class="mt-3 max-w-2xl text-on-surface-variant">
        Những sân bị admin từ chối sẽ chỉ xuất hiện tại đây, kèm ghi chú để bạn chỉnh sửa và gửi lại.
      </p>
    </div>
    <a href="/owner/fields" class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-on-surface shadow-ambient hover:-translate-y-1 transition-all duration-300">
      Xem sân đang hoạt động
    </a>
  </div>
</section>

<section>
  <% if (notifications && notifications.length > 0) { %>
    <div class="space-y-4">
      <% notifications.forEach((field) => { %>
        <article class="rounded-2xl bg-white p-6 md:p-7 shadow-ambient">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div class="min-w-0">
              <p class="kinetic-label text-on-surface-variant mb-2">Thông báo từ admin</p>
              <h3 class="kinetic-headline text-3xl text-on-surface"><%= field.name %></h3>
              <p class="mt-2 text-sm text-on-surface-variant"><%= [field.district, field.city].filter(Boolean).join(' - ') %></p>
              <p class="mt-2 text-sm text-on-surface-variant"><%= field.address %></p>
            </div>
            <div class="flex flex-col items-start gap-2 lg:items-end">
              <span class="rounded-full bg-red-50 px-4 py-2 text-xs font-semibold text-error">REJECTED</span>
              <span class="text-sm text-on-surface-variant">
                <%= new Date(field.approvedAt || field.updatedAt).toLocaleString('vi-VN') %>
              </span>
            </div>
          </div>

          <div class="mt-5 rounded-3xl bg-red-50 px-5 py-4 text-sm text-error">
            <span class="font-semibold">Lý do:</span>
            <%= field.approvalNote || 'Admin từ chối hồ sơ sân. Bạn cần cập nhật lại thông tin và gửi lại.' %>
          </div>

          <div class="mt-5 flex flex-wrap items-center gap-3">
            <a href="/owner/fields/<%= field._id %>/edit" class="rounded-full bg-gradient-to-r from-primary to-primary-container px-5 py-2.5 text-sm font-semibold text-white shadow-cta hover:-translate-y-0.5 transition-all duration-300">
              Chỉnh sửa và gửi lại
            </a>
            <span class="text-sm text-on-surface-variant">Sau khi bạn cập nhật và lưu lại, thông báo này sẽ biến mất khỏi mục này.</span>
          </div>
        </article>
      <% }) %>
    </div>
  <% } else { %>
    <div class="rounded-2xl bg-white p-12 text-center text-on-surface-variant shadow-ambient">
      Hiện không có thông báo nào từ admin.
    </div>
  <% } %>
</section>
