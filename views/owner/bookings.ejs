<section class="rounded-2xl bg-surface-container-low p-6 md:p-10 mb-8 shadow-ambient">
  <p class="kinetic-label text-on-surface-variant mb-3">Booking operations</p>
  <h2 class="kinetic-display text-5xl md:text-6xl leading-none">BOOKING</h2>
  <h2 class="kinetic-display text-5xl md:text-6xl text-primary leading-none -mt-2">CONTROL</h2>
</section>

<section class="space-y-3">
  <% if (bookings && bookings.length > 0) { %>
    <% bookings.forEach((booking) => { %>
      <article class="rounded-3xl bg-white p-5 md:p-6 shadow-ambient">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
          <div class="min-w-0">
            <p class="kinetic-label text-on-surface-variant mb-1">#<%= booking._id.toString().slice(-6).toUpperCase() %></p>
            <h3 class="kinetic-headline text-3xl text-on-surface"><%= booking.field ? booking.field.name : 'N/A' %></h3>
            <p class="text-sm text-on-surface-variant mt-1"><%= new Date(booking.date).toLocaleDateString('vi-VN') %> - <%= booking.startTime %> - <%= booking.endTime %></p>
            <p class="text-sm text-on-surface mt-2"><%= booking.user ? booking.user.name : '' %> <span class="text-on-surface-variant">(<%= booking.user ? booking.user.phone : '' %>)</span></p>
          </div>

          <div class="flex flex-col md:items-end gap-2">
            <% if (booking.status === 'confirmed') { %>
              <span class="rounded-full px-3 py-1 text-xs font-semibold bg-secondary-container text-secondary">CONFIRMED</span>
            <% } else if (booking.status === 'pending') { %>
              <span class="rounded-full px-3 py-1 text-xs font-semibold bg-primary/10 text-primary">PENDING</span>
            <% } else if (booking.status === 'cancelled') { %>
              <span class="rounded-full px-3 py-1 text-xs font-semibold bg-surface-container text-on-surface-variant">CANCELLED</span>
            <% } else { %>
              <span class="rounded-full px-3 py-1 text-xs font-semibold bg-red-50 text-error">REJECTED</span>
            <% } %>
            <% if (booking.paymentImage) { %>
              <a href="<%= booking.paymentImage %>" target="_blank" class="text-sm font-semibold text-primary hover:underline">Xem bill chuyển khoản</a>
            <% } %>
          </div>
        </div>

        <% if (booking.rejectedReason) { %>
          <div class="mt-4 rounded-2xl bg-red-50 px-4 py-3 text-sm text-error">
            Lý do từ chối: <span class="font-medium"><%= booking.rejectedReason %></span>
          </div>
        <% } %>

        <div class="mt-4 flex flex-wrap items-center gap-3">
          <a href="/owner/bookings/<%= booking._id %>" class="rounded-full bg-gradient-to-r from-primary to-primary-container text-white px-5 py-2 text-sm font-semibold shadow-cta hover:-translate-y-0.5 transition-all duration-300">
            <%= booking.status === 'pending' ? 'Xem chi tiết để xử lý' : 'Xem chi tiết' %>
          </a>
          <% if (booking.status === 'pending') { %>
            <span class="text-sm text-on-surface-variant">Duyệt hoặc từ chối ngay trong màn chi tiết, không còn popup xác nhận.</span>
          <% } %>
        </div>
      </article>
    <% }) %>
  <% } else { %>
    <div class="rounded-2xl bg-white p-12 text-center shadow-ambient">
      <div class="w-20 h-20 bg-surface-container-low rounded-full flex items-center justify-center mx-auto mb-6">
        <span class="material-symbols-outlined text-4xl text-on-surface-variant">confirmation_number</span>
      </div>
      <h3 class="kinetic-headline text-2xl text-on-surface mb-2">CHƯA CÓ ĐƠN NÀO</h3>
      <p class="text-on-surface-variant font-light mb-6">Khi khách hàng đặt sân của bạn, đơn sẽ xuất hiện tại đây.</p>
      <a href="/owner/fields" class="inline-flex items-center gap-2 bg-primary text-white px-8 py-3 rounded-full font-bold text-xs font-['Space_Grotesk'] uppercase tracking-widest hover:shadow-cta transition-all">
        <span class="material-symbols-outlined text-[16px]">stadium</span>
        QUẢN LÝ SÂN
      </a>
    </div>
  <% } %>
</section>
