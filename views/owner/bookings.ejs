<div class="space-y-6">
    <div class="flex justify-between items-center">
        <h1 class="text-2xl font-bold tracking-tight text-on-surface">Danh sách Đơn đặt sân</h1>
    </div>

    <div class="bg-surface-container rounded-xl overflow-hidden shadow-lg border border-transparent">
        <% if (bookings && bookings.length> 0) { %>
            <div class="overflow-x-auto w-full">
                <table class="w-full text-left border-collapse whitespace-nowrap">
                    <thead>
                        <tr class="bg-surface-container-low/50">
                            <th
                                class="px-6 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">
                                ID</th>
                            <th
                                class="px-6 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">
                                Ngày đặt</th>
                            <th
                                class="px-6 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">
                                Sân</th>
                            <th
                                class="px-6 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">
                                Ca đá</th>
                            <th
                                class="px-6 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">
                                Khách Hàng</th>
                            <th
                                class="px-6 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">
                                Bill CK</th>
                            <th
                                class="px-6 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">
                                Trạng Thái</th>
                            <th
                                class="px-6 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">
                                Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-[#1C2025]">
                        <% bookings.forEach(booking=> { %>
                            <tr class="hover:bg-surface-container-high transition-colors group">
                                <td class="px-6 py-4 text-sm font-mono text-on-surface-variant">#<%=
                                        booking._id.toString().substring(booking._id.toString().length -
                                        6).toUpperCase() %>
                                </td>
                                <td class="px-6 py-4 text-sm text-on-surface">
                                    <%= new Date(booking.date).toLocaleDateString('vi-VN') %>
                                </td>
                                <td class="px-6 py-4 text-sm font-bold text-primary">
                                    <%= booking.field ? booking.field.name : 'N/A' %>
                                </td>
                                <td class="px-6 py-4 text-sm text-on-surface-variant">
                                    <%= booking.startTime %> - <%= booking.endTime %>
                                </td>
                                <td class="px-6 py-4 text-sm text-on-surface">
                                    <div class="font-medium">
                                        <%= booking.user ? booking.user.name : '' %>
                                    </div>
                                    <div class="text-[10px] text-on-surface-variant">
                                        <%= booking.user ? booking.user.phone : '' %>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-sm">
                                    <% if (booking.paymentImage) { %>
                                        <a href="<%= booking.paymentImage %>" target="_blank"
                                            class="text-blue-400 hover:text-blue-300 underline font-semibold flex items-center gap-1">
                                            <span class="material-symbols-outlined text-sm">image</span> Xem Bill
                                        </a>
                                        <% } else { %>
                                            <span class="text-on-surface-variant text-xs italic">Không có Bill</span>
                                            <% } %>
                                </td>
                                <td class="px-6 py-4">
                                    <% if (booking.status==='confirmed' ) { %>
                                        <span
                                            class="px-3 py-1 rounded-full text-xs font-bold bg-primary/20 text-[#4edea3] uppercase border border-primary/30">Confirmed</span>
                                        <% } else if (booking.status==='pending' ) { %>
                                            <span
                                                class="px-3 py-1 rounded-full text-xs font-bold bg-yellow-500/20 text-yellow-400 uppercase border border-yellow-500/30">Pending</span>
                                            <% } else { %>
                                                <span
                                                    class="px-3 py-1 rounded-full text-xs font-bold bg-error/20 text-error uppercase border border-error/30">Rejected</span>
                                                <% } %>
                                </td>
                                <td class="px-6 py-4 flex gap-2">
                                    <% if (booking.status==='pending' ) { %>
                                        <form action="/owner/bookings/<%= booking._id %>/approve" method="POST"
                                            class="inline">
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                                            <button type="submit"
                                                class="p-2 rounded-lg bg-primary/80 hover:bg-primary text-[#003824] transition-all flex items-center gap-1 font-bold text-xs shadow-lg shadow-primary/20 hover:scale-105 active:scale-95"
                                                onclick="return confirm('Duyệt đơn này?')">
                                                <span class="material-symbols-outlined text-[16px]">check_circle</span>
                                                Duyệt
                                            </button>
                                        </form>
                                        <form action="/owner/bookings/<%= booking._id %>/reject" method="POST"
                                            class="inline">
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                                            <button type="submit"
                                                class="p-2 rounded-lg bg-error/80 hover:bg-error text-[#380000] transition-all flex items-center gap-1 font-bold text-xs shadow-lg shadow-error/20 hover:scale-105 active:scale-95"
                                                onclick="return confirm('Từ chối đơn này?')">
                                                <span class="material-symbols-outlined text-[16px]">cancel</span> Hủy
                                            </button>
                                        </form>
                                        <% } else { %>
                                            <span
                                                class="text-xs text-on-surface-variant italic opacity-50">Locked</span>
                                            <% } %>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>
            <% } else { %>
                <div
                    class="p-12 flex flex-col items-center justify-center text-on-surface-variant gap-4 bg-surface-container-low/30 backdrop-blur-sm">
                    <span class="material-symbols-outlined text-6xl opacity-20">inventory_2</span>
                    <p class="font-medium text-lg tracking-tight">Chưa có đơn đặt sân nào</p>
                </div>
                <% } %>
    </div>
</div>