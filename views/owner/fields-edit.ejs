<section class="rounded-[2rem] bg-surface-container-low p-6 md:p-10 mb-8 shadow-ambient">
  <p class="kinetic-label text-on-surface-variant mb-3">Pitch maintenance</p>
  <h2 class="kinetic-display text-5xl md:text-6xl">EDIT FIELD PROFILE</h2>
  <%
    const approvalStatus = field.approvalStatus || 'approved';
    const approvalText = approvalStatus === 'approved'
      ? 'Sân đã được admin duyệt và đang ở trạng thái live.'
      : approvalStatus === 'pending'
        ? 'Sân đang chờ admin duyệt. Bạn vẫn có thể chỉnh sửa trước khi được mở công khai.'
        : 'Sân đang bị từ chối. Sau khi chỉnh sửa và lưu lại, hệ thống sẽ gửi lại cho admin duyệt.';
  %>
  <p class="mt-4 text-on-surface-variant max-w-2xl"><%= approvalText %></p>
  <% if (field.approvalNote) { %>
    <div class="mt-4 inline-flex max-w-2xl rounded-2xl bg-white px-4 py-3 text-sm text-on-surface shadow-ambient">
      <span class="material-symbols-outlined mr-2 text-primary">info</span>
      <%= field.approvalNote %>
    </div>
  <% } %>
</section>

<form action="/owner/fields/<%= field._id %>" method="POST" enctype="multipart/form-data" class="max-w-5xl rounded-[2rem] bg-white p-6 md:p-8 space-y-6 shadow-ambient">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <input name="name" value="<%= field.name %>" required placeholder="Tên sân" class="rounded-2xl border-none bg-surface-container-low px-4 py-3" />
    <input name="address" value="<%= field.address %>" required placeholder="Địa chỉ" class="rounded-2xl border-none bg-surface-container-low px-4 py-3" />
    <input name="city" value="<%= field.city || '' %>" required placeholder="Thành phố" class="rounded-2xl border-none bg-surface-container-low px-4 py-3" />
    <input name="district" value="<%= field.district || '' %>" required placeholder="Quận/Huyện" class="rounded-2xl border-none bg-surface-container-low px-4 py-3" />
    <select name="type" required class="rounded-2xl border-none bg-surface-container-low px-4 py-3">
      <option value="5-a-side" <%= field.type === '5-a-side' ? 'selected' : '' %>>Sân 5</option>
      <option value="7-a-side" <%= field.type === '7-a-side' ? 'selected' : '' %>>Sân 7</option>
      <option value="11-a-side" <%= field.type === '11-a-side' ? 'selected' : '' %>>Sân 11</option>
    </select>
    <input name="pricePerSlot" type="number" min="0" value="<%= field.pricePerSlot %>" required placeholder="Giá/slot" class="rounded-2xl border-none bg-surface-container-low px-4 py-3" />
  </div>

  <select name="status" class="rounded-2xl border-none bg-surface-container-low px-4 py-3">
    <option value="active" <%= field.status === 'active' ? 'selected' : '' %>>Hoạt động</option>
    <option value="maintenance" <%= field.status === 'maintenance' ? 'selected' : '' %>>Bảo trì</option>
  </select>

  <textarea name="description" rows="4" placeholder="Mô tả sân" class="w-full rounded-2xl border-none bg-surface-container-low px-4 py-3"><%= field.description || '' %></textarea>
  <input name="images" type="file" accept="image/*" multiple class="w-full rounded-2xl border-none bg-surface-container-low px-4 py-3" />

  <div class="grid grid-cols-2 md:grid-cols-3 gap-3 text-sm">
    <label class="flex items-center gap-2 rounded-xl bg-surface-container-low px-3 py-2"><input type="checkbox" name="facilities" value="night_lights" <%= field.facilities && field.facilities.includes('night_lights') ? 'checked' : '' %> /> Night lights</label>
    <label class="flex items-center gap-2 rounded-xl bg-surface-container-low px-3 py-2"><input type="checkbox" name="facilities" value="spectator_stands" <%= field.facilities && field.facilities.includes('spectator_stands') ? 'checked' : '' %> /> Stands</label>
    <label class="flex items-center gap-2 rounded-xl bg-surface-container-low px-3 py-2"><input type="checkbox" name="facilities" value="restrooms" <%= field.facilities && field.facilities.includes('restrooms') ? 'checked' : '' %> /> Restrooms</label>
    <label class="flex items-center gap-2 rounded-xl bg-surface-container-low px-3 py-2"><input type="checkbox" name="facilities" value="showers" <%= field.facilities && field.facilities.includes('showers') ? 'checked' : '' %> /> Showers</label>
    <label class="flex items-center gap-2 rounded-xl bg-surface-container-low px-3 py-2"><input type="checkbox" name="facilities" value="lounge_ac" <%= field.facilities && field.facilities.includes('lounge_ac') ? 'checked' : '' %> /> Lounge AC</label>
    <label class="flex items-center gap-2 rounded-xl bg-surface-container-low px-3 py-2"><input type="checkbox" name="facilities" value="free_wifi" <%= field.facilities && field.facilities.includes('free_wifi') ? 'checked' : '' %> /> Wifi</label>
  </div>

  <div class="flex gap-3">
    <button type="submit" class="rounded-full bg-gradient-to-r from-primary to-primary-container text-white px-7 py-3 text-sm font-semibold shadow-cta hover:-translate-y-1 transition-all duration-300">Lưu thay đổi</button>
    <a href="/owner/fields" class="rounded-full bg-surface-container-low px-6 py-3 text-sm font-semibold text-on-surface hover:bg-surface-container">Quay lại</a>
  </div>
</form>
