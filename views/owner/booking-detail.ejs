<% if (!booking) { %>
  <div class="rounded-[2rem] bg-white p-10 text-center text-on-surface-variant shadow-ambient">
    Không tìm thấy đơn đặt sân.
  </div>
<% } else { %>
  <section class="mb-8 rounded-[2rem] bg-surface-container-low p-6 md:p-10 shadow-ambient">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="kinetic-label text-on-surface-variant mb-2">Booking detail</p>
        <h2 class="kinetic-display text-5xl md:text-6xl">BOOKING</h2>
        <h2 class="kinetic-display -mt-2 text-5xl md:text-6xl text-primary">DETAIL</h2>
        <p class="mt-3 text-on-surface-variant max-w-2xl">
          Xem đầy đủ thông tin khách, bill chuyển khoản và xử lý đơn trực tiếp tại đây.
        </p>
      </div>
      <a href="/owner/bookings" class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-on-surface shadow-ambient hover:-translate-y-1 transition-all duration-300">
        Quay lại danh sách
      </a>
    </div>
  </section>

  <section class="grid grid-cols-1 gap-6 xl:grid-cols-[1.15fr_0.85fr]">
    <div class="rounded-[2rem] bg-white p-6 md:p-8 shadow-ambient">
      <div class="mb-6 flex items-start justify-between gap-4">
        <div>
          <p class="kinetic-label text-on-surface-variant mb-2">Mã đơn</p>
          <h3 class="kinetic-headline text-3xl text-on-surface">#<%= booking._id.toString().slice(-6).toUpperCase() %></h3>
        </div>
        <% if (booking.status === 'pending') { %>
          <span class="rounded-full bg-primary/10 px-4 py-2 text-xs font-semibold text-primary">PENDING</span>
        <% } else if (booking.status === 'confirmed') { %>
          <span class="rounded-full bg-secondary-container px-4 py-2 text-xs font-semibold text-secondary">CONFIRMED</span>
        <% } else if (booking.status === 'cancelled') { %>
          <span class="rounded-full bg-surface-container px-4 py-2 text-xs font-semibold text-on-surface-variant">CANCELLED</span>
        <% } else { %>
          <span class="rounded-full bg-red-50 px-4 py-2 text-xs font-semibold text-error">REJECTED</span>
        <% } %>
      </div>

      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <div class="rounded-3xl bg-surface-container-low p-5">
          <p class="kinetic-label text-on-surface-variant mb-2">Sân bóng</p>
          <p class="text-lg font-bold text-on-surface"><%= booking.field ? booking.field.name : 'N/A' %></p>
          <p class="mt-2 text-sm text-on-surface-variant"><%= booking.field ? booking.field.address : 'N/A' %></p>
          <% if (booking.field) { %>
            <p class="mt-2 text-sm text-on-surface-variant"><%= [booking.field.district, booking.field.city].filter(Boolean).join(' - ') %></p>
          <% } %>
        </div>

        <div class="rounded-3xl bg-surface-container-low p-5">
          <p class="kinetic-label text-on-surface-variant mb-2">Lịch đặt</p>
          <p class="text-lg font-bold text-on-surface"><%= booking.date ? new Date(booking.date).toLocaleDateString('vi-VN', { weekday: 'long', day: '2-digit', month: '2-digit', year: 'numeric' }) : 'N/A' %></p>
          <p class="mt-2 text-sm text-primary font-semibold"><%= booking.startTime %> - <%= booking.endTime %></p>
          <p class="mt-2 text-sm text-on-surface-variant">Loại sân: <%= booking.field ? booking.field.type : 'N/A' %></p>
        </div>

        <div class="rounded-3xl bg-surface-container-low p-5">
          <p class="kinetic-label text-on-surface-variant mb-2">Khách đặt</p>
          <p class="text-lg font-bold text-on-surface"><%= booking.user ? booking.user.name : 'N/A' %></p>
          <p class="mt-2 text-sm text-on-surface-variant"><%= booking.user ? booking.user.email : 'N/A' %></p>
          <p class="mt-1 text-sm text-on-surface-variant"><%= booking.user ? booking.user.phone : 'N/A' %></p>
        </div>

        <div class="rounded-3xl bg-surface-container-low p-5">
          <p class="kinetic-label text-on-surface-variant mb-2">Thanh toán</p>
          <p class="text-lg font-bold text-secondary"><%= Number(booking.finalTotal || booking.totalPrice || 0).toLocaleString('vi-VN') %>đ</p>
          <% if (booking.approvedAt) { %>
            <p class="mt-2 text-sm text-on-surface-variant">Xử lý lúc: <%= new Date(booking.approvedAt).toLocaleString('vi-VN') %></p>
          <% } %>
          <% if (booking.rejectedReason) { %>
            <p class="mt-3 rounded-2xl bg-red-50 px-4 py-3 text-sm text-error">Lý do từ chối: <%= booking.rejectedReason %></p>
          <% } %>
        </div>
      </div>

      <% if (booking.status === 'pending') { %>
        <div class="mt-6 grid grid-cols-1 gap-4 lg:grid-cols-[0.8fr_1.2fr]">
          <form action="/owner/bookings/<%= booking._id %>/approve" method="POST" class="rounded-3xl bg-secondary-container p-5">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <p class="kinetic-label text-secondary mb-2">Chấp thuận đơn</p>
            <p class="text-sm text-on-surface-variant mb-4">Khung giờ sẽ được khóa cho khách này ngay sau khi duyệt.</p>
            <button type="submit" class="w-full rounded-full bg-secondary px-5 py-3 text-sm font-semibold text-white hover:opacity-90 transition-opacity">
              Duyệt đơn
            </button>
          </form>

          <form action="/owner/bookings/<%= booking._id %>/reject" method="POST" class="rounded-3xl bg-red-50 p-5">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <p class="kinetic-label text-error mb-2">Từ chối đơn</p>
            <textarea name="reason" rows="4" placeholder="Nhập lý do từ chối để khách dễ xử lý..." class="w-full rounded-2xl border-none bg-white px-4 py-3 text-sm text-on-surface focus:ring-1 focus:ring-error/40"></textarea>
            <button type="submit" class="mt-4 w-full rounded-full bg-error px-5 py-3 text-sm font-semibold text-white hover:opacity-90 transition-opacity">
              Từ chối đơn
            </button>
          </form>
        </div>
      <% } else if (booking.status === 'confirmed') { %>
        <div class="mt-6 rounded-3xl bg-secondary-container px-5 py-4 text-secondary">
          Đơn này đã được duyệt. Khung giờ tương ứng đang được giữ cho khách.
        </div>
      <% } else { %>
        <div class="mt-6 rounded-3xl bg-red-50 px-5 py-4 text-error">
          Đơn này đã bị từ chối.
        </div>
      <% } %>
    </div>

    <div class="space-y-6">
      <div class="rounded-[2rem] bg-white p-6 md:p-8 shadow-ambient">
        <div class="flex items-center justify-between gap-3">
          <div>
            <p class="kinetic-label text-on-surface-variant mb-2">Bill chuyển khoản</p>
            <h3 class="kinetic-headline text-3xl text-on-surface">PAYMENT PROOF</h3>
          </div>
          <% if (booking.paymentImage) { %>
            <a href="<%= booking.paymentImage %>" target="_blank" class="text-sm font-semibold text-primary hover:underline">Mở ảnh gốc</a>
          <% } %>
        </div>

        <% if (booking.paymentImage) { %>
          <img src="<%= booking.paymentImage %>" alt="Bill chuyển khoản" class="mt-5 w-full rounded-3xl border border-outline-variant/30 object-cover shadow-ambient" />
        <% } else { %>
          <div class="mt-5 rounded-3xl bg-surface-container-low p-10 text-center text-on-surface-variant">
            Khách chưa tải lên bill chuyển khoản.
          </div>
        <% } %>
      </div>

      <div class="rounded-[2rem] bg-white p-6 md:p-8 shadow-ambient">
        <p class="kinetic-label text-on-surface-variant mb-2">Tóm tắt nhanh</p>
        <h3 class="kinetic-headline text-3xl text-on-surface mb-4">OPS SNAPSHOT</h3>
        <div class="space-y-3 text-sm text-on-surface-variant">
          <div class="rounded-2xl bg-surface-container-low px-4 py-3">
            Giá niêm yết sân: <span class="font-semibold text-on-surface"><%= booking.field && booking.field.pricePerSlot ? Number(booking.field.pricePerSlot).toLocaleString('vi-VN') + 'đ' : 'N/A' %></span>
          </div>
          <div class="rounded-2xl bg-surface-container-low px-4 py-3">
            Tổng thanh toán đơn: <span class="font-semibold text-on-surface"><%= Number(booking.finalTotal || booking.totalPrice || 0).toLocaleString('vi-VN') %>đ</span>
          </div>
          <div class="rounded-2xl bg-surface-container-low px-4 py-3">
            Trạng thái hiện tại: <span class="font-semibold text-on-surface"><%= booking.status %></span>
          </div>
        </div>
      </div>
    </div>
  </section>
<% } %>
