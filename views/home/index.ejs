        <hr class="mt-4 border-gray-100">
      </div>
    </div>

    <!-- Arena Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      
      <!-- Card 1 -->
      <a href="/fields" class="group block h-[550px] relative overflow-hidden rounded-[2rem] transform hover:-translate-y-2 transition-all duration-700 shadow-sm hover:shadow-2xl">
