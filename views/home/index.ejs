<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | ĐặtSân.vn</title>
  <meta name="description" content="Hệ thống đặt sân bóng đá online nhanh chóng, tiện lợi. Tìm sân, chọn giờ, đặt ngay!" />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <style>
    :root {
      --green: #22c55e;
      --green-dark: #16a34a;
      --green-light: #dcfce7;
      --blue: #38bdf8;
      --blue-dark: #0ea5e9;
      --blue-light: #e0f2fe;
      --orange: #f97316;
      --orange-light: #fff7ed;
      --bg: #f8fafc;
      --white: #ffffff;
      --dark: #0f172a;
      --gray-900: #1e293b;
      --gray-700: #334155;
      --gray-500: #64748b;
      --gray-300: #cbd5e1;
      --gray-100: #f1f5f9;
      --shadow: 0 4px 20px rgba(0,0,0,0.06);
      --shadow-lg: 0 10px 40px rgba(0,0,0,0.1);
      --radius: 16px;
      --radius-sm: 10px;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Poppins', sans-serif;
      background: var(--bg);
      color: var(--gray-700);
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ===== ANIMATIONS ===== */
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes slideInRight {
      from { opacity: 0; transform: translateX(30px); }
      to { opacity: 1; transform: translateX(0); }
    }
    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.05); }
    }
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }
    @keyframes gradientMove {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }
    .animate-fade { animation: fadeInUp 0.6s ease-out both; }
    .animate-delay-1 { animation-delay: 0.1s; }
    .animate-delay-2 { animation-delay: 0.2s; }
    .animate-delay-3 { animation-delay: 0.3s; }
    .animate-delay-4 { animation-delay: 0.4s; }

    /* ===== NAVBAR ===== */
    .navbar {
      background: var(--white);
      box-shadow: 0 2px 20px rgba(0,0,0,0.05);
      padding: 0 2rem;
      height: 70px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 1000;
      transition: box-shadow 0.3s;
    }
    .navbar.scrolled { box-shadow: 0 4px 30px rgba(0,0,0,0.1); }
    .navbar-brand {
      font-size: 1.5rem;
      font-weight: 800;
      color: var(--green);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.6rem;
      transition: transform 0.2s;
    }
    .navbar-brand:hover { transform: scale(1.03); }
    .navbar-brand i {
      font-size: 1.4rem;
      background: linear-gradient(135deg, var(--green), var(--blue));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .navbar-links {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .navbar-links a {
      color: var(--gray-700);
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      padding: 0.5rem 1rem;
      border-radius: 8px;
      transition: all 0.2s;
    }
    .navbar-links a:hover {
      color: var(--green);
      background: var(--green-light);
    }
    .btn-nav {
      padding: 0.55rem 1.3rem !important;
      border-radius: 10px !important;
      font-weight: 600 !important;
      font-size: 0.85rem !important;
      text-decoration: none;
      transition: all 0.25s !important;
    }
    .btn-login {
      color: var(--green) !important;
      border: 2px solid var(--green);
      background: transparent;
    }
    .btn-login:hover {
      background: var(--green) !important;
      color: var(--white) !important;
      transform: translateY(-2px);
    }
    .btn-register {
      background: linear-gradient(135deg, var(--green), var(--green-dark)) !important;
      color: var(--white) !important;
      border: none;
      box-shadow: 0 4px 15px rgba(34, 197, 94, 0.3);
    }
    .btn-register:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 25px rgba(34, 197, 94, 0.4);
    }
    .user-greeting {
      color: var(--gray-500);
      font-size: 0.85rem;
      padding: 0.5rem 0;
    }
    .user-greeting strong { color: var(--gray-900); }

    /* ===== FLASH MESSAGES ===== */
    .flash-container { padding: 0 2rem; max-width: 1200px; margin: 1rem auto 0; }
    .flash-msg {
      padding: 0.85rem 1.2rem;
      border-radius: var(--radius-sm);
      margin-bottom: 0.5rem;
      font-size: 0.9rem;
      display: flex;
      align-items: center;
      gap: 0.6rem;
      animation: fadeInUp 0.4s ease-out;
    }
    .flash-success { background: var(--green-light); border-left: 4px solid var(--green); color: var(--green-dark); }
    .flash-error { background: #fef2f2; border-left: 4px solid #ef4444; color: #dc2626; }

    /* ===== HERO ===== */
    .hero {
      position: relative;
      padding: 4rem 2rem 3rem;
      overflow: hidden;
      background: linear-gradient(135deg, #ecfdf5 0%, #e0f2fe 50%, #fff7ed 100%);
      background-size: 200% 200%;
      animation: gradientMove 8s ease infinite;
    }
    .hero-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: center;
    }
    .hero-text { animation: fadeInUp 0.8s ease-out; }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.4rem 1rem;
      background: var(--white);
      border-radius: 50px;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--green);
      box-shadow: var(--shadow);
      margin-bottom: 1.2rem;
    }
    .hero-badge i { color: var(--orange); }
    .hero h1 {
      font-size: 3.2rem;
      font-weight: 800;
      color: var(--dark);
      line-height: 1.15;
      margin-bottom: 1rem;
    }
    .hero h1 .highlight {
      background: linear-gradient(135deg, var(--green), var(--blue));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero p {
      font-size: 1.05rem;
      color: var(--gray-500);
      line-height: 1.7;
      margin-bottom: 2rem;
      max-width: 500px;
    }
    .hero-cta {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .btn-primary {
      padding: 0.85rem 2rem;
      background: linear-gradient(135deg, var(--green), var(--green-dark));
      color: var(--white);
      border: none;
      border-radius: var(--radius-sm);
      font-family: 'Poppins', sans-serif;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      transition: all 0.3s;
      box-shadow: 0 4px 15px rgba(34, 197, 94, 0.3);
    }
    .btn-primary:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 30px rgba(34, 197, 94, 0.4);
    }
    .btn-secondary {
      padding: 0.85rem 2rem;
      background: var(--white);
      color: var(--gray-700);
      border: 2px solid var(--gray-300);
      border-radius: var(--radius-sm);
      font-family: 'Poppins', sans-serif;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      transition: all 0.3s;
    }
    .btn-secondary:hover {
      border-color: var(--green);
      color: var(--green);
      transform: translateY(-2px);
    }
    .hero-visual {
      display: flex;
      align-items: center;
      justify-content: center;
      animation: fadeInUp 1s ease-out 0.3s both;
    }
    .hero-emoji {
      font-size: 12rem;
      animation: float 3s ease-in-out infinite;
      filter: drop-shadow(0 20px 40px rgba(0,0,0,0.1));
    }
    .hero-stats {
      display: flex;
      gap: 2rem;
      margin-top: 2rem;
    }
    .stat-item {
      text-align: center;
    }
    .stat-number {
      font-size: 1.5rem;
      font-weight: 800;
      color: var(--dark);
    }
    .stat-label {
      font-size: 0.75rem;
      color: var(--gray-500);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    /* ===== SEARCH BOX ===== */
    .search-section {
      max-width: 1000px;
      margin: -2rem auto 0;
      padding: 0 2rem;
      position: relative;
      z-index: 10;
    }
    .search-box {
      background: var(--white);
      border-radius: var(--radius);
      padding: 1.5rem 2rem;
      box-shadow: var(--shadow-lg);
      border: 1px solid rgba(0,0,0,0.04);
    }
    .search-form {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr auto;
      gap: 1rem;
      align-items: end;
    }
    .form-group { text-align: left; }
    .form-group label {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--gray-500);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.5rem;
    }
    .form-group label i { color: var(--green); font-size: 0.85rem; }
    .form-group input,
    .form-group select {
      width: 100%;
      padding: 0.75rem 1rem;
      background: var(--gray-100);
      border: 2px solid transparent;
      border-radius: var(--radius-sm);
      color: var(--gray-900);
      font-family: 'Poppins', sans-serif;
      font-size: 0.9rem;
      transition: all 0.25s;
    }
    .form-group input:focus,
    .form-group select:focus {
      outline: none;
      border-color: var(--green);
      background: var(--white);
      box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.1);
    }
    .btn-search {
      padding: 0.75rem 2rem;
      background: linear-gradient(135deg, var(--green), var(--green-dark));
      color: var(--white);
      border: none;
      border-radius: var(--radius-sm);
      font-family: 'Poppins', sans-serif;
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      white-space: nowrap;
      box-shadow: 0 4px 15px rgba(34, 197, 94, 0.25);
    }
    .btn-search:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 25px rgba(34, 197, 94, 0.35);
    }
    .btn-search:active { transform: scale(0.97); }

    /* ===== SECTION ===== */
    .section {
      max-width: 1200px;
      margin: 0 auto;
      padding: 3.5rem 2rem;
    }
    .section-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 2rem;
    }
    .section-title {
      font-size: 1.6rem;
      font-weight: 700;
      color: var(--dark);
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }
    .section-title .icon-circle {
      width: 40px;
      height: 40px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
    }
    .icon-green { background: var(--green-light); color: var(--green); }
    .icon-blue { background: var(--blue-light); color: var(--blue-dark); }
    .icon-orange { background: var(--orange-light); color: var(--orange); }
    .section-link {
      color: var(--green);
      text-decoration: none;
      font-weight: 600;
      font-size: 0.9rem;
      display: flex;
      align-items: center;
      gap: 0.3rem;
      transition: all 0.2s;
      padding: 0.5rem 1rem;
      border-radius: 8px;
    }
    .section-link:hover {
      background: var(--green-light);
      gap: 0.6rem;
    }

    /* ===== FIELD CARDS GRID ===== */
    .fields-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
      gap: 1.5rem;
    }
    .field-card {
      background: var(--white);
      border: 1px solid rgba(0,0,0,0.05);
      border-radius: var(--radius);
      overflow: hidden;
      transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
      text-decoration: none;
      color: inherit;
      display: block;
      box-shadow: var(--shadow);
    }
    .field-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 20px 50px rgba(0,0,0,0.12);
    }
    .field-card-img-wrap {
      position: relative;
      overflow: hidden;
    }
    .field-card-img {
      width: 100%;
      height: 210px;
      object-fit: cover;
      transition: transform 0.4s;
    }
    .field-card:hover .field-card-img { transform: scale(1.05); }
    .field-card-img-placeholder {
      width: 100%;
      height: 210px;
      background: linear-gradient(135deg, var(--green-light), var(--blue-light));
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--green);
      font-size: 3.5rem;
    }
    .card-badge-top {
      position: absolute;
      top: 12px;
      left: 12px;
      padding: 0.3rem 0.8rem;
      border-radius: 50px;
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      backdrop-filter: blur(8px);
    }
    .badge-5 { background: rgba(34, 197, 94, 0.9); color: white; }
    .badge-7 { background: rgba(56, 189, 248, 0.9); color: white; }
    .badge-11 { background: rgba(249, 115, 22, 0.9); color: white; }

    .field-card-body { padding: 1.3rem; }
    .field-card-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--dark);
      margin-bottom: 0.4rem;
    }
    .field-card-address {
      font-size: 0.82rem;
      color: var(--gray-500);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }
    .field-card-address i { color: var(--orange); font-size: 0.75rem; }
    .field-card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 1rem;
      border-top: 1px solid var(--gray-100);
    }
    .field-price {
      font-size: 1.15rem;
      font-weight: 800;
      color: var(--green);
    }
    .field-price span {
      font-size: 0.75rem;
      font-weight: 400;
      color: var(--gray-500);
    }
    .card-book-hint {
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--blue-dark);
      display: flex;
      align-items: center;
      gap: 0.3rem;
      transition: gap 0.2s;
    }
    .field-card:hover .card-book-hint { gap: 0.6rem; color: var(--green); }

    /* ===== FEATURES STRIP ===== */
    .features-strip {
      background: var(--white);
      border-top: 1px solid var(--gray-100);
      border-bottom: 1px solid var(--gray-100);
      padding: 2.5rem 2rem;
    }
    .features-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 2rem;
    }
    .feature-item {
      text-align: center;
      padding: 1rem;
      transition: transform 0.3s;
    }
    .feature-item:hover { transform: translateY(-4px); }
    .feature-icon {
      width: 56px;
      height: 56px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.3rem;
      margin: 0 auto 0.8rem;
    }
    .feature-title {
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--dark);
      margin-bottom: 0.3rem;
    }
    .feature-desc {
      font-size: 0.8rem;
      color: var(--gray-500);
      line-height: 1.5;
    }

    /* ===== EMPTY STATE ===== */
    .empty-state {
      text-align: center;
      padding: 4rem 2rem;
      color: var(--gray-500);
    }
    .empty-state i {
      font-size: 3.5rem;
      margin-bottom: 1rem;
      color: var(--gray-300);
    }
    .empty-state p {
      font-size: 1.05rem;
      margin-bottom: 0.5rem;
    }
    .empty-state a {
      color: var(--green);
      text-decoration: none;
      font-weight: 600;
    }

    /* ===== FOOTER ===== */
    .footer {
      background: var(--dark);
      color: var(--gray-300);
      padding: 3rem 2rem 2rem;
    }
    .footer-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 2rem;
    }
    .footer-brand {
      font-size: 1.3rem;
      font-weight: 800;
      color: var(--green);
      margin-bottom: 0.8rem;
    }
    .footer-desc {
      font-size: 0.85rem;
      line-height: 1.6;
      color: var(--gray-500);
    }
    .footer-title {
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--white);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 1rem;
    }
    .footer-links { list-style: none; }
    .footer-links li { margin-bottom: 0.5rem; }
    .footer-links a {
      color: var(--gray-500);
      text-decoration: none;
      font-size: 0.85rem;
      transition: color 0.2s;
    }
    .footer-links a:hover { color: var(--green); }
    .footer-bottom {
      max-width: 1200px;
      margin: 2rem auto 0;
      padding-top: 1.5rem;
      border-top: 1px solid rgba(255,255,255,0.08);
      text-align: center;
      font-size: 0.8rem;
      color: var(--gray-500);
    }

    /* ===== MOBILE MENU ===== */
    .mobile-toggle {
      display: none;
      background: none;
      border: none;
      font-size: 1.5rem;
      color: var(--gray-700);
      cursor: pointer;
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 900px) {
      .hero-inner { grid-template-columns: 1fr; text-align: center; }
      .hero p { max-width: 100%; margin-left: auto; margin-right: auto; }
      .hero-cta { justify-content: center; }
      .hero-stats { justify-content: center; }
      .hero-visual { display: none; }
      .search-form { grid-template-columns: 1fr; }
      .features-inner { grid-template-columns: repeat(2, 1fr); }
      .footer-inner { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 600px) {
      .hero h1 { font-size: 2.2rem; }
      .fields-grid { grid-template-columns: 1fr; }
      .features-inner { grid-template-columns: 1fr; }
      .footer-inner { grid-template-columns: 1fr; }
      .navbar-links { display: none; }
      .mobile-toggle { display: block; }
      .navbar-links.open {
        display: flex;
        flex-direction: column;
        position: absolute;
        top: 70px;
        left: 0;
        right: 0;
        background: var(--white);
        padding: 1rem 2rem;
        box-shadow: var(--shadow-lg);
      }
    }
  </style>
</head>
<body>

  <!-- NAVBAR -->
  <nav class="navbar" id="navbar">
    <a href="/" class="navbar-brand">
      <i class="fas fa-futbol"></i> ĐặtSân.vn
    </a>
    <button class="mobile-toggle" onclick="document.querySelector('.navbar-links').classList.toggle('open')">
      <i class="fas fa-bars"></i>
    </button>
    <div class="navbar-links" id="nav-links">
      <a href="/">Trang chủ</a>
      <a href="/fields">Sân bóng</a>
      <% if (typeof currentUser !== 'undefined' && currentUser) { %>
        <a href="/history">Lịch sử</a>
        <span class="user-greeting">Xin chào, <strong><%= currentUser.name %></strong></span>
        <a href="/auth/logout" class="btn-nav btn-login">Đăng xuất</a>
      <% } else { %>
        <a href="/auth/login" class="btn-nav btn-login">Đăng nhập</a>
        <a href="/auth/register" class="btn-nav btn-register">Đăng ký</a>
      <% } %>
    </div>
  </nav>

  <!-- FLASH MESSAGES -->
  <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
    <div class="flash-container">
      <% success.forEach(msg => { %>
        <div class="flash-msg flash-success"><i class="fas fa-check-circle"></i> <%= msg %></div>
      <% }); %>
    </div>
  <% } %>
  <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <div class="flash-container">
      <% error.forEach(msg => { %>
        <div class="flash-msg flash-error"><i class="fas fa-exclamation-triangle"></i> <%= msg %></div>
      <% }); %>
    </div>
  <% } %>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <div class="hero-badge"><i class="fas fa-bolt"></i> Đặt sân siêu nhanh</div>
        <h1>Đặt sân bóng đá<br/><span class="highlight">nhanh chóng & dễ dàng</span></h1>
        <p>Tìm sân phù hợp, chọn khung giờ yêu thích và đặt chỗ chỉ trong vài bước. Không cần gọi điện, không cần chờ đợi!</p>
        <div class="hero-cta">
          <a href="/fields" class="btn-primary"><i class="fas fa-search"></i> Tìm sân ngay</a>
          <a href="#how-it-works" class="btn-secondary"><i class="fas fa-play-circle"></i> Cách đặt sân</a>
        </div>
        <div class="hero-stats">
          <div class="stat-item">
            <div class="stat-number" style="color:var(--green);">50+</div>
            <div class="stat-label">Sân bóng</div>
          </div>
          <div class="stat-item">
            <div class="stat-number" style="color:var(--blue);">1000+</div>
            <div class="stat-label">Lượt đặt</div>
          </div>
          <div class="stat-item">
            <div class="stat-number" style="color:var(--orange);">4.9★</div>
            <div class="stat-label">Đánh giá</div>
          </div>
        </div>
      </div>
      <div class="hero-visual">
        <span class="hero-emoji">⚽</span>
      </div>
    </div>
  </section>

  <!-- SEARCH BOX -->
  <div class="search-section animate-fade">
    <div class="search-box">
      <form class="search-form" action="/search" method="GET">
        <div class="form-group">
          <label for="search-date"><i class="fas fa-calendar-alt"></i> Ngày đá</label>
          <input type="date" id="search-date" name="date" value="<%= new Date().toISOString().split('T')[0] %>" />
        </div>
        <div class="form-group">
          <label for="search-time"><i class="fas fa-clock"></i> Khung giờ</label>
          <select id="search-time" name="time">
            <option value="">Tất cả giờ</option>
            <option value="06:00">06:00 - 07:30</option>
            <option value="07:30">07:30 - 09:00</option>
            <option value="09:00">09:00 - 10:30</option>
            <option value="10:30">10:30 - 12:00</option>
            <option value="12:00">12:00 - 13:30</option>
            <option value="13:30">13:30 - 15:00</option>
            <option value="15:00">15:00 - 16:30</option>
            <option value="16:30">16:30 - 18:00</option>
            <option value="18:00">18:00 - 19:30</option>
            <option value="19:30">19:30 - 21:00</option>
            <option value="21:00">21:00 - 22:30</option>
          </select>
        </div>
        <div class="form-group">
          <label for="search-type"><i class="fas fa-users"></i> Loại sân</label>
          <select id="search-type" name="type">
            <option value="all">Tất cả loại sân</option>
            <option value="5-a-side">Sân 5 người</option>
            <option value="7-a-side">Sân 7 người</option>
            <option value="11-a-side">Sân 11 người</option>
          </select>
        </div>
        <button type="submit" class="btn-search"><i class="fas fa-search"></i> Tìm sân</button>
      </form>
    </div>
  </div>

  <!-- FEATURED FIELDS -->
  <section class="section">
    <div class="section-header">
      <h2 class="section-title">
        <span class="icon-circle icon-orange"><i class="fas fa-fire"></i></span>
        Sân nổi bật
      </h2>
      <a href="/fields" class="section-link">Xem tất cả <i class="fas fa-arrow-right"></i></a>
    </div>

    <% if (featuredFields && featuredFields.length > 0) { %>
      <div class="fields-grid">
        <% featuredFields.forEach((field, idx) => { %>
          <a href="/fields/<%= field._id %>" class="field-card animate-fade animate-delay-<%= Math.min(idx + 1, 4) %>">
            <div class="field-card-img-wrap">
              <% if (field.images && field.images.length > 0) { %>
                <img src="<%= field.images[0] %>" alt="<%= field.name %>" class="field-card-img" />
              <% } else { %>
                <div class="field-card-img-placeholder"><i class="fas fa-futbol"></i></div>
              <% } %>
              <span class="card-badge-top <%= field.type === '5-a-side' ? 'badge-5' : field.type === '7-a-side' ? 'badge-7' : 'badge-11' %>">
                <i class="fas fa-users"></i>
                <%= field.type === '5-a-side' ? 'Sân 5' : field.type === '7-a-side' ? 'Sân 7' : 'Sân 11' %>
              </span>
            </div>
            <div class="field-card-body">
              <h3 class="field-card-title"><%= field.name %></h3>
              <p class="field-card-address"><i class="fas fa-map-marker-alt"></i> <%= field.address %></p>
              <div class="field-card-footer">
                <span class="field-price"><%= field.pricePerSlot.toLocaleString('vi-VN') %>đ <span>/ slot</span></span>
                <span class="card-book-hint">Đặt ngay <i class="fas fa-arrow-right"></i></span>
              </div>
            </div>
          </a>
        <% }); %>
      </div>
    <% } else { %>
      <div class="empty-state">
        <i class="fas fa-futbol"></i>
        <p>Chưa có sân nào. Vui lòng quay lại sau!</p>
      </div>
    <% } %>
  </section>

  <!-- FEATURES STRIP -->
  <section class="features-strip" id="how-it-works">
    <div class="features-inner">
      <div class="feature-item animate-fade animate-delay-1">
        <div class="feature-icon icon-green"><i class="fas fa-search"></i></div>
        <div class="feature-title">Tìm sân</div>
        <div class="feature-desc">Chọn ngày, giờ và loại sân bạn muốn chơi</div>
      </div>
      <div class="feature-item animate-fade animate-delay-2">
        <div class="feature-icon icon-blue"><i class="fas fa-calendar-check"></i></div>
        <div class="feature-title">Chọn giờ</div>
        <div class="feature-desc">Xem bảng thời gian và chọn khung giờ trống</div>
      </div>
      <div class="feature-item animate-fade animate-delay-3">
        <div class="feature-icon icon-orange"><i class="fas fa-qrcode"></i></div>
        <div class="feature-title">Thanh toán</div>
        <div class="feature-desc">Quét mã QR chuyển khoản và upload ảnh bill</div>
      </div>
      <div class="feature-item animate-fade animate-delay-4">
        <div class="feature-icon" style="background:#fce7f3; color:#ec4899;"><i class="fas fa-check-circle"></i></div>
        <div class="feature-title">Xác nhận</div>
        <div class="feature-desc">Admin duyệt đơn, bạn nhận xác nhận thành công!</div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div>
        <div class="footer-brand"><i class="fas fa-futbol"></i> ĐặtSân.vn</div>
        <p class="footer-desc">Hệ thống đặt sân bóng đá online nhanh chóng và tiện lợi. Tìm sân, chọn giờ, đặt chỗ dễ dàng.</p>
      </div>
      <div>
        <div class="footer-title">Liên kết</div>
        <ul class="footer-links">
          <li><a href="/">Trang chủ</a></li>
          <li><a href="/fields">Danh sách sân</a></li>
          <li><a href="/auth/register">Đăng ký</a></li>
        </ul>
      </div>
      <div>
        <div class="footer-title">Hỗ trợ</div>
        <ul class="footer-links">
          <li><a href="#">Hướng dẫn đặt sân</a></li>
          <li><a href="#">Câu hỏi thường gặp</a></li>
          <li><a href="#">Liên hệ</a></li>
        </ul>
      </div>
      <div>
        <div class="footer-title">Kết nối</div>
        <ul class="footer-links">
          <li><a href="#"><i class="fab fa-facebook"></i> Facebook</a></li>
          <li><a href="#"><i class="fab fa-instagram"></i> Instagram</a></li>
          <li><a href="#"><i class="fas fa-phone"></i> 0912.345.678</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      © 2026 ĐặtSân.vn — Hệ thống đặt sân bóng đá online. All rights reserved.
    </div>
  </footer>

  <script>
    // Navbar scroll effect
    window.addEventListener('scroll', () => {
      document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 10);
    });
  </script>

</body>
</html>
