<!-- ===== SELECTED ARENAS ===== -->
<section class="relative -mt-20 z-20 max-w-8xl mx-auto mb-20 px-4 sm:px-8">
  <div class="bg-white rounded-[3rem] p-10 sm:p-20 shadow-[0_20px_50px_-10px_rgba(0,0,0,0.05)] w-full">
    
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
      <div class="w-full">
        <h2 class="text-3xl sm:text-5xl font-black italic text-[#0b1c30] tracking-tighter mb-2">SELECTED ARENAS</h2>
        <div class="flex justify-between items-center w-full mt-4">
          <p class="text-[10px] uppercase font-['Space_Grotesk'] tracking-[0.15em] text-gray-400 font-bold">PREMIER ENVIRONMENTS FOR ELITE PLAY.</p>
