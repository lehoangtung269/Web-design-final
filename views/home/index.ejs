             alt="Velocity Courts">
        <div class="absolute inset-0 bg-gradient-to-t from-[#0b1c30]/90 via-[#0b1c30]/40 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-8">
          <p class="text-[9px] text-white/70 uppercase font-['Space_Grotesk'] tracking-[0.2em] font-bold mb-2">WEST END</p>
          <h3 class="text-white text-3xl font-black italic tracking-tighter mb-3">Velocity Courts</h3>
          <p class="text-white/80 text-sm font-light leading-relaxed">FIBA-grade maple hardwood designed for explosive athletic movement.</p>
        </div>
      </a>

      <!-- Card 3 -->
      <a href="/fields" class="group block h-[550px] relative overflow-hidden rounded-[2rem] transform hover:-translate-y-2 transition-all duration-700 shadow-sm hover:shadow-2xl">
        <img class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" 
             src="https://lh3.googleusercontent.com/aida-public/AB6AXuDz4T_45H1mP22F3rQ8bQZ-lYk6J5bC4l9z6B7D_p8G3G8d6V4qH3Z1-M9l9Q0C24m_yK9E143tY5z5O15qL8-I4M5j1iC7Y9o8O1J2V-m4m-vJ32_4P7D8cW1U6T-y2K0X2zJ4_I4R1S2W_rL7v6eX11i9M011jQ" 
             alt="Azure Club">
        <div class="absolute inset-0 bg-gradient-to-t from-[#0b1c30]/90 via-[#0b1c30]/40 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-8">
          <p class="text-[9px] text-white/70 uppercase font-['Space_Grotesk'] tracking-[0.2em] font-bold mb-2">SOUTH GROUNDS</p>
          <h3 class="text-white text-3xl font-black italic tracking-tighter mb-3">Azure Club</h3>
          <p class="text-white/80 text-sm font-light leading-relaxed">Championship-level hard courts providing consistent medium-fast pace.</p>
        </div>
      </a>

    </div>
  </div>
</section>

<!-- ===== FLOATING SEARCH BAR ===== -->
<section class="relative z-30 -mt-24 mb-16 px-4">
  <div class="max-w-4xl mx-auto">
    <form action="/search" method="GET" class="bg-white/90 backdrop-blur-xl p-4 rounded-xl flex flex-col md:flex-row gap-4 items-center shadow-[0_15px_40px_-5px_rgba(0,0,0,0.1)] border border-gray-100">
      
      <!-- Location Input -->
      <div class="flex-1 w-full pl-6 pr-4 py-2 flex gap-4 items-center border-b md:border-b-0 md:border-r border-gray-200">
        <span class="material-symbols-outlined text-gray-400 text-[20px]">search</span>
        <div class="flex flex-col w-full">
          <label class="text-[8px] uppercase font-['Space_Grotesk'] tracking-[0.2em] font-bold text-gray-400">FIND LOCATION</label>
          <input name="keyword" class="bg-transparent border-none focus:ring-0 p-0 text-[#0b1c30] text-lg font-medium placeholder-gray-300 w-full" placeholder="City, Zip, or Venue Name" type="text" />
        </div>
      </div>
      
      <!-- Date Input -->
      <div class="flex-1 w-full pl-6 pr-4 py-2 flex gap-4 items-center">
        <span class="material-symbols-outlined text-gray-400 text-[20px]">calendar_today</span>
        <div class="flex flex-col w-full">
          <label class="text-[8px] uppercase font-['Space_Grotesk'] tracking-[0.2em] font-bold text-gray-400">DATE</label>
          <input name="date" class="bg-transparent border-none focus:ring-0 p-0 text-[#0b1c30] text-lg font-medium outline-none w-full" type="date" value="<%= (() => { const d = new Date(); return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0'); })() %>" />
        </div>
      </div>
      
      <!-- Search Button -->
      <button type="submit" class="w-full md:w-auto h-16 w-16 bg-[#6a37d3] hover:bg-[#ae8dff] text-white rounded-xl shadow-[0_10px_25px_-5px_rgba(107,56,212,0.4)] hover:-translate-y-1 transition-all duration-300 flex items-center justify-center flex-shrink-0 group">
        <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
      </button>

    </form>
  </div>
</section>