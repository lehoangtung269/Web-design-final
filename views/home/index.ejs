    <!-- Primary CTA -->
    <a href="/fields" class="bg-[#ae8dff] hover:bg-[#6a37d3] text-white px-10 py-4 rounded-full text-[10px] sm:text-xs uppercase tracking-[0.2em] font-['Space_Grotesk'] font-bold shadow-[0_10px_25px_-5px_rgba(107,56,212,0.4)] hover:shadow-[0_15px_35px_-5px_rgba(107,56,212,0.6)] transform hover:-translate-y-1 transition-all duration-500 animate-fade-in animate-delay-4">
