<!-- ===== HERO SECTION ===== -->
<section class="relative h-[600px] flex items-center justify-center overflow-hidden">
  <div class="absolute inset-0 z-0">
    <img class="w-full h-full object-cover"
      src="https://lh3.googleusercontent.com/aida-public/AB6AXuBMfgCMduiXkew4jpHMbApTL6fO8jeruasAFUId49kNgVzSJJsDWkaV2blSKyftwJnkBfcEW_xhZp3vVPNA9bkqUx3DX6Eo1yalFdwHD4qEMVO3xPGVa0OgJ7VPOYuZU6fGC-zowmw8ovE3EaccTHOqlk-Y-OxSZOvFaf0l4w5-Z_TjWhunHgsvzYP7VcAiUyQ4rQQaGYneBtllUiQhencaKNNPus2pB1_6vXae0y2FckEOWo0Hx3fCx6s9opAamgmPtf6fN9sX6cg"
      alt="Football stadium" />
    <div class="absolute inset-0 bg-gradient-to-r from-black/75 to-black/35"></div>
  </div>
  <div class="relative z-10 max-w-7xl mx-auto px-6 w-full text-center md:text-left">
    <div class="max-w-2xl animate-fade-in">
      <h1 class="text-5xl md:text-7xl font-extrabold text-white leading-tight tracking-tight mb-4">
        Đặt sân bóng <span class="text-primary-fixed">dễ như đặt xe</span>
      </h1>
      <p class="text-xl text-gray-300 font-medium mb-10 opacity-90">
        Hơn 500+ sân bóng chất lượng cao trên toàn quốc đang chờ bạn.
      </p>

      <!-- Search Bar Bento -->
      <form action="/search" method="GET"
        class="bg-white p-2 rounded-2xl shadow-2xl flex flex-col md:flex-row gap-2 items-stretch max-w-4xl animate-fade-in animate-delay-2">
        <div class="flex-1 flex items-center px-4 bg-gray-100 rounded-xl min-h-[56px]">
          <span class="material-symbols-outlined text-gray-400 mr-3">search</span>
          <input name="keyword"
            class="bg-transparent border-none focus:ring-0 w-full text-gray-900 font-medium placeholder-gray-400"
            placeholder="Tìm khu vực, tên sân..." type="text" />
        </div>
        <div class="flex-1 flex items-center px-4 bg-gray-100 rounded-xl min-h-[56px]">
          <span class="material-symbols-outlined text-gray-400 mr-3">calendar_today</span>
          <input name="date" class="bg-transparent border-none focus:ring-0 w-full text-gray-900 font-medium"
            type="date" value="<%= new Date().toISOString().split('T')[0] %>" />
        </div>
        <div class="flex-1 flex items-center px-4 bg-gray-100 rounded-xl min-h-[56px]">
          <span class="material-symbols-outlined text-gray-400 mr-3">groups</span>
          <select name="type"
            class="bg-transparent border-none focus:ring-0 w-full text-gray-900 font-medium cursor-pointer">
            <option value="all">Tất cả loại sân</option>
            <option value="5-a-side">Sân 5 người</option>
            <option value="7-a-side">Sân 7 người</option>
            <option value="11-a-side">Sân 11 người</option>
          </select>
        </div>
        <button type="submit"
          class="bg-primary hover:bg-emerald-700 text-white px-8 py-4 rounded-xl font-bold flex items-center justify-center gap-2 transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5 active:scale-95 group">
          <span class="material-symbols-outlined group-hover:scale-110 transition-transform">search</span>
          Tìm kiếm
        </button>
      </form>
    </div>
  </div>
</section>

<!-- ===== STATS BAR ===== -->
<section class="bg-primary py-8">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-8">
    <div class="flex flex-col items-center text-white">
      <span class="text-4xl font-black mb-1">500+</span>
      <span class="text-sm font-bold uppercase tracking-widest opacity-80">Sân bóng</span>
    </div>
    <div class="flex flex-col items-center text-white">
      <span class="text-4xl font-black mb-1">10,000+</span>
      <span class="text-sm font-bold uppercase tracking-widest opacity-80">Trận mỗi tháng</span>
    </div>
    <div class="flex flex-col items-center text-white">
      <span class="text-4xl font-black mb-1">50,000+</span>
      <span class="text-sm font-bold uppercase tracking-widest opacity-80">Người dùng</span>
    </div>
  </div>
</section>

<!-- ===== HOW IT WORKS ===== -->
<section class="py-24 bg-surface">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <span class="text-primary font-bold text-sm uppercase tracking-widest mb-4 block">Quy trình đơn giản</span>
      <h2 class="text-4xl font-extrabold text-on-surface tracking-tight">Bắt đầu trận đấu chỉ sau 3 bước</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <div class="flex flex-col items-center text-center group animate-fade-in animate-delay-1">
        <div
          class="w-20 h-20 bg-primary-container text-white rounded-3xl flex items-center justify-center mb-6 shadow-xl transition-all group-hover:-translate-y-2 group-hover:shadow-2xl">
          <span class="material-symbols-outlined text-4xl">search</span>
        </div>
        <h3 class="text-xl font-bold mb-3">Tìm kiếm</h3>
        <p class="text-on-surface-variant leading-relaxed">Chọn khu vực gần bạn và sân bóng mong muốn với bộ lọc thông
          minh.</p>
      </div>
      <div class="flex flex-col items-center text-center group animate-fade-in animate-delay-2">
        <div
          class="w-20 h-20 bg-tertiary-container text-white rounded-3xl flex items-center justify-center mb-6 shadow-xl transition-all group-hover:-translate-y-2 group-hover:shadow-2xl">
          <span class="material-symbols-outlined text-4xl">event_available</span>
        </div>
        <h3 class="text-xl font-bold mb-3">Chọn giờ</h3>
        <p class="text-on-surface-variant leading-relaxed">Kiểm tra lịch trống thời gian thực và chọn khung giờ thi đấu
          phù hợp.</p>
      </div>
      <div class="flex flex-col items-center text-center group animate-fade-in animate-delay-3">
        <div
          class="w-20 h-20 bg-primary text-white rounded-3xl flex items-center justify-center mb-6 shadow-xl transition-all group-hover:-translate-y-2 group-hover:shadow-2xl">
          <span class="material-symbols-outlined text-4xl">verified</span>
        </div>
        <h3 class="text-xl font-bold mb-3">Xác nhận</h3>
        <p class="text-on-surface-variant leading-relaxed">Nhận xác nhận tức thì qua ứng dụng và sẵn sàng ra sân tỏa
          sáng.</p>
      </div>
    </div>
  </div>
</section>

<!-- ===== FEATURED FIELDS (DYNAMIC) ===== -->
<section class="py-24 bg-surface-container-low">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
      <div class="max-w-xl">
        <h2 class="text-4xl font-extrabold text-on-surface tracking-tight mb-4">Sân bóng nổi bật</h2>
        <p class="text-on-surface-variant">Danh sách các sân được cộng đồng đánh giá cao nhất về chất lượng cỏ và dịch
          vụ.</p>
      </div>
      <a href="/fields"
        class="flex items-center gap-2 font-bold text-primary hover:opacity-80 transition-all border-b-2 border-primary/20 pb-1 hover:gap-3">
        Xem tất cả
        <span class="material-symbols-outlined">arrow_forward</span>
      </a>
    </div>

    <% if (featuredFields && featuredFields.length> 0) { %>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <% featuredFields.forEach((field, idx)=> { %>
          <a href="/fields/<%= field._id %>"
            class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border-none block group animate-fade-in animate-delay-<%= idx + 1 %>">
            <div class="relative h-64 overflow-hidden">
              <% if (field.images && field.images.length> 0) { %>
                <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                  src="<%= field.images[0] %>" alt="<%= field.name %>" />
                <% } else { %>
                  <div
                    class="w-full h-full bg-gradient-to-br from-emerald-100 to-cyan-100 flex items-center justify-center">
                    <span class="material-symbols-outlined text-7xl text-emerald-300">sports_soccer</span>
                  </div>
                  <% } %>
                    <div
                      class="absolute top-4 right-4 <%= field.type === '5-a-side' ? 'bg-emerald-500' : field.type === '7-a-side' ? 'bg-sky-500' : 'bg-orange-500' %> text-white px-3 py-1 rounded-full text-xs font-black uppercase tracking-widest">
                      <%= field.type==='5-a-side' ? 'Sân 5' : field.type==='7-a-side' ? 'Sân 7' : 'Sân 11' %>
                    </div>
            </div>
            <div class="p-6">
              <h4 class="text-xl font-bold text-on-surface mb-2">
                <%= field.name %>
              </h4>
              <div class="flex items-center gap-2 text-on-surface-variant text-sm mb-6">
                <span class="material-symbols-outlined text-sm">location_on</span>
                <%= field.address %>
              </div>
              <div class="flex items-center justify-between">
                <div class="flex flex-col">
                  <span class="text-xs text-on-surface-variant font-bold uppercase">Giá từ</span>
                  <span class="text-lg font-black text-primary">
                    <%= field.pricePerSlot.toLocaleString('vi-VN') %>đ<span
                        class="text-sm font-medium text-on-surface-variant">/slot</span>
                  </span>
                </div>
                <span
                  class="bg-gray-100 group-hover:bg-primary group-hover:text-white text-on-surface px-4 py-2 rounded-xl font-bold transition-all duration-200 text-sm">
                  Đặt ngay →
                </span>
              </div>
            </div>
          </a>
          <% }); %>
      </div>
      <% } else { %>
        <div class="text-center py-16 text-on-surface-variant">
          <span class="material-symbols-outlined text-6xl text-gray-300 mb-4 block">sports_soccer</span>
          <p class="text-lg mb-2">Chưa có sân nào trong hệ thống.</p>
          <p class="text-sm">Vui lòng quay lại sau hoặc liên hệ admin để thêm sân.</p>
        </div>
        <% } %>
  </div>
</section>

