<section class="relative overflow-hidden px-6 md:px-10 pb-20">
  <div class="max-w-7xl mx-auto relative">
    <div
      class="absolute -left-16 top-16 hidden lg:block w-56 h-72 rounded-3xl overflow-hidden -rotate-6 shadow-ambient">
      <img src="https://images.unsplash.com/photo-1574629810360-7efbbe195018?auto=format&fit=crop&w=800&q=80"
        alt="Cỏ sân bóng" class="w-full h-full object-cover" loading="lazy" />
    </div>
    <div
      class="absolute -right-12 bottom-14 hidden lg:block w-60 h-72 rounded-3xl overflow-hidden rotate-6 shadow-ambient">
      <img src="https://images.unsplash.com/photo-1579952363873-27f3bade9f55?auto=format&fit=crop&w=800&q=80"
        alt="Góc sân bóng" class="w-full h-full object-cover" loading="lazy" />
    </div>

    <div class="pt-14 md:pt-20 text-center">
      <p class="kinetic-label text-on-surface-variant mb-4">The Kinetic Archive</p>
      <h1 class="kinetic-display text-5xl md:text-7xl lg:text-8xl leading-[0.95] text-on-surface">REDEFINE</h1>
      <h1 class="kinetic-display text-5xl md:text-7xl lg:text-8xl leading-[0.95] text-primary -mt-1 md:-mt-3">THE MATCH
      </h1>
      <p class="max-w-2xl mx-auto mt-7 text-on-surface-variant font-light text-lg">
        Nâng tầm trận đấu của bạn với hệ thống sân bóng chất lượng cao và quy trình đặt sân thông minh, chuyên nghiệp.
      </p>
      <a href="/fields" id="hero-explore-cta"
        class="inline-flex items-center gap-2 mt-9 rounded-full bg-gradient-to-r from-primary to-primary-container text-white px-7 py-3.5 font-semibold transition-all duration-500 hover:-translate-y-1 hover:shadow-cta-glow">
        Explore Venues
        <span class="material-symbols-outlined">arrow_outward</span>
      </a>
    </div>
  </div>
</section>

<section id="about" class="px-6 md:px-10 pb-20">
  <div class="max-w-7xl mx-auto rounded-2xl bg-surface-container-low p-6 md:p-10">
    <div class="flex items-center justify-between gap-4 mb-8">
      <div>
        <p class="kinetic-label text-on-surface-variant">Premier environments for elite play</p>
        <h2 class="kinetic-headline text-3xl md:text-5xl text-on-surface">SELECTED ARENAS</h2>
      </div>
      <a href="/fields" class="text-sm font-semibold text-primary hover:underline underline-offset-4">View all
        directory</a>
    </div>

    <% if (featuredFields && featuredFields.length> 0) { %>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <% featuredFields.slice(0, 3).forEach((field)=> { %>
          <a href="/fields/<%= field._id %>"
            class="group rounded-2xl bg-surface-container-lowest overflow-hidden transition-all duration-500 hover:-translate-y-2 hover:shadow-ambient">
            <div class="h-64 overflow-hidden">
              <% if (field.images && field.images.length> 0) { %>
                <img src="<%= field.images[0] %>" alt="<%= field.name %>"
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                  loading="lazy" />
                <% } else { %>
                  <div class="w-full h-full bg-surface-container flex items-center justify-center">
                    <span class="material-symbols-outlined text-6xl text-on-surface-variant/60">sports_soccer</span>
                  </div>
                  <% } %>
            </div>
            <div class="p-5">
              <p class="kinetic-label text-on-surface-variant mb-1">
                <%= field.type %> venue
              </p>
              <h3 class="text-2xl font-semibold text-on-surface mb-2">
                <%= field.name %>
              </h3>
              <p class="text-sm text-on-surface-variant mb-4 line-clamp-2">
                <%= field.address %>
              </p>
              <p class="kinetic-label text-on-surface-variant">From <span
                  class="not-italic normal-case tracking-normal font-semibold text-on-surface ml-1">
                  <%= field.pricePerSlot.toLocaleString('vi-VN') %>d / slot
                </span></p>
            </div>
          </a>
          <% }) %>
      </div>
      <% } else { %>
        <div class="rounded-2xl bg-surface-container-lowest p-10 text-center">
          <div class="w-20 h-20 bg-surface-container rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="material-symbols-outlined text-4xl text-on-surface-variant">sports_soccer</span>
          </div>
          <h3 class="kinetic-headline text-xl text-on-surface mb-2">CHƯA CÓ SÂN NỔI BẬT</h3>
          <p class="text-on-surface-variant font-light">Vui lòng quay lại sau để khám phá những sân bóng tốt nhất.</p>
        </div>
        <% } %>
  </div>
</section>

<section class="px-6 md:px-10 pb-20">
  <div class="max-w-7xl mx-auto rounded-2xl bg-surface-container p-5 md:p-7">
    <form action="/search" method="GET" id="home-search-form"
      class="grid grid-cols-1 md:grid-cols-[1fr_1fr_220px_64px] gap-3">
      <label class="flex items-center gap-2 rounded-full bg-white px-4 py-3 text-sm">
        <span class="material-symbols-outlined text-on-surface-variant">search</span>
        <input name="keyword" type="text" placeholder="City, district, venue name"
          class="w-full border-none focus:ring-0 p-0 bg-transparent" />
      </label>
      <label class="flex items-center gap-2 rounded-full bg-white px-4 py-3 text-sm">
        <span class="material-symbols-outlined text-on-surface-variant">calendar_today</span>
        <input name="date" type="date"
          value="<%= (() => { const d = new Date(); return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0'); })() %>"
          class="w-full border-none focus:ring-0 p-0 bg-transparent" />
      </label>
      <label class="flex items-center gap-2 rounded-full bg-white px-4 py-3 text-sm">
        <span class="material-symbols-outlined text-on-surface-variant">groups</span>
        <select name="type" class="w-full border-none focus:ring-0 p-0 bg-transparent">
          <option value="all">All formats</option>
          <option value="5-a-side">5-a-side</option>
          <option value="7-a-side">7-a-side</option>
          <option value="11-a-side">11-a-side</option>
        </select>
      </label>
      <button type="submit"
        class="rounded-full bg-primary text-white flex items-center justify-center transition-all duration-500 hover:-translate-y-1 hover:shadow-cta-glow"
        aria-label="Tim san">
        <span class="material-symbols-outlined">arrow_forward</span>
      </button>
    </form>
  </div>
</section>

<section id="policy" class="px-6 md:px-10 pb-10">
  <div class="max-w-7xl mx-auto text-center">
    <p class="kinetic-label text-on-surface-variant">Policy and transparency</p>
    <p class="mt-2 text-sm text-on-surface-variant">
      Bằng việc tiếp tục sử dụng nền tảng, bạn đồng ý với điều khoản sử dụng và chính sách bảo mật của DatSan.vn.
    </p>
  </div>
</section>

<script>
  if (window.DatSanAnalytics) {
    window.DatSanAnalytics.track('home_view', { section: 'kinetic-home' });

    const heroCTA = document.getElementById('hero-explore-cta');
    const heroVariant = window.DatSanAnalytics.getVariant('hero_cta_copy');
    if (heroCTA && heroVariant === 'B') {
      heroCTA.firstChild.textContent = ' Kham pha san ngay ';
    }
    if (heroCTA) {
      heroCTA.addEventListener('click', function () {
        window.DatSanAnalytics.track('hero_cta_click', { cta: 'explore_venues', variant: heroVariant });
      });
    }

    const homeSearchForm = document.getElementById('home-search-form');
    if (homeSearchForm) {
      homeSearchForm.addEventListener('submit', function () {
        window.DatSanAnalytics.track('search_submit', { source: 'home_strip' });
      });
    }
  }
</script>