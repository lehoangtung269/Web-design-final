        <div class="absolute bottom-0 left-0 right-0 p-8">
          <p class="text-[9px] text-white/70 uppercase font-['Space_Grotesk'] tracking-[0.2em] font-bold mb-2">DOWNTOWN CORE</p>
          <h3 class="text-white text-3xl font-black italic tracking-tighter mb-3">The Apex Pitch</h3>
          <p class="text-white/80 text-sm font-light leading-relaxed">Elevated synthetic turf with panoramic city views and premium lighting.</p>
        </div>
      </a>

      <!-- Card 2 -->
      <a href="/fields" class="group block h-[550px] relative overflow-hidden rounded-[2rem] transform hover:-translate-y-2 transition-all duration-700 shadow-sm hover:shadow-2xl">
        <img class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" 
