<!-- Custom styles for checkout file input -->
<style>
  .custom-file-input::-webkit-file-upload-button { visibility: hidden; display: none; }
  .custom-file-input::before {
    content: 'Tải ảnh lên';
    display: inline-block;
    background: #059669;
    color: white;
    border-radius: 8px;
    padding: 8px 16px;
    cursor: pointer;
    font-weight: 600;
    font-size: 0.875rem;
    transition: background 0.2s;
  }
  .custom-file-input:hover::before { background: #047857; }
</style>

<div class="max-w-4xl mx-auto px-6 py-10 animate-fade-in">
  <div class="text-center mb-8">
    <h1 class="text-3xl font-extrabold text-on-surface tracking-tight flex items-center justify-center gap-2">
      <span class="material-symbols-outlined text-primary text-3xl">payments</span>
      Thanh toán đặt sân
    </h1>
    <p class="text-on-surface-variant mt-2">Vui lòng kiểm tra thông tin và tải lên biên lai chuyển khoản để hoàn tất.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-[1.5fr_1fr] gap-8">
    <!-- LEFT: Thông tin Booking -->
    <div>
      <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 mb-6">
        <h2 class="text-lg font-bold text-on-surface mb-4 border-b border-slate-100 pb-2">Thông tin sân bóng</h2>
        <div class="space-y-4">
          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-1">Tên sân</label>
            <div class="text-lg font-semibold text-on-surface"><%= field.name %></div>
          </div>
          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-1">Loại sân</label>
            <div class="inline-flex items-center gap-1.5 px-3 py-1 bg-slate-100 text-slate-700 rounded-lg text-sm font-medium">
              <span class="material-symbols-outlined text-sm">groups</span>
              <%= field.type === '5-a-side' ? 'Sân 5 người' : field.type === '7-a-side' ? 'Sân 7 người' : 'Sân 11 người' %>
            </div>
          </div>
          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-1">Địa chỉ</label>
            <div class="text-sm text-on-surface-variant"><%= field.address %></div>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
        <h2 class="text-lg font-bold text-on-surface mb-4 border-b border-slate-100 pb-2">Thời gian thi đấu</h2>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-1">Ngày đá</label>
            <div class="text-base font-semibold text-emerald-700 bg-emerald-50 px-4 py-2 rounded-xl inline-block">
              <%= new Date(bookingDate).toLocaleDateString('vi-VN', { weekday: 'long', day: '2-digit', month: '2-digit', year: 'numeric' }) %>
            </div>
          </div>
          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-1">Khung giờ</label>
            <div class="text-base font-semibold text-sky-700 bg-sky-50 px-4 py-2 rounded-xl inline-block">
              <%= startTime %> - <%= endTime %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- RIGHT: Thanh toán & Upload -->
    <div>
      <div class="bg-surface-container-lowest rounded-2xl shadow-lg border-2 border-emerald-100 p-6 sticky top-24">
        <h2 class="text-lg font-bold text-on-surface mb-6 border-b border-slate-100 pb-2 flex items-center gap-2">
          <span class="material-symbols-outlined text-emerald-600">account_balance_wallet</span>
          Chi tiết thanh toán
        </h2>

        <div class="flex justify-between items-center mb-4">
          <span class="text-slate-500">Giá 1 slot</span>
          <span class="font-semibold"><%= field.pricePerSlot.toLocaleString('vi-VN') %>đ</span>
        </div>
        <div class="flex justify-between items-center mb-6 pt-4 border-t border-slate-100">
          <span class="text-slate-700 font-bold">Tổng thanh toán</span>
          <span class="text-2xl font-black text-primary"><%= totalPrice.toLocaleString('vi-VN') %>đ</span>
        </div>

        <div class="bg-slate-50 rounded-xl p-4 mb-6 border border-slate-200">
          <p class="text-xs text-slate-500 uppercase font-bold tracking-widest mb-3">Thông tin chuyển khoản</p>
          <div class="space-y-2 text-sm text-on-surface">
            <div class="flex justify-between">
              <span class="text-slate-500">Ngân hàng</span>
              <span class="font-bold">Vietcombank</span>
            </div>
            <div class="flex justify-between">
              <span class="text-slate-500">Chủ tài khoản</span>
              <span class="font-bold">DAT SAN VN</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-slate-500">Số tài khoản</span>
              <span class="font-bold text-emerald-700 text-lg">19039281928</span>
            </div>
            <div class="mt-3 pt-3 border-t border-slate-200 text-center">
              <span class="text-xs text-slate-500 mb-1 block">Nội dung chuyển khoản:</span>
              <strong class="text-sky-700 bg-sky-50 px-3 py-1 rounded">DATSAN <%= currentUser.phone %></strong>
            </div>
          </div>
        </div>

        <form action="/checkout" method="POST" enctype="multipart/form-data">
          <input type="hidden" name="fieldId" value="<%= field._id %>" />
          <input type="hidden" name="slotId" value="<%= slot._id %>" />
          <input type="hidden" name="bookingDate" value="<%= bookingDate %>" />
          <input type="hidden" name="startTime" value="<%= startTime %>" />
          <input type="hidden" name="endTime" value="<%= endTime %>" />
          <input type="hidden" name="totalPrice" value="<%= totalPrice %>" />

          <div class="mb-6">
            <label class="block text-sm font-bold text-slate-700 mb-2">
              Tải lên biên lai / ảnh chụp màn hình CK <span class="text-red-500">*</span>
            </label>
            <input type="file" name="paymentImage" accept="image/*" required
                   class="custom-file-input block w-full text-sm text-slate-500 cursor-pointer" />
          </div>

          <button type="submit" class="w-full bg-primary hover:bg-emerald-700 text-white py-4 rounded-xl font-bold flex items-center justify-center gap-2 transition-all hover:shadow-lg hover:-translate-y-0.5">
            <span class="material-symbols-outlined">check_circle</span>
            Xác nhận thanh toán & Đặt sân
          </button>
        </form>
      </div>
    </div>
  </div>
</div>