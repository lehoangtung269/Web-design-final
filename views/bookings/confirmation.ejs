<div class="max-w-3xl mx-auto px-6 py-10 animate-fade-in text-center">

  <% if (booking.status==='pending' ) { %>
    <div
      class="w-24 h-24 mx-auto bg-amber-50 rounded-full border-4 border-amber-100 flex items-center justify-center mb-6">
      <span class="material-symbols-outlined text-5xl text-amber-500">hourglass_empty</span>
    </div>
    <h1 class="text-3xl font-extrabold text-slate-800 tracking-tight mb-3">Đang xử lý đơn</h1>
    <p class="text-slate-500 mb-8 max-w-lg mx-auto">
      Yêu cầu đặt sân của bạn đã được ghi nhận.<br />
      Đơn đang chờ Admin kiểm tra bill và duyệt.
    </p>
    <div
      class="inline-flex items-center gap-2 bg-amber-50 border border-amber-200 text-amber-600 px-4 py-2 rounded-full text-sm font-bold mb-10 shadow-sm">
      <span class="w-2 h-2 rounded-full bg-amber-500 animate-pulse block"></span> Đang chờ duyệt
    </div>
    <% } else if (booking.status==='confirmed' ) { %>
      <div
        class="w-24 h-24 mx-auto bg-surface-container-low rounded-full border-4 border-outline-variant flex items-center justify-center mb-6">
        <span class="material-symbols-outlined text-5xl text-primary">check</span>
      </div>
      <h1 class="text-3xl font-extrabold text-slate-800 tracking-tight mb-3">Đặt sân thành công!</h1>
      <p class="text-slate-500 mb-8 max-w-lg mx-auto">
        Sân bóng đã được chuẩn bị sẵn sàng cho bạn.<br />
        Vui lòng đến đúng giờ để trải nghiệm tốt nhất!
      </p>
      <div
        class="inline-flex items-center gap-2 bg-surface-container-low border border-outline-variant text-primary px-4 py-2 rounded-full text-sm font-bold mb-10 shadow-sm">
        <span class="material-symbols-outlined text-base">verified</span> Đã duyệt thành công
      </div>
      <% } else { %>
        <div
          class="w-24 h-24 mx-auto bg-red-50 rounded-full border-4 border-red-100 flex items-center justify-center mb-6">
          <span class="material-symbols-outlined text-5xl text-red-500">close</span>
        </div>
        <h1 class="text-3xl font-extrabold text-red-600 tracking-tight mb-3">Đơn đã bị từ chối</h1>
        <p class="text-slate-500 mb-8 max-w-lg mx-auto">
          Rất tiếc yêu cầu đặt sân của bạn đã bị từ chối.<br />
          Lý do: <strong class="text-slate-700">
            <%= booking.rejectedReason || 'Không cung cấp' %>
          </strong>
        </p>
        <div
          class="inline-flex items-center gap-2 bg-red-50 border border-red-200 text-red-600 px-4 py-2 rounded-full text-sm font-bold mb-10 shadow-sm">
          <span class="material-symbols-outlined text-base">warning</span> Đã bị từ chối Admin
        </div>
        <% } %>

          <div class="bg-surface-container-low rounded-2xl p-8 mb-8 text-left shadow-ambient">
            <p class="kinetic-label text-on-surface-variant mb-6 text-center">Tiến trình xử lý đơn hàng</p>

            <div class="relative max-w-lg mx-auto">
              <div class="absolute left-6 top-6 bottom-6 w-0.5 bg-outline-variant/30"></div>

              <div class="relative flex items-center gap-6 mb-8 group animate-fade-in">
                <div
                  class="w-12 h-12 rounded-full <%= booking.status === 'pending' || booking.status === 'confirmed' ? 'bg-primary text-white shadow-cta-glow' : 'bg-surface-container text-on-surface-variant' %> flex items-center justify-center shrink-0 z-10 transition-all duration-300">
                  <span class="material-symbols-outlined text-[20px]">
                    <%= booking.status==='pending' || booking.status==='confirmed' ? 'check' : 'pending_actions' %>
                  </span>
                </div>
                <div
                  class="bg-white p-5 rounded-2xl border border-outline-variant/20 shadow-sm flex-1 group-hover:-translate-y-1 transition-transform duration-300">
                  <p class="kinetic-label text-primary mb-1">01. ĐÃ TIẾP NHẬN</p>
                  <p class="text-on-surface font-light text-sm">Hệ thống đã lưu đơn và ảnh bill trên hệ thống của bạn.
                  </p>
                </div>
              </div>

              <div class="relative flex items-center gap-6 mb-8 group animate-fade-in animate-delay-1">
                <div
                  class="w-12 h-12 rounded-full <%= booking.status === 'pending' ? 'bg-primary-container text-primary shadow-sm animate-pulse' : booking.status === 'confirmed' ? 'bg-primary text-white shadow-cta-glow' : 'bg-surface-container text-on-surface-variant' %> flex items-center justify-center shrink-0 z-10 transition-all duration-300">
                  <span class="material-symbols-outlined text-[20px]">admin_panel_settings</span>
                </div>
                <div
                  class="bg-white p-5 rounded-2xl border border-outline-variant/20 shadow-sm flex-1 group-hover:-translate-y-1 transition-transform duration-300">
                  <p class="kinetic-label text-on-surface-variant mb-1">02. ĐANG ĐỢI DUYỆT</p>
                  <p class="text-on-surface font-light text-sm">Admin đang kiểm tra giao dịch (dự kiến 5-30 phút).</p>
                </div>
              </div>

              <div class="relative flex items-center gap-6 group animate-fade-in animate-delay-2">
                <div
                  class="w-12 h-12 rounded-full <%= booking.status === 'confirmed' ? 'bg-primary text-white shadow-cta-glow' : booking.status === 'rejected' ? 'bg-error text-white shadow-sm' : 'bg-surface-container text-on-surface-variant' %> flex items-center justify-center shrink-0 z-10 transition-all duration-300">
                  <span class="material-symbols-outlined text-[20px]">
                    <%= booking.status==='confirmed' ? 'check_circle' : booking.status==='rejected' ? 'cancel'
                      : 'where_to_vote' %>
                  </span>
                </div>
                <div
                  class="bg-white p-5 rounded-2xl border border-outline-variant/20 shadow-sm flex-1 group-hover:-translate-y-1 transition-transform duration-300">
                  <p class="kinetic-label text-on-surface-variant mb-1">03. KẾT QUẢ</p>
                  <p class="text-on-surface font-light text-sm">Thông báo xác nhận đơn hoặc lý do từ chối đơn sân.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Booking Detail Card -->
          <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-8 text-left mb-8">
            <h2 class="text-lg font-bold text-slate-800 mb-6 flex items-center gap-2 border-b border-slate-100 pb-3">
              <span class="material-symbols-outlined text-primary">receipt_long</span>
              Chi tiết đơn đặt sân
            </h2>
            <div class="space-y-4">
              <div class="flex justify-between items-center py-2">
                <span class="text-slate-500 text-sm">Mã đơn</span>
                <span class="font-mono text-xs text-slate-500 bg-slate-50 px-2 py-1 rounded">
                  <%= booking._id %>
                </span>
              </div>
              <% if (booking.bookingCode) { %>
                <div class="flex justify-between items-center py-2 border-t border-slate-50">
                  <span class="text-slate-500 text-sm">Mã tại sân</span>
                  <span class="font-bold text-slate-800 bg-amber-50 text-amber-600 px-3 py-1 rounded-lg">
                    <%= booking.bookingCode %>
                  </span>
                </div>
                <% } %>
                  <div class="flex justify-between items-center py-2 border-t border-slate-50">
                    <span class="text-slate-500 text-sm">Sân bóng</span>
                    <span class="font-bold text-slate-800">
                      <%= booking.field ? booking.field.name : 'N/A' %>
                    </span>
                  </div>
                  <div class="flex justify-between items-center py-2 border-t border-slate-50">
                    <span class="text-slate-500 text-sm">Ngày đá</span>
                    <span class="font-semibold text-slate-800">
                      <%= new Date(booking.date).toLocaleDateString('vi-VN', { weekday: 'long' , day: '2-digit' ,
                        month: '2-digit' , year: 'numeric' }) %>
                    </span>
                  </div>
                  <div class="flex justify-between items-center py-2 border-t border-slate-50">
                    <span class="text-slate-500 text-sm">Khung giờ</span>
                    <span class="font-semibold text-primary bg-surface-container-low px-3 py-1 rounded-lg">
                      <%= booking.startTime %> — <%= booking.endTime %>
                    </span>
                  </div>
                  <div class="flex justify-between items-center py-2 border-t border-slate-50">
                    <span class="text-slate-500 text-sm">Ảnh bill</span>
                    <% if (booking.paymentImage) { %>
                      <a href="<%= booking.paymentImage %>" target="_blank"
                        class="inline-flex items-center gap-1 text-sm font-bold text-primary hover:text-sky-700">
                        <span class="material-symbols-outlined text-[16px]">image</span> Xem ảnh
                      </a>
                      <% } else { %>
                        <span class="inline-flex items-center gap-1 text-sm font-bold text-red-500">
                          <span class="material-symbols-outlined text-[16px]">image_not_supported</span> Chưa upload
                        </span>
                        <% } %>
                  </div>
                  <div class="flex justify-between items-center py-4 mt-2 border-t-2 border-slate-100">
                    <span class="text-slate-600 font-bold uppercase tracking-widest text-xs">Tổng thanh toán</span>
                    <span class="font-black text-2xl text-primary">
                      <%= booking.totalPrice.toLocaleString('vi-VN') %>đ
                    </span>
                  </div>
            </div>
          </div>

          <!-- Action Buttons -->
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/history"
              class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-on-surface text-white px-6 py-3.5 rounded-xl font-bold transition-all shadow-sm hover:shadow-md hover:-translate-y-0.5 w-full sm:w-auto">
              <span class="material-symbols-outlined text-xl">history</span>
              Xem lịch sử đặt sân
            </a>
            <a href="/"
              class="inline-flex items-center justify-center gap-2 bg-white border-2 border-slate-200 text-slate-600 hover:text-slate-800 hover:border-slate-300 px-6 py-3.5 rounded-xl font-bold transition-all w-full sm:w-auto">
              <span class="material-symbols-outlined text-xl">home</span>
              Về trang chủ
            </a>
          </div>
</div>